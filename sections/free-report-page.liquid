{%- comment -%}BaseCode Root - free-report-page{%- endcomment -%}

{%- liquid
  assign primary_color = section.settings.primary_color
  assign accent_color  = section.settings.accent_color
  assign light_color   = section.settings.light_color
  assign card_bg_color = section.settings.card_bg_color

  assign hero_bullets    = section.blocks | where: "type", "hero_bullet"
  assign stat_blocks     = section.blocks | where: "type", "stat"
  assign card_blocks     = section.blocks | where: "type", "card"
  assign citation_blocks = section.blocks | where: "type", "citation"
  assign value_bullets   = section.blocks | where: "type", "value_bullet"
-%}

<!-- ═══════════════════════════════════════════════════════════════
     FREE REPORT PAGE — The Biology Gap
     Two-column layout with form card, stat bar, what's inside,
     pull quote, citations, founder note, bottom CTA
     ═══════════════════════════════════════════════════════════════ -->

<div style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

<!-- ────────────────────────────────────────────────────────────
     HERO SECTION
     ──────────────────────────────────────────────────────────── -->
<section style="background: {{ primary_color }}; padding: 142px 24px 80px;">
  <div style="max-width: 1040px; margin: 0 auto;">
    <div class="fr-hero-grid" style="display: grid; gap: 40px; align-items: center;">

      <!-- LEFT COLUMN -->
      <div>
        <p class="font-mono-spec uppercase reveal-hidden" style="font-size: 11px; color: {{ accent_color }}; letter-spacing: 0.2em; margin-bottom: 20px;">
          {{ section.settings.hero_eyebrow }}
        </p>

        <h1 class="font-display font-medium reveal-hidden" style="color: {{ light_color }}; font-size: clamp(34px, 5vw, 52px); line-height: 1.1; margin-bottom: 24px;">
          {{ section.settings.hero_heading }}
        </h1>

        <p class="font-heading font-light reveal-hidden" style="font-size: 16px; color: rgba(245,242,236,0.60); line-height: 1.7; max-width: 480px; margin-bottom: 28px;">
          {{ section.settings.hero_body }}
        </p>

        <!-- Bullet points -->
        {%- if hero_bullets.size > 0 -%}
        <ul style="list-style: none; padding: 0; margin: 0 0 32px 0;" class="reveal-hidden">
          {%- for block in hero_bullets -%}
          <li style="font-size: 14px; color: rgba(245,242,236,0.55); margin-bottom: {% if forloop.last %}0{% else %}10px{% endif %}; display: flex; align-items: baseline; gap: 10px;" {{ block.shopify_attributes }}>
            <span style="color: {{ accent_color }}; flex-shrink: 0;">&#10022;</span>
            <span class="font-heading font-light">{{ block.settings.text }}</span>
          </li>
          {%- endfor -%}
        </ul>
        {%- endif -%}

        <!-- Founder quote -->
        <div style="border-left: 2px solid {{ accent_color }}; padding-left: 20px; margin-bottom: 8px;" class="reveal-hidden">
          <p class="font-display" style="font-size: 15px; color: {{ accent_color }}; font-style: italic; line-height: 1.6;">
            {{ section.settings.hero_quote }}
          </p>
        </div>
        <p class="font-mono-spec reveal-hidden" style="font-size: 11px; color: rgba(245,242,236,0.30); padding-left: 22px;">
          &mdash; {{ section.settings.hero_quote_author }}
        </p>
      </div>

      <!-- RIGHT COLUMN — Form Card -->
      <div style="background: {{ light_color }}; border-radius: 32px; padding: 32px;" class="fr-form-card reveal-hidden" data-lead-wrapper>

        <div data-lead-form-view>
          <p class="font-mono-spec uppercase" style="font-size: 11px; color: #8A9490; letter-spacing: 0.15em; margin-bottom: 12px;">
            {{ section.settings.form_eyebrow }}
          </p>

          <h2 class="font-heading font-medium" style="font-size: 24px; color: {{ primary_color }}; line-height: 1.25; margin-bottom: 10px;">
            {{ section.settings.form_heading }}
          </h2>

          <p class="font-heading font-light" style="font-size: 14px; color: #4A5550; line-height: 1.6; margin-bottom: 24px;">
            {{ section.settings.form_body }}
          </p>

          <form data-lead-form data-lead-source="{{ section.settings.form_source }}">
            <!-- Honeypot -->
            <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true"
              style="position: absolute; left: -9999px; opacity: 0; height: 0; width: 0;">

            <div style="display: flex; flex-direction: column; gap: 12px;">
              <input type="text" data-lead-name name="firstName" required
                placeholder="Full name" aria-label="Full name" autocomplete="name"
                class="font-heading font-light"
                style="width: 100%; font-size: 15px; background: #FFFFFF; border: 2px solid #D5CFC6; border-radius: 50px; padding: 16px 24px; color: {{ primary_color }}; outline: none;">

              <input type="email" data-lead-email name="email" required
                placeholder="Your best email" aria-label="Email address" autocomplete="email"
                class="font-heading font-light"
                style="width: 100%; font-size: 15px; background: #FFFFFF; border: 2px solid #D5CFC6; border-radius: 50px; padding: 16px 24px; color: {{ primary_color }}; outline: none;">

              <button type="submit" data-default-text="{{ section.settings.form_button_text }} &rarr;"
                class="font-heading font-semibold cta-pulse"
                style="width: 100%; font-size: 15px; background: linear-gradient(135deg, {{ accent_color }}, #D4925A); color: {{ primary_color }}; border: none; border-radius: 50px; padding: 16px 24px; cursor: pointer;">
                {{ section.settings.form_button_text }} &rarr;
              </button>
            </div>

            <p data-lead-error class="font-heading" style="font-size: 14px; color: {{ accent_color }}; display: none; margin-top: 12px; text-align: center;" role="alert">
              Something went wrong. Please try again.
            </p>
          </form>

          <p class="font-mono-spec" style="font-size: 11px; color: #8A9490; margin-top: 16px; text-align: center;">
            {{ section.settings.form_privacy_text }}
          </p>

          <p class="font-mono-spec" style="font-size: 10px; color: #B0ABA3; margin-top: 8px; text-align: center;">
            Cited: Nature Medicine &middot; Cell &middot; Gut
          </p>
        </div>

        <!-- Success view -->
        <div data-lead-success-view style="display: none; text-align: center;">
          <p data-success-msg class="font-display italic" style="font-size: 24px; color: {{ primary_color }}; margin-bottom: 8px;">
            {{ section.settings.success_message }}
          </p>
          <div style="margin: 16px auto; padding: 12px 24px; background: {{ primary_color }}; border-radius: 12px; display: inline-block;">
            <p class="font-mono-spec uppercase" style="font-size: 11px; color: {{ accent_color }}; letter-spacing: 0.15em; margin-bottom: 4px;">Your 20% discount code</p>
            <p class="font-heading font-semibold" style="font-size: 24px; color: {{ light_color }}; letter-spacing: 0.1em;">{{ section.settings.discount_code }}</p>
          </div>
          <p class="font-heading" style="font-size: 14px; color: #4A5550; margin-bottom: 16px;">
            20% off is automatically applied at checkout. No code needed.
          </p>
          <a href="{{ section.settings.product_link }}" class="inline-block font-heading font-semibold"
            style="background: {{ accent_color }}; color: {{ primary_color }}; padding: 16px 40px; border-radius: 50px; text-decoration: none; font-size: 15px; box-shadow: 0 4px 20px rgba(196,120,58,0.25);">
            {{ section.settings.success_shop_text }}
          </a>
        </div>

        <!-- Duplicate view -->
        <div data-lead-duplicate-view style="display: none; text-align: center;">
          <p class="font-heading" style="font-size: 16px; color: #4A5550;">
            {{ section.settings.duplicate_message }}
          </p>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ────────────────────────────────────────────────────────────
     STAT BAR
     ──────────────────────────────────────────────────────────── -->
{%- if stat_blocks.size > 0 -%}
<section style="background: {{ primary_color }}; border-top: 1px solid rgba(245,242,236,0.08); padding: 48px 24px;">
  <div class="fr-stat-grid stagger-children" style="max-width: 900px; margin: 0 auto;">

    {%- for block in stat_blocks -%}
    <div class="fr-stat-item" style="text-align: center;" {{ block.shopify_attributes }}>
      <p class="font-mono-spec font-semibold" style="font-size: 24px; color: {{ accent_color }}; margin-bottom: 6px;">
        <span
          data-count-target="{{ block.settings.number }}"
          {%- if block.settings.number > 999 %} data-count-separator=","{% endif %}
          {%- if block.settings.suffix != blank %} data-count-suffix="{{ block.settings.suffix }}"{% endif %}
          data-count-duration="1000">
          0{%- if block.settings.suffix != blank %}{{ block.settings.suffix }}{% endif %}
        </span>
      </p>
      <p class="font-mono-spec uppercase" style="font-size: 11px; color: rgba(245,242,236,0.40); letter-spacing: 0.1em;">
        {{ block.settings.label }}
      </p>
    </div>
    {%- endfor -%}

  </div>
</section>
{%- endif -%}

<!-- ────────────────────────────────────────────────────────────
     WHAT'S INSIDE SECTION
     ──────────────────────────────────────────────────────────── -->
{%- if card_blocks.size > 0 -%}
<section style="background: {{ light_color }}; padding: 80px 24px;">
  <div style="max-width: 900px; margin: 0 auto;">

    <p class="font-mono-spec uppercase reveal-hidden" style="font-size: 11px; color: {{ accent_color }}; letter-spacing: 0.2em; margin-bottom: 16px;">
      {{ section.settings.inside_eyebrow }}
    </p>

    <h2 class="font-heading font-medium reveal-hidden" style="font-size: clamp(28px, 4vw, 40px); color: {{ primary_color }}; line-height: 1.15; margin-bottom: 16px; max-width: 640px;">
      {{ section.settings.inside_heading }}
    </h2>

    <p class="font-heading font-light reveal-hidden" style="font-size: 16px; color: #4A5550; line-height: 1.7; max-width: 600px; margin-bottom: 40px;">
      {{ section.settings.inside_body }}
    </p>

    <!-- Cards grid -->
    {%- if card_blocks.size > 0 -%}
    <div class="fr-cards-grid stagger-children">
      {%- for block in card_blocks -%}
      <div class="card-hover reveal-hidden" style="display: flex; gap: 20px; border-radius: 16px; padding: 28px; background: {{ card_bg_color }}; border: 1px solid #D5CFC6;" {{ block.shopify_attributes }}>
        <span class="font-display" style="font-size: 32px; color: #D5CFC6; flex-shrink: 0; line-height: 1;">{{ block.settings.number }}</span>
        <div>
          <h3 class="font-heading font-semibold" style="font-size: 14px; color: {{ primary_color }}; margin-bottom: 6px;">{{ block.settings.title }}</h3>
          <p class="font-heading font-light" style="font-size: 14px; color: #4A5550; line-height: 1.6;">
            {{ block.settings.text }}
          </p>
        </div>
      </div>
      {%- endfor -%}
    </div>
    {%- endif -%}

  </div>
</section>
{%- endif -%}

<!-- ────────────────────────────────────────────────────────────
     PULL QUOTE SECTION
     ──────────────────────────────────────────────────────────── -->
{%- if section.settings.quote_text != blank -%}
<section style="background: {{ primary_color }}; padding: 72px 24px;">
  <div style="max-width: 760px; margin: 0 auto; text-align: center;">
    <p class="font-display italic reveal-hidden" style="font-size: clamp(20px, 3vw, 28px); color: {{ light_color }}; line-height: 1.5;">
      {{ section.settings.quote_text }}
    </p>
    <p class="font-mono-spec reveal-hidden" style="font-size: 11px; color: rgba(245,242,236,0.35); margin-top: 24px;">
      {{ section.settings.quote_source }}
    </p>
  </div>
</section>
{%- endif -%}

<!-- ────────────────────────────────────────────────────────────
     CITATION STRIP
     ──────────────────────────────────────────────────────────── -->
{%- if citation_blocks.size > 0 -%}
<section style="background: {{ primary_color }}; border-top: 1px solid rgba(245,242,236,0.08); padding: 56px 24px;">
  <div style="max-width: 900px; margin: 0 auto;">

    <p class="font-mono-spec uppercase" style="font-size: 11px; color: rgba(245,242,236,0.35); letter-spacing: 0.15em; margin-bottom: 24px; text-align: center;">
      {{ section.settings.citations_heading }}
    </p>

    <div class="grid md:grid-cols-3 gap-6">
      {%- for block in citation_blocks -%}
      <div class="glass-card" style="background: rgba(245,242,236,0.04); border: 1px solid rgba(245,242,236,0.08); border-radius: 16px; padding: 24px;" {{ block.shopify_attributes }}>
        <p class="font-mono-spec" style="font-size: 11px; color: {{ accent_color }}; margin-bottom: 6px;">{{ block.settings.journal }}</p>
        <p class="font-heading font-light" style="font-size: 13px; color: rgba(245,242,236,0.55); line-height: 1.6; margin-bottom: 10px;">
          {{ block.settings.description }}
        </p>
        {%- if block.settings.url != blank -%}
        <a href="{{ block.settings.url }}" target="_blank" rel="noopener noreferrer"
          class="font-mono-spec hover:underline" style="font-size: 11px; color: {{ accent_color }};">
          View Study &rarr;
        </a>
        {%- endif -%}
      </div>
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

<!-- ────────────────────────────────────────────────────────────
     FOUNDER NOTE
     ──────────────────────────────────────────────────────────── -->
{%- if section.settings.founder_heading != blank -%}
<section style="background: {{ light_color }}; padding: 80px 24px;">
  <div class="fr-founder-grid" style="max-width: 1040px; margin: 0 auto;">

    <!-- Left column -->
    <div>
      <p class="font-mono-spec uppercase reveal-hidden" style="font-size: 11px; color: {{ accent_color }}; letter-spacing: 0.2em; margin-bottom: 16px;">
        {{ section.settings.founder_eyebrow }}
      </p>

      <h2 class="font-heading font-medium reveal-hidden" style="font-size: clamp(26px, 3.5vw, 36px); color: {{ primary_color }}; line-height: 1.2; margin-bottom: 24px; max-width: 420px;">
        {{ section.settings.founder_heading }}
      </h2>

      <div style="border-left: 2px solid {{ accent_color }}; padding-left: 20px; margin-bottom: 0;" class="reveal-hidden">
        <p class="font-display italic" style="font-size: 18px; color: {{ primary_color }}; line-height: 1.5;">
          {{ section.settings.founder_quote }}
        </p>
      </div>
    </div>

    <!-- Right column -->
    <div class="reveal-hidden">
      <div class="font-heading font-light" style="font-size: 15px; color: #4A5550; line-height: 1.7; margin-bottom: 24px;">
        {{ section.settings.founder_body }}
      </div>

      <p class="font-mono-spec" style="font-size: 12px; color: #8A9490; margin-bottom: 20px;">
        &mdash; {{ section.settings.founder_attribution }}
      </p>

      <a href="{{ section.settings.founder_cta_link }}" class="font-heading font-medium hover:underline" style="font-size: 15px; color: {{ accent_color }}; text-decoration: none;">
        {{ section.settings.founder_cta_text }} &rarr;
      </a>
    </div>

  </div>
</section>
{%- endif -%}

<!-- ────────────────────────────────────────────────────────────
     BOTTOM CTA
     ──────────────────────────────────────────────────────────── -->
{%- if section.settings.bottom_heading != blank -%}
<section id="fr-bottom-form" style="background: {{ card_bg_color }}; padding: 64px 24px 80px;">
  <div style="max-width: 680px; margin: 0 auto; text-align: center;">

    <h2 class="font-heading font-medium reveal-hidden" style="font-size: clamp(28px, 4vw, 40px); color: {{ primary_color }}; line-height: 1.15; margin-bottom: 12px;">
      {{ section.settings.bottom_heading }}
    </h2>

    <p class="font-heading font-light reveal-hidden" style="font-size: 16px; color: #4A5550; line-height: 1.7; max-width: 520px; margin: 0 auto 28px;">
      {{ section.settings.bottom_body }}
    </p>

    <!-- Shop CTA -->
    <a href="{{ section.settings.shop_cta_link }}" class="font-heading font-semibold reveal-hidden"
      style="display: inline-block; font-size: 16px; background: {{ primary_color }}; color: {{ light_color }}; padding: 18px 48px; border-radius: 50px; text-decoration: none; margin-bottom: 32px; box-shadow: 0 4px 20px rgba(28,46,35,0.20);">
      {{ section.settings.shop_cta_text }}
    </a>

    <!-- Transition text -->
    <p class="font-heading font-light reveal-hidden" style="font-size: 14px; color: #8A9490; margin-bottom: 28px;">
      {{ section.settings.bottom_transition_text }}
    </p>

    <!-- Value stack -->
    {%- if value_bullets.size > 0 -%}
    <div style="max-width: 400px; margin: 0 auto 32px; text-align: left;" class="reveal-hidden">
      {%- for block in value_bullets -%}
      <div style="display: flex; align-items: baseline; gap: 10px; margin-bottom: {% if forloop.last %}0{% else %}10px{% endif %};" {{ block.shopify_attributes }}>
        <span style="color: {{ accent_color }}; flex-shrink: 0; font-size: 14px;">&#10022;</span>
        <span class="font-heading font-light" style="font-size: 14px; color: #4A5550;">{{ block.settings.text }}</span>
      </div>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- Investment line -->
    <p class="font-heading font-medium reveal-hidden" style="font-size: 14px; color: {{ primary_color }}; margin-bottom: 28px;">
      {{ section.settings.bottom_investment_text }}
    </p>

    <!-- Bottom email capture form -->
    <div data-lead-wrapper style="max-width: 520px; margin: 0 auto;">
      <div data-lead-form-view>
        <form data-lead-form data-lead-source="{{ section.settings.bottom_form_source }}">
          <!-- Honeypot -->
          <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true"
            style="position: absolute; left: -9999px; opacity: 0; height: 0; width: 0;">

          <!-- Desktop inline pill -->
          <div class="fr-bottom-inline" style="border: 2px solid {{ primary_color }}; border-radius: 50px; overflow: hidden;">
            <input type="text" data-lead-name name="firstName" required
              placeholder="Full name" aria-label="Full name" autocomplete="name"
              class="font-heading font-light"
              style="font-size: 15px; background: {{ light_color }}; color: {{ primary_color }}; padding: 16px 20px; border: none; outline: none; min-width: 80px; width: 26%;">
            <div style="width: 1px; align-self: stretch; background: #D5CFC6;"></div>
            <input type="email" data-lead-email name="email" required
              placeholder="Your best email" aria-label="Email address" autocomplete="email"
              class="font-heading font-light"
              style="font-size: 15px; background: {{ light_color }}; color: {{ primary_color }}; padding: 16px 20px; border: none; outline: none; flex: 1;">
            <button type="submit" data-default-text="Send Report"
              class="font-heading font-medium"
              style="font-size: 14px; background: {{ primary_color }}; color: {{ light_color }}; padding: 16px 28px; border: none; border-radius: 0 50px 50px 0; cursor: pointer; white-space: nowrap;">
              Send Report
            </button>
          </div>

          <!-- Mobile stacked -->
          <div class="fr-bottom-stack" style="max-width: 400px; margin: 0 auto;">
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <input type="text" data-lead-name name="firstNameMobile" required
                placeholder="Full name" aria-label="Full name" autocomplete="name"
                class="font-heading font-light"
                style="width: 100%; font-size: 15px; background: {{ light_color }}; border: 2px solid {{ primary_color }}; border-radius: 50px; padding: 16px 24px; color: {{ primary_color }}; outline: none;">
              <input type="email" data-lead-email name="emailMobile" required
                placeholder="Your best email" aria-label="Email address" autocomplete="email"
                class="font-heading font-light"
                style="width: 100%; font-size: 15px; background: {{ light_color }}; border: 2px solid {{ primary_color }}; border-radius: 50px; padding: 16px 24px; color: {{ primary_color }}; outline: none;">
              <button type="submit" data-default-text="{{ section.settings.form_button_text }}"
                class="font-heading font-medium"
                style="width: 100%; font-size: 14px; background: {{ primary_color }}; color: {{ light_color }}; border: none; border-radius: 50px; padding: 16px 24px; cursor: pointer;">
                {{ section.settings.form_button_text }}
              </button>
            </div>
          </div>

          <p data-lead-error class="font-heading" style="font-size: 14px; color: {{ accent_color }}; display: none; margin-top: 12px;" role="alert">
            Something went wrong. Please try again.
          </p>
        </form>
      </div>

      <!-- Success view -->
      <div data-lead-success-view style="display: none; text-align: center;">
        <p data-success-msg class="font-display italic" style="font-size: 22px; color: {{ primary_color }}; margin-bottom: 8px;">
          {{ section.settings.success_message }}
        </p>
        <div style="margin: 16px auto; padding: 12px 24px; background: {{ primary_color }}; border-radius: 12px; display: inline-block;">
          <p class="font-mono-spec uppercase" style="font-size: 11px; color: {{ accent_color }}; letter-spacing: 0.15em; margin-bottom: 4px;">Your 20% discount code</p>
          <p class="font-heading font-semibold" style="font-size: 24px; color: {{ light_color }}; letter-spacing: 0.1em;">{{ section.settings.discount_code }}</p>
        </div>
        <p class="font-heading" style="font-size: 14px; color: #4A5550; margin-bottom: 16px;">
          20% off is automatically applied at checkout. No code needed.
        </p>
        <a href="{{ section.settings.product_link }}" class="inline-block font-heading font-semibold"
          style="background: {{ accent_color }}; color: {{ primary_color }}; padding: 16px 40px; border-radius: 50px; text-decoration: none; font-size: 15px;">
          {{ section.settings.success_shop_text }}
        </a>
      </div>

      <!-- Duplicate view -->
      <div data-lead-duplicate-view style="display: none; text-align: center;">
        <p class="font-heading" style="font-size: 15px; color: #4A5550;">
          {{ section.settings.duplicate_message }}
        </p>
      </div>
    </div>

    <!-- Risk reversal -->
    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 20px;" class="reveal-hidden">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8A9490" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <p class="font-mono-spec" style="font-size: 11px; color: #8A9490;">
        No credit card. No spam. Unsubscribe anytime. Delivered instantly.
      </p>
    </div>

  </div>
</section>
{%- endif -%}

</div><!-- end padding wrapper -->

<!-- ────────────────────────────────────────────────────────────
     SCOPED STYLES
     ──────────────────────────────────────────────────────────── -->
<style>
  /* Hero grid: single column mobile, two columns desktop */
  .fr-hero-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .fr-hero-grid {
      grid-template-columns: 1fr minmax(320px, 420px);
      gap: 64px !important;
      padding: 0 56px;
    }
  }

  /* Form card responsive padding */
  @media (min-width: 768px) {
    .fr-form-card {
      padding: 40px !important;
    }
  }

  /* Hero section responsive padding */
  @media (min-width: 768px) {
    .fr-hero-grid {
      /* handled by parent section padding override */
    }
  }

  /* Stat bar grid */
  .fr-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (min-width: 768px) {
    .fr-stat-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .fr-stat-item {
      border-right: 1px solid rgba(245,242,236,0.08);
    }
    .fr-stat-item:last-child {
      border-right: none;
    }
  }

  /* What's inside cards grid */
  .fr-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .fr-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    /* Last card spans full width if odd count */
    .fr-cards-grid > :nth-child(odd):last-child {
      grid-column: 1 / -1;
    }
  }

  /* Founder note grid */
  .fr-founder-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .fr-founder-grid {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }
  }

  /* Bottom CTA: inline pill on desktop, stacked on mobile */
  .fr-bottom-inline {
    display: none;
  }
  .fr-bottom-stack {
    display: block;
  }
  @media (min-width: 640px) {
    .fr-bottom-inline {
      display: flex;
      align-items: stretch;
    }
    .fr-bottom-stack {
      display: none;
    }
  }

  /* cta-pulse animation */
  @keyframes cta-pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(196,120,58,0.3); }
    50% { box-shadow: 0 0 20px 4px rgba(196,120,58,0.15); }
  }
  .cta-pulse {
    animation: cta-pulse-glow 3s ease-in-out infinite;
  }
  .cta-pulse:hover {
    animation: none;
    box-shadow: 0 4px 20px rgba(196,120,58,0.30);
    transform: translateY(-1px);
    transition: all 0.2s ease;
  }

  /* card-hover effect */
  .card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-hover:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(28,46,35,0.08);
  }

  /* glass-card hover */
  .glass-card {
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .glass-card:hover {
    background: rgba(245,242,236,0.07) !important;
    border-color: rgba(245,242,236,0.14) !important;
  }

  /* Focus states for inputs */
  .fr-form-card input:focus {
    border-color: #C4783A !important;
  }
</style>


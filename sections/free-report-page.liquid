      <div style="display: flex; align-items: baseline; gap: 10px; margin-bottom: 10px;">
        <span style="color: #C4783A; flex-shrink: 0; font-size: 14px;">&#10022;</span>
        <span class="font-heading font-light" style="font-size: 14px; color: #4A5550;">Exclusive subscriber pricing on future products</span>
      </div>
      <div style="display: flex; align-items: baseline; gap: 10px;">
        <span style="color: #C4783A; flex-shrink: 0; font-size: 14px;">&#10022;</span>
        <span class="font-heading font-light" style="font-size: 14px; color: #4A5550;">Free report included with every Origin order</span>
      </div>
    </div>

    <!-- Investment line -->
    <p class="font-heading font-medium reveal-hidden" style="font-size: 14px; color: #1C2E23; margin-bottom: 28px;">
      Research report + future product access + subscriber pricing. Your investment: <strong>$0.</strong>
    </p>

    <!-- Bottom email capture form -->
    <div data-lead-wrapper style="max-width: 520px; margin: 0 auto;">
      <div data-lead-form-view>
        <form data-lead-form data-lead-source="free-report-bottom">
          <!-- Honeypot -->
          <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true"
            style="position: absolute; left: -9999px; opacity: 0; height: 0; width: 0;">

          <!-- Desktop inline pill -->
          <div class="fr-bottom-inline" style="border: 2px solid #1C2E23; border-radius: 50px; overflow: hidden;">
            <input type="text" data-lead-name name="firstName" required
              placeholder="Full name" aria-label="Full name" autocomplete="name"
              class="font-heading font-light"
              style="font-size: 15px; background: #F5F2EC; color: #1C2E23; padding: 16px 20px; border: none; outline: none; min-width: 80px; width: 26%;">
            <div style="width: 1px; align-self: stretch; background: #D5CFC6;"></div>
            <input type="email" data-lead-email name="email" required
              placeholder="Your best email" aria-label="Email address" autocomplete="email"
              class="font-heading font-light"
              style="font-size: 15px; background: #F5F2EC; color: #1C2E23; padding: 16px 20px; border: none; outline: none; flex: 1;">
            <button type="submit" data-default-text="Send Report"
              class="font-heading font-medium"
              style="font-size: 14px; background: #1C2E23; color: #F5F2EC; padding: 16px 28px; border: none; border-radius: 0 50px 50px 0; cursor: pointer; white-space: nowrap;">
              Send Report
            </button>
          </div>

          <!-- Mobile stacked -->
          <div class="fr-bottom-stack" style="max-width: 400px; margin: 0 auto;">
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <input type="text" data-lead-name name="firstNameMobile" required
                placeholder="Full name" aria-label="Full name" autocomplete="name"
                class="font-heading font-light"
                style="width: 100%; font-size: 15px; background: #F5F2EC; border: 2px solid #1C2E23; border-radius: 50px; padding: 16px 24px; color: #1C2E23; outline: none;">
              <input type="email" data-lead-email name="emailMobile" required
                placeholder="Your best email" aria-label="Email address" autocomplete="email"
                class="font-heading font-light"
                style="width: 100%; font-size: 15px; background: #F5F2EC; border: 2px solid #1C2E23; border-radius: 50px; padding: 16px 24px; color: #1C2E23; outline: none;">
              <button type="submit" data-default-text="Send My Free Report"
                class="font-heading font-medium"
                style="width: 100%; font-size: 14px; background: #1C2E23; color: #F5F2EC; border: none; border-radius: 50px; padding: 16px 24px; cursor: pointer;">
                Send My Free Report
              </button>
            </div>
          </div>

          <p data-lead-error class="font-heading" style="font-size: 14px; color: #C4783A; display: none; margin-top: 12px;" role="alert">
            Something went wrong. Please try again.
          </p>
        </form>
      </div>

      <!-- Success view -->
      <div data-lead-success-view style="display: none; text-align: center;">
        <p data-success-msg class="font-display italic" style="font-size: 22px; color: #1C2E23; margin-bottom: 8px;">
          You're in &#10022; Check your inbox.
        </p>
        <div style="margin: 16px auto; padding: 12px 24px; background: #1C2E23; border-radius: 12px; display: inline-block;">
          <p class="font-mono-spec uppercase" style="font-size: 11px; color: #C4783A; letter-spacing: 0.15em; margin-bottom: 4px;">Your 20% discount code</p>
          <p class="font-heading font-semibold" style="font-size: 24px; color: #F5F2EC; letter-spacing: 0.1em;">FOUNDER20</p>
        </div>
        <p class="font-heading" style="font-size: 14px; color: #4A5550; margin-bottom: 16px;">
          20% off is automatically applied at checkout. No code needed.
        </p>
        <a href="/products/origin" class="inline-block font-heading font-semibold"
          style="background: #C4783A; color: #1C2E23; padding: 16px 40px; border-radius: 50px; text-decoration: none; font-size: 15px;">
          Shop Origin
        </a>
      </div>

      <!-- Duplicate view -->
      <div data-lead-duplicate-view style="display: none; text-align: center;">
        <p class="font-heading" style="font-size: 15px; color: #4A5550;">
          Already on the list &mdash; check your inbox.
        </p>
      </div>
    </div>

    <!-- Risk reversal -->
    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 20px;" class="reveal-hidden">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8A9490" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <p class="font-mono-spec" style="font-size: 11px; color: #8A9490;">
        No credit card. No spam. Unsubscribe anytime. Delivered instantly.
      </p>
    </div>

  </div>
</section>

<!-- ────────────────────────────────────────────────────────────
     SCOPED STYLES
     ──────────────────────────────────────────────────────────── -->
<style>
  /* Hero grid: single column mobile, two columns desktop */
  .fr-hero-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .fr-hero-grid {
      grid-template-columns: 1fr minmax(320px, 420px);
      gap: 64px !important;
      padding: 0 56px;
    }
  }

  /* Form card responsive padding */
  @media (min-width: 768px) {
    .fr-form-card {
      padding: 40px !important;
    }
  }

  /* Hero section responsive padding */
  @media (min-width: 768px) {
    .fr-hero-grid {
      /* handled by parent section padding override */
    }
  }

  /* Stat bar grid */
  .fr-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (min-width: 768px) {
    .fr-stat-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .fr-stat-item {
      border-right: 1px solid rgba(245,242,236,0.08);
    }
    .fr-stat-item:last-child {
      border-right: none;
    }
  }

  /* What's inside cards grid */
  .fr-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .fr-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    /* Last card (05) spans full width if odd */
    .fr-cards-grid > :nth-child(5) {
      grid-column: 1 / -1;
    }
  }

  /* Founder note grid */
  .fr-founder-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .fr-founder-grid {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }
  }

  /* Bottom CTA: inline pill on desktop, stacked on mobile */
  .fr-bottom-inline {
    display: none;
  }
  .fr-bottom-stack {
    display: block;
  }
  @media (min-width: 640px) {
    .fr-bottom-inline {
      display: flex;
      align-items: stretch;
    }
    .fr-bottom-stack {
      display: none;
    }
  }

  /* cta-pulse animation */
  @keyframes cta-pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(196,120,58,0.3); }
    50% { box-shadow: 0 0 20px 4px rgba(196,120,58,0.15); }
  }
  .cta-pulse {
    animation: cta-pulse-glow 3s ease-in-out infinite;
  }
  .cta-pulse:hover {
    animation: none;
    box-shadow: 0 4px 20px rgba(196,120,58,0.30);
    transform: translateY(-1px);
    transition: all 0.2s ease;
  }

  /* card-hover effect */
  .card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-hover:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(28,46,35,0.08);
  }

  /* glass-card hover */
  .glass-card {
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .glass-card:hover {
    background: rgba(245,242,236,0.07) !important;
    border-color: rgba(245,242,236,0.14) !important;
  }

  /* Focus states for inputs */
  .fr-form-card input:focus {
    border-color: #C4783A !important;
  }
</style>


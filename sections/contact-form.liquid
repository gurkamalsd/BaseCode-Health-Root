{%- comment -%}BaseCode Root - contact-form{%- endcomment -%}
<section class="section bg-white">
  <div class="container container--narrow">
    <h1 class="text-center mb-4">{{ section.settings.heading | default: 'Contact Us' }}</h1>
    {%- if section.settings.text != blank -%}
      <p class="text-center mb-10" style="font-size: var(--text-lg); color: var(--color-text-light);">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div style="padding: var(--space-6); background: rgba(22, 163, 74, 0.1); border: 1px solid var(--color-success); border-radius: var(--radius-md); text-align: center; margin-bottom: var(--space-6);">
          <p style="color: var(--color-success); font-weight: 600;">Thanks for reaching out! We'll get back to you within 24 hours.</p>
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div style="padding: var(--space-4); background: rgba(220, 38, 38, 0.1); border: 1px solid var(--color-error); border-radius: var(--radius-md); margin-bottom: var(--space-6);">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="grid gap-6" style="grid-template-columns: 1fr 1fr;">
        <div>
          <label for="contact-name" class="form-label">Name</label>
          <input type="text" name="contact[name]" id="contact-name" class="form-input" placeholder="{{ 'forms.name_placeholder' | t }}" required>
        </div>
        <div>
          <label for="contact-email" class="form-label">Email</label>
          <input type="email" name="contact[email]" id="contact-email" class="form-input" placeholder="{{ 'forms.email_placeholder' | t }}" required>
        </div>
      </div>
      <div style="margin-top: var(--space-4);">
        <label for="contact-subject" class="form-label">Subject</label>
        <input type="text" name="contact[subject]" id="contact-subject" class="form-input" placeholder="{{ 'forms.subject_placeholder' | t }}">
      </div>
      <div style="margin-top: var(--space-4);">
        <label for="contact-message" class="form-label">Message</label>
        <textarea name="contact[body]" id="contact-message" class="form-input" rows="6" placeholder="{{ 'forms.message_placeholder' | t }}" required></textarea>
      </div>
      <div style="margin-top: var(--space-6);">
        <button type="submit" class="btn btn--primary btn--lg">{{ 'forms.submit' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext",
      "default": "Have a question? We'd love to hear from you. Email us at hello@basecodehealth.com or use the form below."
    }
  ],
  "presets": [{ "name": "Contact Form" }]
}
{% endschema %}

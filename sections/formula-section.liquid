<section class="relative" style="background: #1C2E23; border-radius: 48px 48px 0 0; margin-top: -24px;">
  <div class="px-6 md:px-20 py-14 md:py-20" style="max-width: 1200px; margin: 0 auto;">
    <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-start">
      <!-- Left – product photos, sticky on desktop -->
      <div class="w-full md:w-1/2 md:sticky md:top-88 reveal-hidden">
        <div class="flex flex-col gap-5">
          {%- if section.settings.bottle_image != blank -%}
            <img src="{{ section.settings.bottle_image | image_url: width: 960 }}" alt="Origin by BaseCode Health — The First Adaptobiotic. 40 Billion CFU, Synbiotic, 60 Capsules." width="480" height="600" loading="lazy" class="w-full rounded-2xl" style="aspect-ratio: 4/5; object-fit: cover;">
          {%- else -%}
            <div class="w-full rounded-2xl flex items-center justify-center" style="aspect-ratio: 4/5; background: linear-gradient(180deg, #243b2c, #1C2E23); border: 1px solid rgba(196,120,58,0.15);">
              <div class="text-center px-8">
                <p class="font-display text-64" style="color: rgba(196,120,58,0.2);">O</p>
                <p class="font-mono-spec text-12 uppercase mt-4" style="color: rgba(245,242,236,0.35); letter-spacing: 0.2em;">Origin</p>
                <p class="font-heading text-14 mt-2" style="color: rgba(245,242,236,0.2);">The First Adaptobiotic</p>
                <p class="font-mono-spec text-10 mt-4" style="color: rgba(196,120,58,0.3);">40B CFU · 4 Strains · 60 Capsules</p>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.lifestyle_image != blank -%}
            <img src="{{ section.settings.lifestyle_image | image_url: width: 960 }}" alt="Woman holding Origin bottle — precision Adaptobiotic for the foundational microbiome." width="480" height="600" loading="lazy" class="w-full rounded-2xl" style="aspect-ratio: 4/5; object-fit: cover;">
          {%- else -%}
            <div class="w-full rounded-2xl flex items-center justify-center" style="aspect-ratio: 4/5; background: linear-gradient(180deg, rgba(196,120,58,0.08), rgba(196,120,58,0.03)); border: 1px solid rgba(196,120,58,0.1);">
              <div class="text-center px-8">
                <p class="font-heading text-18" style="color: rgba(28,46,35,0.25);">Alive on arrival.</p>
                <p class="font-heading text-18 mt-1" style="color: rgba(28,46,35,0.2);">Fed on impact.</p>
              </div>
            </div>
          {%- endif -%}
        </div>
        <div class="grid grid-cols-2 mt-8" style="max-width: 320px; column-gap: 32px; row-gap: 12px;">
          <div>
            <p class="font-mono-spec text-11" style="color: rgba(245,242,236,0.35);">Format</p>
            <p class="font-heading text-13 font-light" style="color: #F5F2EC;">MAKTREK synbiotic</p>
          </div>
          <div>
            <p class="font-mono-spec text-11" style="color: rgba(245,242,236,0.35);">Weight</p>
            <p class="font-heading text-13 font-light" style="color: #F5F2EC;">Per capsule</p>
          </div>
          <div>
            <p class="font-mono-spec text-11" style="color: rgba(245,242,236,0.35);">Supply</p>
            <p class="font-heading text-13 font-light" style="color: #F5F2EC;">60 capsules / 30 days</p>
          </div>
          <div>
            <p class="font-mono-spec text-11" style="color: rgba(245,242,236,0.35);">Origin</p>
            <p class="font-heading text-13 font-light" style="color: #F5F2EC;">USA</p>
          </div>
        </div>
      </div>

      <!-- Right – formula details -->
      <div class="w-full md:w-1/2 reveal-hidden">
        <span class="inline-block font-mono-spec text-11 rounded-full mb-6" style="letter-spacing: 0.1em; border: 1px solid #C4783A; color: #C4783A; padding: 6px 16px;">
          Clinical-Grade Adaptobiotic
        </span>
        <h2 class="font-heading text-40 md:text-52 font-medium mb-4" style="color: #F5F2EC;">
          The formula they never built.
        </h2>
        <p class="font-heading text-17 font-light mb-10" style="color: rgba(245,242,236,0.65); line-height: 1.7;">
          Every probiotic on the shelf was designed for a generic Western biology.
          None of them account for how your biology shapes your microbiome.
          Origin does. Four clinically studied strains selected for the depletion
          patterns modern populations share, protected by MAKTREK Bi-Pass
          Technology, fed by FOS prebiotic on arrival. This is the formula the
          supplement industry should have built decades ago.
        </p>

        <!-- Spec rows -->
        <div class="mb-10">
          {%- assign spec_keys = "Colony-Forming Units|Strains|Delivery|Prebiotic|Format|Supply|Certifications" | split: "|" -%}
          {%- assign spec_vals = "40 Billion CFU at manufacture|L. acidophilus · B. lactis · L. plantarum · L. paracasei|MAKTREK Bi-Pass Technology (marine polysaccharide)|Fructooligosaccharide (FOS)|Vegetarian capsule (Hypromellose / HPMC)|60 capsules (30-day supply at 2/day)|GMP · Non-GMO · Vegan · Gluten-free · USA" | split: "|" -%}
          {%- for key in spec_keys -%}
            <div class="flex justify-between items-baseline py-4" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
              <span class="font-heading text-14 font-light" style="color: rgba(245,242,236,0.45);">{{ key }}</span>
              <span class="font-heading text-14 font-normal text-right" style="color: {% if forloop.index <= 3 %}#C4783A{% else %}#F5F2EC{% endif %}; max-width: 60%;">
                {{ spec_vals[forloop.index0] }}
              </span>
            </div>
          {%- endfor -%}
        </div>

        <!-- Value stack -->
        <div class="mb-8 pt-6" style="border-top: 1px solid rgba(255,255,255,0.08);">
          <p class="font-mono-spec text-11 uppercase mb-4" style="color: rgba(245,242,236,0.40); letter-spacing: 0.15em;">
            What you get
          </p>
          {%- assign value_items = "30 days of targeted microbiome restoration — less bloating, more energy|4 strains selected for environmental disruption patterns — delivered alive|MAKTREK Bi-Pass — survives stomach acid, reaches your gut|FOS prebiotic — feeds bacteria on arrival for lasting inflammation relief" | split: "|" -%}
          {%- for item in value_items -%}
            <div class="flex items-center gap-3" style="padding: 6px 0;">
              <span class="text-12" style="color: #C4783A;">✦</span>
              <span class="font-heading text-14 font-light" style="color: rgba(245,242,236,0.65);">{{ item }}</span>
            </div>
          {%- endfor -%}
          <div class="flex items-center gap-3" style="padding: 6px 0;">
            <span class="text-12" style="color: #C4783A;">✦</span>
            <span class="font-heading text-14 font-light" style="color: rgba(245,242,236,0.65);">
              Free research report: "The Foundational Microbiome" <span class="font-mono-spec text-11 ml-1" style="color: #C4783A;">FREE</span>
            </span>
          </div>
          <div class="flex items-center gap-3" style="padding: 6px 0;">
            <span class="text-12" style="color: #C4783A;">✦</span>
            <span class="font-heading text-14 font-light" style="color: rgba(245,242,236,0.65);">
              Early access to future product releases <span class="font-mono-spec text-11 ml-1" style="color: #C4783A;">FREE</span>
            </span>
          </div>
        </div>

        <!-- Price -->
        <div class="mb-2">
          <span class="font-heading font-medium" style="color: #F5F2EC; font-size: 56px;">$34</span>
          <span class="font-heading font-light ml-2" style="color: rgba(245,242,236,0.55); font-size: 22px;">
            /mo <span style="font-size: 16px;">subscribe</span>
          </span>
        </div>
        <p class="font-mono-spec text-12 mb-1" style="color: rgba(245,242,236,0.35);">
          $40 one-time · That's $1.13/day — less than your morning coffee.
        </p>
        <p class="font-mono-spec text-11 mb-6" style="color: #C4783A;">
          Subscribe & Save $6 · Delivered monthly · Cancel anytime
        </p>

        <a href="/products/origin" class="btn btn--primary block text-center mb-3">
          Buy Origin — $34/mo
        </a>
        <p class="text-center font-heading text-14 font-light mb-4" style="color: rgba(245,242,236,0.40);">
          30-day supply. Free shipping. Free research report with your order.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <span class="flex items-center gap-1.5 font-mono-spec text-10" style="color: rgba(245,242,236,0.45);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            30-Day Money Back
          </span>
          <span class="flex items-center gap-1.5 font-mono-spec text-10" style="color: rgba(245,242,236,0.45);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Free Shipping
          </span>
          <span class="flex items-center gap-1.5 font-mono-spec text-10" style="color: rgba(245,242,236,0.45);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Cancel Anytime
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Formula",
  "class": "formula-section",
  "settings": [
    { "type": "image_picker", "id": "bottle_image", "label": "Bottle Image" },
    { "type": "image_picker", "id": "lifestyle_image", "label": "Lifestyle Image" }
  ]
}
{% endschema %}

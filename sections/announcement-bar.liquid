{%- comment -%}BaseCode Root - announcement-bar{%- endcomment -%}
{%- if section.settings.enable -%}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar__track">
    {%- for i in (1..10) -%}
      <span class="announcement-bar__item">{{ section.settings.text }}</span>
      <span class="announcement-bar__item" aria-hidden="true">{{ section.settings.text }}</span>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on all subscriptions — Use code FOUNDER20 for 20% off"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    }
  ]
}
{% endschema %}

{%- assign is_dark = section.settings.variant | default: 'dark' -%}
{%- assign bg_color = '#1C2E23' -%}
{%- assign text_color = '#F5F2EC' -%}
{%- assign sub_color = 'rgba(245,242,236,0.60)' -%}
{%- assign input_bg = 'rgba(245,242,236,0.06)' -%}
{%- assign input_border = 'rgba(245,242,236,0.20)' -%}
{%- assign micro_color = 'rgba(245,242,236,0.35)' -%}
{%- if is_dark == 'light' -%}
  {%- assign bg_color = '#EDE8DF' -%}
  {%- assign text_color = '#1C2E23' -%}
  {%- assign sub_color = '#4A5550' -%}
  {%- assign input_bg = '#F5F2EC' -%}
  {%- assign input_border = '#1C2E23' -%}
  {%- assign micro_color = '#8A9490' -%}
{%- endif -%}

<section class="py-16 px-6 md:px-20" style="background: {{ bg_color }};" aria-label="Email signup form">
  <div style="max-width: 680px; margin: 0 auto; text-align: center;" data-lead-wrapper>

    <!-- Form view -->
    <div data-lead-form-view>
      <h2 class="font-heading text-28 md:text-36 font-medium mb-3" style="color: {{ text_color }}; line-height: 1.2;">
        {{ section.settings.headline | default: 'Understand your biology. Get the free report.' }}
      </h2>
      <p class="font-heading text-16 font-light mb-8" style="color: {{ sub_color }}; line-height: 1.7; max-width: 520px; margin: 0 auto;">
        {{ section.settings.subtext | default: 'The science behind biological diversity and your microbiome — delivered instantly to your inbox. Plus 20% off your first order.' }}
      </p>

      <form data-lead-form data-lead-source="{{ section.settings.source | default: 'inline-capture' }}">
        <!-- Honeypot -->
        <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position: absolute; left: -9999px; opacity: 0; height: 0; width: 0;">

        <!-- Desktop inline row -->
        <div class="inline-capture-row" style="border-color: {{ input_border }};">
          <input type="text" data-lead-name placeholder="Full name" required aria-label="Full name" autocomplete="name"
            class="font-heading text-15 font-light px-5 py-4"
            style="background: {{ input_bg }}; color: {{ text_color }}; min-width: 90px; width: 28%; outline: none; border: none;">
          <div style="width: 1px; align-self: stretch; background: {% if is_dark == 'light' %}#D5CFC6{% else %}rgba(245,242,236,0.12){% endif %};"></div>
          <input type="email" data-lead-email placeholder="Your best email" required aria-label="Email address" autocomplete="email"
            class="flex-1 font-heading text-15 font-light px-6 py-4"
            style="background: {{ input_bg }}; color: {{ text_color }}; outline: none; border: none;">
          <button type="submit" data-default-text="{{ section.settings.button_text | default: 'Send My Free Report' }}"
            class="font-heading text-14 font-medium px-7 py-4 whitespace-nowrap"
            style="background: #C4783A; color: #1C2E23; border-radius: 0 50px 50px 0;">
            {{ section.settings.button_text | default: 'Send My Free Report' }}
          </button>
        </div>

        <!-- Mobile stacked -->
        <div class="inline-capture-stack space-y-3" style="max-width: 400px; margin: 0 auto;">
          <input type="text" data-lead-name placeholder="Full name" required aria-label="Full name" autocomplete="name"
            class="w-full input font-heading text-15 font-light rounded-full"
            style="background: {{ input_bg }}; border: 2px solid {{ input_border }}; color: {{ text_color }}; padding: 16px 24px;">
          <input type="email" data-lead-email placeholder="Your best email" required aria-label="Email address" autocomplete="email"
            class="w-full input font-heading text-15 font-light rounded-full"
            style="background: {{ input_bg }}; border: 2px solid {{ input_border }}; color: {{ text_color }}; padding: 16px 24px;">
          <button type="submit" data-default-text="{{ section.settings.button_text | default: 'Send My Free Report' }}"
            class="w-full font-heading text-14 font-medium rounded-full"
            style="background: #C4783A; color: #1C2E23; padding: 16px 24px;">
            {{ section.settings.button_text | default: 'Send My Free Report' }}
          </button>
        </div>

        <p data-lead-error class="font-heading text-14 mt-3" style="color: #C4783A; display: none;" role="alert">
          Something went wrong. Please try again.
        </p>
      </form>

      <p class="font-mono-spec text-11 mt-4" style="color: {{ micro_color }};">
        No spam. Free report delivered immediately. Unsubscribe anytime.
      </p>
    </div>

    <!-- Success view -->
    <div data-lead-success-view style="display: none;">
      <p data-success-msg class="font-display text-24 italic mb-2" style="color: {% if is_dark == 'light' %}#1C2E23{% else %}#C4783A{% endif %};">
        You're in ✦ Check your inbox for the report.
      </p>
      <div class="mx-auto my-4 px-6 py-3 rounded-xl inline-block" style="background: {% if is_dark == 'light' %}#1C2E23{% else %}rgba(245,242,236,0.08){% endif %};">
        <p class="font-mono-spec text-11 uppercase mb-1" style="color: #C4783A; letter-spacing: 0.15em;">Your 20% discount code</p>
        <p class="font-heading text-24 font-semibold" style="color: #F5F2EC; letter-spacing: 0.1em;">FOUNDER20</p>
      </div>
      <p class="font-heading text-14 mb-4" style="color: {{ sub_color }};">
        20% off is automatically applied at checkout. No code needed.
      </p>
      <a href="/products/origin" class="inline-block font-heading text-15 font-semibold rounded-full transition" style="background: #C4783A; color: #1C2E23; padding: 16px 40px; box-shadow: 0 4px 20px rgba(196,120,58,0.25);">
        Shop Origin
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lead Capture",
  "class": "lead-capture-section",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Color Variant",
      "options": [
        { "value": "dark", "label": "Dark (Forest Green)" },
        { "value": "light", "label": "Light (Cream)" }
      ],
      "default": "dark"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Understand your biology. Get the free report."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "The science behind biological diversity and your microbiome — delivered instantly to your inbox. Plus 20% off your first order."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Send My Free Report"
    },
    {
      "type": "text",
      "id": "source",
      "label": "Analytics Source",
      "default": "inline-capture"
    }
  ]
}
{% endschema %}

<!-- Star rating social proof -->
<div class="py-3 px-6 text-center" style="background: #F5F2EC; border-bottom: 1px solid #E2DDD4;">
  <p class="font-heading text-13" style="color: #1C2E23;">
    <span class="stars">★★★★★</span>
    Rated 5 stars by early users including Priya, Carlos, Amira & David
  </p>
</div>

<!-- Stats grid -->
<div class="py-4 px-4 md:px-10" style="background: #1C2E23; border-bottom: 1px solid rgba(255,255,255,0.08);">
  <div style="max-width: 1200px; margin: 0 auto;" class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-0">
    <div class="text-center md:border-r" style="border-color: rgba(255,255,255,0.10);">
      <span class="font-heading text-20 md:text-28 font-semibold" style="color: #C4783A;">1st</span>
      <p class="font-mono-spec text-10 mt-0" style="color: rgba(245,242,236,0.45); letter-spacing: 0.08em;">World's First Ethnobiotic</p>
    </div>
    <div class="text-center md:border-r" style="border-color: rgba(255,255,255,0.10);">
      <span class="font-heading text-20 md:text-28 font-semibold" style="color: #C4783A;" data-count-target="40" data-count-suffix="B" data-count-duration="1000">0B</span>
      <p class="font-mono-spec text-10 mt-0" style="color: rgba(245,242,236,0.45); letter-spacing: 0.08em;">Live CFU Delivered</p>
    </div>
    <div class="text-center md:border-r" style="border-color: rgba(255,255,255,0.10);">
      <span class="font-heading text-20 md:text-28 font-semibold" style="color: #C4783A;" data-count-target="2084" data-count-duration="1500">0</span>
      <p class="font-mono-spec text-10 mt-0" style="color: rgba(245,242,236,0.45); letter-spacing: 0.08em;">HELIUS Study Subjects</p>
    </div>
    <div class="text-center md:border-r" style="border-color: rgba(255,255,255,0.10);">
      <span class="font-heading text-20 md:text-28 font-semibold" style="color: #F5F2EC;">MAKTREK</span>
      <p class="font-mono-spec text-10 mt-0" style="color: rgba(245,242,236,0.45); letter-spacing: 0.08em;">Bi-Pass Technology</p>
    </div>
    <div class="text-center col-span-2 md:col-span-1">
      <span class="font-heading text-20 md:text-28 font-semibold" style="color: #F5F2EC;">Free</span>
      <p class="font-mono-spec text-10 mt-0" style="color: rgba(245,242,236,0.45); letter-spacing: 0.08em;">Shipping · All Orders</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Strip",
  "class": "trust-strip-section",
  "settings": []
}
{% endschema %}

<section class="section bg-white">
  <div class="container">
    <div class="mission">
      <!-- Image -->
      <div class="mission__image reveal-left">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 800 }} 800w"
            sizes="(max-width: 767px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            loading="lazy"
          >
        {%- else -%}
          <img
            src="{{ section.settings.fallback_asset | default: 'origin-bottle.webp' | asset_url }}"
            alt="BaseCode Health Origin"
            loading="lazy"
            style="width: 100%; height: 100%; object-fit: cover;"
          >
        {%- endif -%}
      </div>

      <!-- Content -->
      <div class="reveal-right">
        {%- if section.settings.subtitle != blank -%}
          <p class="mission__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <h2 class="mission__heading">{{ section.settings.heading | default: 'There\'s a science to the science.' }}</h2>

        <div class="mission__checklist">
          {%- for block in section.blocks -%}
            <div class="mission__check-item" {{ block.shopify_attributes }}>
              <div class="mission__check-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <span>{{ block.settings.text }}</span>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="link">{{ section.settings.button_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mission",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Mission"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Supplements informed by biological diversity research."
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "Fallback asset filename",
      "default": "origin-bottle.webp",
      "info": "Used when no image is picked"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/pages/science"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Checklist item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Informed by the HELIUS study (2,084 subjects, 6 ethnic groups)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mission",
      "blocks": [
        { "type": "item", "settings": { "text": "Informed by the HELIUS study (2,084 subjects, 6 ethnic groups)." } },
        { "type": "item", "settings": { "text": "Strains selected for biological diversity, not generic formulas." } },
        { "type": "item", "settings": { "text": "MAKTREK acid-protection ensures bacteria arrive alive." } }
      ]
    }
  ]
}
{% endschema %}

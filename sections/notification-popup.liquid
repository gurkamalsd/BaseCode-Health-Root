{%- comment -%}BaseCode Root - notification-popup{%- endcomment -%}
{%- if section.settings.enable -%}
<div class="notification-popup" id="notification-popup" data-popup-delay="{{ section.settings.delay | default: 5 }}">
  <button class="notification-popup__close" id="popup-close" aria-label="Close">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>

  {%- if section.settings.image != blank -%}
    <div style="width:100%;height:180px;border-radius:var(--radius-md);overflow:hidden;margin-bottom:var(--space-4);">
      <img src="{{ section.settings.image | image_url: width: 760 }}" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
    </div>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h3 style="font-family:var(--font-heading);font-size:var(--text-xl);font-weight:700;text-transform:uppercase;margin-bottom:var(--space-2);">
      {{ section.settings.heading }}
    </h3>
  {%- endif -%}

  {%- if section.settings.text != blank -%}
    <p style="font-size:var(--text-sm);color:var(--color-text-light);margin-bottom:var(--space-4);line-height:1.5;">
      {{ section.settings.text }}
    </p>
  {%- endif -%}

  {%- if section.settings.show_form -%}
    <form data-lead-form data-source="popup" style="display:flex;gap:var(--space-2);">
      <div style="position:absolute;left:-9999px;" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off">
      </div>
      <input type="email" name="email" class="form-input" placeholder="{{ 'forms.email_placeholder' | t }}" required style="flex:1;font-size:var(--text-sm);">
      <button type="submit" class="btn btn--primary btn--sm">{{ section.settings.button_text | default: 'Get Code' }}</button>
    </form>
    <div data-form-success style="display:none;padding:var(--space-4) 0;text-align:center;">
      <p style="font-weight:600;">{{ 'forms.success' | t }}</p>
      {%- if settings.discount_code != blank -%}
        <p style="font-family:var(--font-mono);font-size:var(--text-xl);font-weight:700;margin-top:var(--space-2);">{{ settings.discount_code }}</p>
      {%- endif -%}
    </div>
  {%- elsif section.settings.button_text != blank -%}
    <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn--primary btn--full">
      {{ section.settings.button_text }}
    </a>
  {%- endif -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var popup = document.getElementById('notification-popup');
    var closeBtn = document.getElementById('popup-close');
    if (!popup || sessionStorage.getItem('popup_dismissed')) return;

    var delay = parseInt(popup.dataset.popupDelay || '5') * 1000;
    var trigger = '{{ section.settings.trigger | default: "delay" }}';

    function showPopup() {
      if (!sessionStorage.getItem('popup_dismissed')) {
        popup.classList.add('is-visible');
      }
    }

    if (trigger === 'exit_intent') {
      document.addEventListener('mouseleave', function(e) {
        if (e.clientY < 10) showPopup();
      }, { once: true });
      setTimeout(showPopup, 30000);
    } else {
      setTimeout(showPopup, delay);
    }

    closeBtn.addEventListener('click', function() {
      popup.classList.remove('is-visible');
      sessionStorage.setItem('popup_dismissed', '1');
    });
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "Notification Popup",
  "settings": [
    { "type": "checkbox", "id": "enable", "label": "Enable popup", "default": true },
    {
      "type": "select", "id": "trigger", "label": "Trigger",
      "default": "delay",
      "options": [
        { "value": "delay", "label": "Time delay" },
        { "value": "exit_intent", "label": "Exit intent" }
      ]
    },
    { "type": "range", "id": "delay", "label": "Delay (seconds)", "min": 3, "max": 30, "step": 1, "default": 5 },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 20% off your first order" },
    { "type": "textarea", "id": "text", "label": "Body text", "default": "Join our list and receive your discount code instantly." },
    { "type": "checkbox", "id": "show_form", "label": "Show email form", "default": true },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Get Code" },
    { "type": "url", "id": "button_link", "label": "Button link (if no form)" }
  ],
  "presets": [{ "name": "Notification Popup" }]
}
{% endschema %}

{%- comment -%}BaseCode Root - hero{%- endcomment -%}
{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
  assign text_color = section.settings.text_color | default: '#FFFFFF'
  assign overlay_opacity = section.settings.overlay_opacity | default: 40
-%}

<section class="hero-fullbleed" data-hero-section>
  <!-- Background Image -->
  <div class="hero-fullbleed__bg">
    {%- if has_image -%}
      <img
        src="{{ section.settings.image | image_url: width: 2400 }}"
        srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1800 }} 1800w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'basecode-hero-bg-new.webp' | asset_url }}"
        alt="BaseCode Health"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>

  <!-- Overlay -->
  <div class="hero-fullbleed__overlay" style="background: rgba(0,0,0,{{ overlay_opacity | divided_by: 100.0 }});"></div>

  <!-- Content -->
  <div class="hero-fullbleed__content" style="color: {{ text_color }};">
    <div class="hero-fullbleed__inner">
      {%- if section.settings.show_social_proof -%}
        <div class="hero-fullbleed__proof reveal-hidden">
          <span class="stars">★★★★★</span>
          <span>{{ section.settings.social_proof_text | default: 'Backed by clinical research' }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="hero-fullbleed__subtitle reveal-hidden reveal-delay-1">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <h1 class="hero-fullbleed__heading reveal-hidden reveal-delay-2">
        {{ section.settings.heading | default: 'Engineered for Modern Biology.' }}
      </h1>

      {%- if section.settings.text != blank -%}
        <p class="hero-fullbleed__text reveal-hidden reveal-delay-3">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <div class="reveal-hidden reveal-delay-3">
          <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn--white btn--lg">
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}

      {%- if section.settings.guarantee_text != blank -%}
        <div class="hero-fullbleed__guarantee reveal-hidden reveal-delay-4">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <span>{{ section.settings.guarantee_text }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* Full-bleed hero — fills viewport, image covers entire background */
  .hero-fullbleed {
    position: relative;
    min-height: {{ section.settings.height | default: 100 }}vh;
    display: flex;
    align-items: {{ section.settings.vertical_align | default: 'center' }};
    justify-content: center;
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height));
    padding-top: var(--header-height);
  }

  .hero-fullbleed__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-fullbleed__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position | default: 'center center' }};
  }

  .hero-fullbleed__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-fullbleed__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--container-max);
    padding: var(--space-12) var(--container-padding);
    text-align: {{ section.settings.text_align | default: 'center' }};
  }

  .hero-fullbleed__inner {
    max-width: {{ section.settings.content_width | default: 700 }}px;
    {% if section.settings.text_align == 'left' %}
      margin-right: auto;
    {% elsif section.settings.text_align == 'right' %}
      margin-left: auto;
    {% else %}
      margin: 0 auto;
    {% endif %}
  }

  .hero-fullbleed__proof {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    opacity: 0.9;
    margin-bottom: var(--space-4);
  }

  .hero-fullbleed__proof .stars {
    color: #f59e0b;
    letter-spacing: 2px;
  }

  .hero-fullbleed__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-4);
    opacity: 0.8;
  }

  .hero-fullbleed__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  .hero-fullbleed__text {
    font-size: var(--text-lg);
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: var(--space-8);
    max-width: 520px;
    {% if section.settings.text_align == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
  }

  .hero-fullbleed__guarantee {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    opacity: 0.7;
  }

  /* Make header transparent when hero is first section */
  .hero-fullbleed ~ .header,
  [data-template="index"] .header {
    background: transparent;
    border-bottom-color: transparent;
    color: {{ text_color }};
  }

  [data-template="index"] .header.header--scrolled {
    background: var(--color-white);
    border-bottom-color: var(--color-border);
    color: var(--color-text);
  }

  @media (max-width: 767px) {
    .hero-fullbleed {
      min-height: {{ section.settings.mobile_height | default: 85 }}vh;
    }
    .hero-fullbleed__heading {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: 2400x1600px. Falls back to brand asset if empty."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "default": "center center",
      "options": [
        { "value": "top center", "label": "Top" },
        { "value": "center center", "label": "Center" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_social_proof",
      "label": "Show social proof",
      "default": true
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof text",
      "default": "Backed by clinical research"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Future of Supplements"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engineered for Modern Biology."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "Origin is the first probiotic engineered for the biological tax of modern life."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Discover Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical alignment",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ]
    },
    {
      "type": "range",
      "id": "height",
      "label": "Desktop height",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 85,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "default": 700,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

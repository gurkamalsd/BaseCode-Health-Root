<section class="hero" style="background-color: {{ section.settings.bg_color | default: '#F5F2EC' }};">
  <!-- Content Side -->
  <div class="hero__content" style="{% if section.settings.content_bg_color != blank %}background-color: {{ section.settings.content_bg_color }};{% endif %}">
    {%- if section.settings.show_social_proof -%}
      <div class="hero__social-proof reveal-hidden">
        <span class="stars">★★★★★</span>
        <span>{{ section.settings.social_proof_text | default: 'Backed by biological diversity research' }}</span>
      </div>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle reveal-hidden reveal-delay-1">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <h1 class="hero__heading reveal-hidden reveal-delay-2">{{ section.settings.heading }}</h1>

    {%- if section.settings.text != blank -%}
      <p style="font-size: var(--text-lg); margin-bottom: var(--space-6); max-width: 480px; opacity: 0.85;" class="reveal-hidden reveal-delay-3">
        {{ section.settings.text }}
      </p>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <div class="reveal-hidden reveal-delay-3">
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn--primary btn--lg">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.guarantee_text != blank -%}
      <div class="hero__guarantee reveal-hidden reveal-delay-4">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        <span>{{ section.settings.guarantee_text }}</span>
      </div>
    {%- endif -%}
  </div>

  <!-- Image Side -->
  <div class="hero__image">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
        sizes="(max-width: 767px) 100vw, 50vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'basecode-hero-bg-new.webp' | asset_url }}"
        alt="BaseCode Health — Supplements built for your biology"
        loading="eager"
        fetchpriority="high"
        style="width: 100%; height: 100%; object-fit: cover;"
      >
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F2EC"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content area background",
      "default": ""
    },
    {
      "type": "checkbox",
      "id": "show_social_proof",
      "label": "Show social proof badge",
      "default": true
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof text",
      "default": "Backed by biological diversity research"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Future of Supplements"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your biology is unique. Your supplements should be too."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "Origin is the first probiotic informed by biological diversity research. 40 billion CFU. 4 targeted strains. MAKTREK delivery."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Discover Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/products/origin"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

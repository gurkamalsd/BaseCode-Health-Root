<section class="py-16 md:py-20 px-6 md:px-20" style="background: #F5F2EC;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="text-center mb-12 reveal-hidden">
      <p class="font-mono-spec text-11 uppercase mb-4" style="color: #C4783A; letter-spacing: 0.2em;">Why Origin Is Different</p>
      <h2 class="font-heading text-28 md:text-44 font-medium" style="color: #1A1A1A;">
        Built different. Because your biology <em class="italic" style="color: #C4783A;">is</em> different.
      </h2>
      <p class="font-heading text-16 md:text-18 font-light mt-4 mx-auto" style="color: #4A5550; max-width: 560px; line-height: 1.7;">
        Generic probiotics weren't designed for you. Origin does four things no other probiotic does.
      </p>
    </div>

    {%- assign pillar_titles = "Adaptobiotic Protocol|MAKTREK Bi-Pass|cGMP Manufactured|Synbiotic Formula" | split: "|" -%}
    {%- assign pillar_descs = "The first probiotic engineered for systemic adaptation. Built for people whose background, heritage, and environment make generic supplements useless.|Marine polysaccharide shield protects bacteria through stomach acid. Delivered alive to your intestine. Not a coating — a different delivery system.|Produced in a cGMP-certified, FDA-registered facility in the USA. COA with every batch. 40 billion CFU guaranteed.|Probiotic + prebiotic in one capsule. FOS feeds the bacteria on arrival. Deliver alive. Feed on impact." | split: "|" -%}

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
      {%- for title in pillar_titles -%}
        <div class="reveal-hidden rounded-2xl p-6 md:p-8 card-hover" style="background: #1C2E23; border: 1px solid rgba(255,255,255,0.08);">
          <div class="flex items-start gap-4">
            <div class="shrink-0 flex items-center justify-center rounded-xl" style="width: 48px; height: 48px; background: rgba(196,120,58,0.12); border: 1px solid rgba(196,120,58,0.20);">
              {%- case forloop.index0 -%}
                {%- when 0 -%}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                {%- when 1 -%}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {%- when 2 -%}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {%- when 3 -%}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              {%- endcase -%}
            </div>
            <div>
              <h3 class="font-heading text-18 md:text-20 font-medium mb-2" style="color: #F5F2EC;">{{ title }}</h3>
              <p class="font-heading text-14 md:text-15 font-light" style="color: rgba(245,242,236,0.60); line-height: 1.7;">{{ pillar_descs[forloop.index0] }}</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="text-center mt-10 reveal-hidden">
      <a href="/pages/free-report" class="inline-block font-heading text-15 font-medium py-3 transition hover:underline" style="color: #C4783A;">
        Read the full formulation rationale in our free research report →
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pillars",
  "class": "pillars-section",
  "settings": []
}
{% endschema %}

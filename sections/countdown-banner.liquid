{%- comment -%}BaseCode Root - countdown-banner{%- endcomment -%}

{%- liquid
  assign section_id   = 'countdown-banner-' | append: section.id
  assign pt           = section.settings.padding_top   | default: 60
  assign pb           = section.settings.padding_bottom | default: 60
  assign enable_anim  = section.settings.enable_animation
  assign box_style    = section.settings.box_style | default: 'cards'
  assign h_level      = section.settings.heading_level | default: 'h2'
  assign h_size       = section.settings.heading_size  | default: 'h2'
  assign end_date     = section.settings.end_date | default: ''
  assign has_bg_image = false
  if section.settings.bg_image != blank
    assign has_bg_image = true
  endif
  assign has_mobile_bg = false
  if section.settings.bg_image_mobile != blank
    assign has_mobile_bg = true
  endif

  case h_size
    when 'h1'
      assign h_fs = 'var(--text-5xl, 3rem)'
    when 'h2'
      assign h_fs = 'var(--text-4xl, 2.25rem)'
    when 'h3'
      assign h_fs = 'var(--text-3xl, 1.875rem)'
    when 'h4'
      assign h_fs = 'var(--text-2xl, 1.5rem)'
    when 'h5'
      assign h_fs = 'var(--text-xl, 1.25rem)'
    when 'h6'
      assign h_fs = 'var(--text-lg, 1.125rem)'
    else
      assign h_fs = 'var(--text-4xl, 2.25rem)'
  endcase

  assign overlay_opacity_decimal = section.settings.overlay_opacity | default: 40 | divided_by: 100.0
  assign accent_color  = section.settings.accent_color  | default: '#C4783A'
  assign bg_color      = section.settings.bg_color      | default: '#1C2E23'
  assign text_color    = section.settings.text_color    | default: '#F5F2EC'
  assign overlay_color = section.settings.overlay_color | default: '#000000'
-%}

<section
  id="{{ section_id }}"
  class="countdown-banner-section{% if enable_anim %} anim-enabled{% endif %}"
  style="
    position: relative;
    background-color: {{ bg_color }};
    color: {{ text_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
    overflow: hidden;
    text-align: center;
  "
>

  {%- comment -%}---- Background image (desktop) ----{%- endcomment -%}
  {%- if has_bg_image -%}
    <img
      class="countdown-banner__bg-img countdown-banner__bg-img--desktop{% if has_mobile_bg %} countdown-banner__bg-img--hide-mobile{% endif %}"
      src="{{ section.settings.bg_image | image_url: width: 2400 }}"
      srcset="
        {{ section.settings.bg_image | image_url: width: 800 }}  800w,
        {{ section.settings.bg_image | image_url: width: 1200 }} 1200w,
        {{ section.settings.bg_image | image_url: width: 1800 }} 1800w,
        {{ section.settings.bg_image | image_url: width: 2400 }} 2400w
      "
      sizes="100vw"
      alt="{{ section.settings.bg_image.alt | default: '' }}"
      loading="lazy"
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        pointer-events: none;
      "
    >
  {%- endif -%}

  {%- comment -%}---- Background image (mobile) ----{%- endcomment -%}
  {%- if has_mobile_bg -%}
    <img
      class="countdown-banner__bg-img countdown-banner__bg-img--mobile"
      src="{{ section.settings.bg_image_mobile | image_url: width: 800 }}"
      srcset="
        {{ section.settings.bg_image_mobile | image_url: width: 400 }} 400w,
        {{ section.settings.bg_image_mobile | image_url: width: 800 }} 800w
      "
      sizes="100vw"
      alt="{{ section.settings.bg_image_mobile.alt | default: '' }}"
      loading="lazy"
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        pointer-events: none;
        display: none;
      "
    >
  {%- endif -%}

  {%- comment -%}---- Overlay ----{%- endcomment -%}
  {%- if has_bg_image or has_mobile_bg -%}
    <div
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        z-index: 1;
        background-color: {{ overlay_color }};
        opacity: {{ overlay_opacity_decimal }};
        pointer-events: none;
      "
    ></div>
  {%- endif -%}

  {%- comment -%}---- Content wrapper ----{%- endcomment -%}
  <div
    class="{% if section.settings.full_width %}container--wide{% else %}container{% endif %}"
    style="position: relative; z-index: 2;"
  >

    {%- comment -%}---- Subheading ----{%- endcomment -%}
    {%- if section.settings.subheading != blank -%}
      <p
        class="countdown-banner__subheading{% if enable_anim %} anim-fade-up{% endif %}"
        style="
          font-family: var(--font-heading);
          font-size: var(--text-sm, 0.875rem);
          font-weight: 600;
          text-transform: uppercase;
          letter-spacing: 0.12em;
          color: {{ accent_color }};
          margin: 0 0 var(--space-3, 0.75rem);
        "
      >{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- comment -%}---- Heading ----{%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <{{ h_level }}
        class="countdown-banner__heading{% if enable_anim %} anim-fade-up{% endif %}"
        style="
          font-size: {{ h_fs }};
          line-height: 1.15;
          margin: 0 0 var(--space-4, 1rem);
          color: {{ text_color }};
        "
      >{{ section.settings.heading }}</{{ h_level }}>
    {%- endif -%}

    {%- comment -%}---- Body text ----{%- endcomment -%}
    {%- if section.settings.body_text != blank -%}
      <div
        class="countdown-banner__body{% if enable_anim %} anim-fade-up{% endif %}"
        style="
          font-size: var(--text-lg, 1.125rem);
          line-height: 1.65;
          color: {{ text_color }};
          opacity: 0.85;
          max-width: 640px;
          margin: 0 auto var(--space-6, 1.5rem);
        "
      >{{ section.settings.body_text }}</div>
    {%- endif -%}

    {%- comment -%}---- Countdown timer ----{%- endcomment -%}
    {%- if end_date != blank -%}
      <div
        class="countdown-banner__timer{% if enable_anim %} anim-fade-up{% endif %}"
        style="margin-bottom: var(--space-8, 2rem);"
      >
        <div
          class="countdown-banner__units countdown-banner__units--{{ box_style }}"
          id="cdb-units-{{ section.id }}"
          data-countdown="{{ end_date }}"
          role="timer"
          aria-live="off"
          aria-label="Countdown timer"
          style="
            display: inline-flex;
            align-items: flex-start;
            gap: {{ section.settings.unit_gap | default: 16 }}px;
            flex-wrap: nowrap;
          "
        >
          {%- assign countdown_units = 'days,hours,mins,secs' | split: ',' -%}
          {%- for unit_item in countdown_units -%}
            {%- assign unit_label = unit_item -%}
            <div
              class="countdown-banner__unit"
              style="
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 6px;
              "
            >
              {%- comment -%} Number box {%- endcomment -%}
              <div
                class="countdown-banner__num countdown-banner__{{ unit_item }}"
                style="
                  font-family: var(--font-mono, monospace);
                  font-size: {{ section.settings.number_size | default: 56 }}px;
                  font-weight: 800;
                  line-height: 1;
                  color: {{ section.settings.number_color | default: text_color }};
                  {%- if box_style == 'cards' -%}
                    background-color: {{ accent_color }};
                    color: #fff;
                    min-width: {{ section.settings.number_size | default: 56 | plus: 24 }}px;
                    padding: 14px 20px;
                    border-radius: 8px;
                    box-shadow: 0 4px 18px rgba(0,0,0,0.2);
                  {%- elsif box_style == 'circles' -%}
                    background-color: {{ accent_color }};
                    color: #fff;
                    width: {{ section.settings.number_size | default: 56 | plus: 36 }}px;
                    height: {{ section.settings.number_size | default: 56 | plus: 36 }}px;
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    box-shadow: 0 4px 18px rgba(0,0,0,0.2);
                  {%- else -%}
                    background: transparent;
                  {%- endif -%}
                  display: {%- if box_style == 'circles' -%} flex {%- else -%} block {%- endif -%};
                  text-align: center;
                "
              >00</div>

              {%- comment -%} Unit label {%- endcomment -%}
              <div
                class="countdown-banner__unit-label"
                style="
                  font-size: var(--text-xs, 0.75rem);
                  text-transform: uppercase;
                  letter-spacing: 0.1em;
                  color: {{ text_color }};
                  opacity: 0.7;
                  line-height: 1;
                "
              >{{ unit_label }}</div>
            </div>

            {%- comment -%} Separator colon between units (not after last) {%- endcomment -%}
            {%- unless forloop.last -%}
              <div
                class="countdown-banner__sep"
                aria-hidden="true"
                style="
                  font-family: var(--font-mono, monospace);
                  font-size: {{ section.settings.number_size | default: 56 }}px;
                  font-weight: 800;
                  line-height: 1;
                  color: {{ accent_color }};
                  {%- if box_style == 'cards' or box_style == 'circles' -%}
                    padding-top: 14px;
                  {%- endif -%}
                  align-self: flex-start;
                  opacity: 0.8;
                "
              >:</div>
            {%- endunless -%}

          {%- endfor -%}
        </div>

        {%- comment -%} Expired message (hidden by default, shown by JS when timer hits zero) {%- endcomment -%}
        <p
          class="countdown-banner__expired"
          id="cdb-expired-{{ section.id }}"
          style="
            display: none;
            font-size: var(--text-lg, 1.125rem);
            font-weight: 600;
            color: {{ accent_color }};
            margin: 0;
          "
        >{{ section.settings.expired_message | default: 'This offer has ended.' }}</p>

      </div>
    {%- endif -%}

    {%- comment -%}---- CTA button ----{%- endcomment -%}
    {%- if section.settings.button_text != blank -%}
      <div class="countdown-banner__cta{% if enable_anim %} anim-fade-up{% endif %}">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="btn btn--{{ section.settings.button_style | default: 'primary' }} btn--lg"
        >
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}

  </div>{%- comment -%}end container{%- endcomment -%}
</section>

{%- comment -%}---- Section-scoped CSS ----{%- endcomment -%}
<style>
  {%- if has_mobile_bg -%}
  @media (max-width: 767px) {
    #{{ section_id }} .countdown-banner__bg-img--hide-mobile { display: none !important; }
    #{{ section_id }} .countdown-banner__bg-img--mobile      { display: block !important; }
  }
  {%- endif -%}

  @media (max-width: 767px) {
    #{{ section_id }} .countdown-banner__units {
      gap: {{ section.settings.unit_gap | default: 16 | divided_by: 2 }}px !important;
    }
    #{{ section_id }} .countdown-banner__num {
      font-size: {{ section.settings.number_size | default: 56 | times: 0.65 | round }}px !important;
      {%- if box_style == 'cards' -%}
      min-width: {{ section.settings.number_size | default: 56 | times: 0.65 | round | plus: 16 }}px !important;
      padding: 10px 14px !important;
      {%- elsif box_style == 'circles' -%}
      width: {{ section.settings.number_size | default: 56 | times: 0.65 | round | plus: 24 }}px !important;
      height: {{ section.settings.number_size | default: 56 | times: 0.65 | round | plus: 24 }}px !important;
      {%- endif -%}
    }
    #{{ section_id }} .countdown-banner__sep {
      font-size: {{ section.settings.number_size | default: 56 | times: 0.65 | round }}px !important;
    }
    #{{ section_id }} .countdown-banner__heading {
      font-size: calc({{ h_fs }} * 0.75) !important;
    }
  }

  {%- if enable_anim -%}
  #{{ section_id }} .anim-fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  #{{ section_id }}.in-view .anim-fade-up {
    opacity: 1;
    transform: none;
  }
  #{{ section_id }}.in-view .anim-fade-up:nth-child(1) { transition-delay: 0.05s; }
  #{{ section_id }}.in-view .anim-fade-up:nth-child(2) { transition-delay: 0.15s; }
  #{{ section_id }}.in-view .anim-fade-up:nth-child(3) { transition-delay: 0.25s; }
  #{{ section_id }}.in-view .anim-fade-up:nth-child(4) { transition-delay: 0.35s; }
  #{{ section_id }}.in-view .anim-fade-up:nth-child(5) { transition-delay: 0.45s; }
  {%- endif -%}
</style>

{%- comment -%}---- Countdown JS ----{%- endcomment -%}
{%- if end_date != blank -%}
<script>
(function () {
  'use strict';

  var END_DATE   = new Date('{{ end_date }}').getTime();
  var unitsEl    = document.getElementById('cdb-units-{{ section.id }}');
  var expiredEl  = document.getElementById('cdb-expired-{{ section.id }}');

  if (!unitsEl) return;

  // Validate date
  if (isNaN(END_DATE)) {
    console.warn('[countdown-banner] Invalid end_date: {{ end_date }}');
    return;
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    var now  = Date.now();
    var diff = END_DATE - now;

    if (diff <= 0) {
      // Timer expired
      unitsEl.style.display = 'none';
      if (expiredEl) {
        expiredEl.style.display = 'block';
      }
      clearInterval(timer);
      return;
    }

    var days  = Math.floor(diff / 86400000);
    var hours = Math.floor((diff % 86400000) / 3600000);
    var mins  = Math.floor((diff % 3600000) / 60000);
    var secs  = Math.floor((diff % 60000) / 1000);

    var d = unitsEl.querySelector('.countdown-banner__days');
    var h = unitsEl.querySelector('.countdown-banner__hours');
    var m = unitsEl.querySelector('.countdown-banner__mins');
    var s = unitsEl.querySelector('.countdown-banner__secs');

    if (d) d.textContent = pad(days);
    if (h) h.textContent = pad(hours);
    if (m) m.textContent = pad(mins);
    if (s) s.textContent = pad(secs);
  }

  // Run immediately then set interval
  tick();
  var timer = setInterval(tick, 1000);
})();
</script>
{%- endif -%}

{%- if enable_anim -%}
<script>
(function () {
  var el = document.getElementById('{{ section_id }}');
  if (!el) return;
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    obs.observe(el);
  } else {
    el.classList.add('in-view');
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Countdown Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Founding Member Pricing"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch Special — Limited Time"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level (SEO)",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Extra large (H1 size)" },
        { "value": "h2", "label": "Large (H2 size)" },
        { "value": "h3", "label": "Medium (H3 size)" },
        { "value": "h4", "label": "Small (H4 size)" },
        { "value": "h5", "label": "Extra small (H5 size)" },
        { "value": "h6", "label": "Tiny (H6 size)" }

{%- comment -%}BaseCode Root - slideshow{%- endcomment -%}
<section class="slideshow" data-slideshow style="height: {{ section.settings.height | default: 85 }}vh;">
  <div class="slideshow__track" data-slideshow-track>
    {%- for block in section.blocks -%}
      <div class="slideshow__slide {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <!-- Background Image -->
        <div class="slideshow__bg">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 2400 }}"
              srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1400 }} 1400w, {{ block.settings.image | image_url: width: 2400 }} 2400w"
              sizes="100vw"
              alt="{{ block.settings.heading | default: 'Slide' }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(135deg, var(--color-primary), var(--color-accent));"></div>
          {%- endif -%}
        </div>

        <!-- Overlay -->
        <div class="slideshow__overlay" style="background:rgba(0,0,0,{{ block.settings.overlay | default: 30 | divided_by: 100.0 }});"></div>

        <!-- Content -->
        <div class="slideshow__content" style="text-align:{{ block.settings.text_align | default: 'center' }}; color:{{ block.settings.text_color | default: '#FFFFFF' }};">
          {%- if block.settings.subheading != blank -%}
            <p class="slideshow__subheading">{{ block.settings.subheading }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="slideshow__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="slideshow__text">{{ block.settings.text }}</p>
          {%- endif -%}
          {%- if block.settings.button_text != blank -%}
            <a href="{{ block.settings.button_link | default: '#' }}" class="btn btn--white btn--lg">{{ block.settings.button_text }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="slideshow__nav">
      <button class="slideshow__arrow slideshow__arrow--prev" data-slideshow-prev aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <div class="slideshow__dots">
        {%- for block in section.blocks -%}
          <button class="slideshow__dot {% if forloop.first %}is-active{% endif %}" data-slideshow-dot="{{ forloop.index0 }}"></button>
        {%- endfor -%}
      </div>
      <button class="slideshow__arrow slideshow__arrow--next" data-slideshow-next aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  {%- endif -%}
</section>

<style>
  .slideshow { position: relative; overflow: hidden; }
  .slideshow__track { position: relative; width: 100%; height: 100%; }
  .slideshow__slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 0.8s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .slideshow__slide.is-active { opacity: 1; z-index: 1; }
  .slideshow__bg { position: absolute; inset: 0; }
  .slideshow__bg img { width: 100%; height: 100%; object-fit: cover; }
  .slideshow__overlay { position: absolute; inset: 0; z-index: 1; }
  .slideshow__content {
    position: relative; z-index: 2;
    max-width: 800px; padding: var(--space-8) var(--container-padding);
  }
  .slideshow__subheading {
    font-size: var(--text-sm); text-transform: uppercase;
    letter-spacing: 0.15em; margin-bottom: var(--space-3); opacity: 0.8;
  }
  .slideshow__heading {
    font-family: var(--font-heading); font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700; text-transform: uppercase; line-height: 1.05;
    margin-bottom: var(--space-4);
  }
  .slideshow__text { font-size: var(--text-lg); opacity: 0.85; margin-bottom: var(--space-6); max-width: 500px; }
  .slideshow__nav {
    position: absolute; bottom: var(--space-8); left: 50%;
    transform: translateX(-50%); z-index: 3;
    display: flex; align-items: center; gap: var(--space-4);
  }
  .slideshow__arrow {
    width: 44px; height: 44px; border-radius: var(--radius-full);
    background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer; border: none;
    transition: background var(--duration-fast);
  }
  .slideshow__arrow:hover { background: rgba(255,255,255,0.4); }
  .slideshow__dots { display: flex; gap: var(--space-2); }
  .slideshow__dot {
    width: 8px; height: 8px; border-radius: var(--radius-full);
    background: rgba(255,255,255,0.4); border: none; cursor: pointer;
    transition: all var(--duration-fast);
  }
  .slideshow__dot.is-active { background: #fff; width: 24px; }

  @media (max-width: 767px) {
    .slideshow { height: {{ section.settings.mobile_height | default: 70 }}vh !important; }
  }
</style>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "Desktop height",
      "min": 40, "max": 100, "step": 5, "default": 85, "unit": "vh"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 40, "max": 100, "step": 5, "default": 70, "unit": "vh"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "label": "Rotation speed (seconds)",
      "min": 3, "max": 10, "step": 1, "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "text", "id": "subheading", "label": "Subheading" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered for Modern Biology." },
        { "type": "textarea", "id": "text", "label": "Body text" },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop Now" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        {
          "type": "select", "id": "text_align", "label": "Text alignment", "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
        { "type": "range", "id": "overlay", "label": "Overlay darkness", "min": 0, "max": 80, "step": 5, "default": 30, "unit": "%" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide", "settings": { "heading": "Engineered for Modern Biology.", "button_text": "Discover Now" } },
        { "type": "slide", "settings": { "heading": "The First Adaptobiotic.", "button_text": "Shop Origin" } }
      ]
    }
  ]
}
{% endschema %}

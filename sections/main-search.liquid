{%- comment -%}
  BaseCode Root — main-search
  Search results page with configurable results-per-page, product image toggle,
  full color/padding controls, and animation.
  Settings: bg_color, text_color, padding_top/bottom, results_per_page,
            show_product_images, enable_animation
{%- endcomment -%}

{%- liquid
  assign bg           = section.settings.bg_color
  assign tc           = section.settings.text_color
  assign pt           = section.settings.padding_top
  assign pb           = section.settings.padding_bottom
  assign animate      = section.settings.enable_animation
  assign per_page     = section.settings.results_per_page | default: 12
  assign show_images  = section.settings.show_product_images
-%}

<style>
  #shopify-section-{{ section.id }} .s-search-wrap {
    background-color: {{ bg }};
    color: {{ tc }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }
  #shopify-section-{{ section.id }} .s-search-wrap h1,
  #shopify-section-{{ section.id }} .s-search-wrap h3,
  #shopify-section-{{ section.id }} .s-search-wrap p {
    color: inherit;
  }
  #shopify-section-{{ section.id }} .s-search-title {
    text-align: center;
    font-size: var(--text-4xl, 2.25rem);
    font-weight: 700;
    margin-bottom: var(--space-8, 2rem);
  }
  #shopify-section-{{ section.id }} .s-search-form {
    max-width: 520px;
    margin: 0 auto var(--space-10, 2.5rem);
  }
  #shopify-section-{{ section.id }} .s-search-form-inner {
    display: flex;
    gap: var(--space-3, 0.75rem);
  }
  #shopify-section-{{ section.id }} .s-search-form .form-input {
    flex: 1;
  }
  #shopify-section-{{ section.id }} .s-search-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6, 1.5rem);
  }
  @media (max-width: 1023px) {
    #shopify-section-{{ section.id }} .s-search-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    #shopify-section-{{ section.id }} .s-search-grid {
      grid-template-columns: 1fr;
    }
  }
  #shopify-section-{{ section.id }} .s-search-result-card {
    background: rgba(0,0,0,0.03);
    border-radius: var(--radius-lg, 0.75rem);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__body {
    padding: var(--space-4, 1rem) var(--space-5, 1.25rem);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
  }
  #shopify-section-{{ section.id }} .s-search-result-card__type {
    font-size: var(--text-xs, 0.75rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.5;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__title {
    font-size: var(--text-base, 1rem);
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__title a {
    color: inherit;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__title a:hover {
    text-decoration: underline;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__excerpt {
    font-size: var(--text-sm, 0.875rem);
    opacity: 0.65;
    line-height: 1.6;
  }
  #shopify-section-{{ section.id }} .s-search-result-card__price {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    margin-top: auto;
    padding-top: var(--space-2, 0.5rem);
  }
  #shopify-section-{{ section.id }} .s-search-empty {
    text-align: center;
    opacity: 0.6;
    font-size: var(--text-lg, 1.125rem);
    padding: var(--space-12, 3rem) 0;
  }
  #shopify-section-{{ section.id }} .s-search-results-count {
    text-align: center;
    font-size: var(--text-sm, 0.875rem);
    opacity: 0.55;
    margin-bottom: var(--space-8, 2rem);
  }
  {%- if animate -%}
  @keyframes sSearchFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #shopify-section-{{ section.id }} .s-search-animate {
    animation: sSearchFadeUp 0.5s ease both;
  }
  #shopify-section-{{ section.id }} .s-search-result-card {
    animation: sSearchFadeUp 0.5s ease both;
  }
  {%- for i in (1..24) -%}
  #shopify-section-{{ section.id }} .s-search-result-card:nth-child({{ i }}) {
    animation-delay: {{ i | minus: 1 | times: 0.06 }}s;
  }
  {%- endfor -%}
  {%- endif -%}
</style>

<div class="s-search-wrap">
  <div class="container container--narrow">

    <h1 class="s-search-title{% if animate %} s-search-animate{% endif %}">
      {{ 'general.search' | t }}
    </h1>

    <div class="s-search-form{% if animate %} s-search-animate{% endif %}">
      <form action="/search" method="get">
        <div class="s-search-form-inner">
          <input
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            class="form-input"
            placeholder="{{ 'general.search' | t }}..."
            autofocus
            aria-label="{{ 'general.search' | t }}"
          >
          <button type="submit" class="btn btn--primary">
            {{ 'general.search' | t }}
          </button>
        </div>
      </form>
    </div>

    {%- if search.performed -%}

      {%- paginate search.results by per_page -%}

        {%- if search.results.size > 0 -%}

          <p class="s-search-results-count">
            {{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for &ldquo;{{ search.terms | escape }}&rdquo;
          </p>

          <div class="s-search-grid">
            {%- for result in search.results -%}

              {%- if result.object_type == 'product' -%}
                <div class="s-search-result-card">
                  {%- if show_images and result.featured_image -%}
                    <a href="{{ result.url }}" tabindex="-1" aria-hidden="true">
                      <img
                        src="{{ result.featured_image | image_url: width: 500 }}"
                        alt="{{ result.featured_image.alt | default: result.title }}"
                        loading="lazy"
                        class="s-search-result-card__img"
                        width="500"
                        height="500"
                      >
                    </a>
                  {%- endif -%}
                  <div class="s-search-result-card__body">
                    <span class="s-search-result-card__type">Product</span>
                    <h3 class="s-search-result-card__title">
                      <a href="{{ result.url }}">{{ result.title }}</a>
                    </h3>
                    {%- if result.price -%}
                      <p class="s-search-result-card__price">
                        {{ result.price | money }}
                      </p>
                    {%- endif -%}
                  </div>
                </div>

              {%- else -%}
                <div class="s-search-result-card">
                  <div class="s-search-result-card__body">
                    <span class="s-search-result-card__type">{{ result.object_type | capitalize }}</span>
                    <h3 class="s-search-result-card__title">
                      <a href="{{ result.url }}">{{ result.title }}</a>
                    </h3>
                    <p class="s-search-result-card__excerpt">
                      {{ result.content | strip_html | truncate: 160 }}
                    </p>
                  </div>
                </div>

              {%- endif -%}

            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="flex justify-center gap-2 mt-12" aria-label="Search results pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="btn btn--secondary btn--sm">&laquo; Prev</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="btn btn--secondary btn--sm">{{ part.title }}</a>
                {%- else -%}
                  <span class="btn btn--primary btn--sm">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="btn btn--secondary btn--sm">Next &raquo;</a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        {%- else -%}

          <p class="s-search-empty">
            {{ 'general.no_results' | t }} &ldquo;{{ search.terms | escape }}&rdquo;
          </p>

        {%- endif -%}

      {%- endpaginate -%}

    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Search Page",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1C2E23"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Results"
    },
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 6,
      "max": 24,
      "step": 6,
      "default": 12
    },
    {
      "type": "header",
      "content": "Display Options"
    },
    {
      "type": "checkbox",
      "id": "show_product_images",
      "label": "Show product images",
      "default": true
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable fade-up animation",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Search Page"
    }
  ]
}
{% endschema %}

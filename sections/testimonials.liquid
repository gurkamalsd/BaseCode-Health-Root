{%- comment -%}BaseCode Root - testimonials{%- endcomment -%}
<section class="section bg-white">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-center mb-10 reveal-hidden">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="testimonials__carousel" data-testimonial-carousel>
      {%- for block in section.blocks -%}
        <div class="testimonial {% unless forloop.first %}{% endunless %}" data-testimonial-slide="{{ forloop.index0 }}" {% unless forloop.first %}style="display: none;"{% endunless %} {{ block.shopify_attributes }}>
          {%- if block.settings.avatar != blank -%}
            <div class="testimonial__avatar">
              <img src="{{ block.settings.avatar | image_url: width: 160 }}" alt="{{ block.settings.author }}" width="80" height="80" loading="lazy">
            </div>
          {%- else -%}
            <div class="testimonial__avatar" style="background: var(--color-cream); display: flex; align-items: center; justify-content: center;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light)" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
          {%- endif -%}

          <div class="testimonial__stars">★★★★★</div>

          <p class="testimonial__quote">"{{ block.settings.quote }}"</p>

          <p class="testimonial__author">{{ block.settings.author }}</p>
        </div>
      {%- endfor -%}

      {%- if section.blocks.size > 1 -%}
        <div class="carousel__dots">
          {%- for block in section.blocks -%}
            <button class="carousel__dot {% if forloop.first %}is-active{% endif %}" data-testimonial-dot="{{ forloop.index0 }}" aria-label="Testimonial {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Finally, a supplement that actually considers my biology. I noticed a difference within the first week."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Priya S."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "Finally, a supplement that considers my biology. I noticed a difference within the first week.", "author": "Priya S." } },
        { "type": "testimonial", "settings": { "quote": "I've tried every probiotic out there. Origin is the first one that actually works for my body.", "author": "Marcus T." } }
      ]
    }
  ]
}
{% endschema %}

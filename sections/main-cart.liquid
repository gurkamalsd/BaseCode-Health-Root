<section class="section bg-white">
  <div class="container container--narrow">
    <h1 class="text-center mb-10">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count == 0 -%}
      <div class="text-center" style="padding: var(--space-12) 0;">
        <p style="font-size: var(--text-lg); color: var(--color-text-light); margin-bottom: var(--space-6);">{{ 'cart.empty' | t }}</p>
        <a href="/collections/all" class="btn btn--primary btn--lg">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    {%- else -%}
      <form action="/cart" method="post">
        {%- for item in cart.items -%}
          <div class="flex gap-6 items-start" style="padding: var(--space-6) 0; border-bottom: 1px solid var(--color-border);">
            <a href="{{ item.url }}" style="flex-shrink: 0; width: 100px; height: 100px; border-radius: var(--radius-md); overflow: hidden; background: var(--color-cream);">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" width="100" height="100" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
              {%- endif -%}
            </a>
            <div style="flex: 1;">
              <a href="{{ item.url }}" style="font-weight: 600; font-size: var(--text-base);">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' -%}
                <p style="font-size: var(--text-sm); color: var(--color-text-light);">{{ item.variant.title }}</p>
              {%- endif -%}
              {%- if item.selling_plan_allocation -%}
                <p style="font-size: var(--text-xs); color: var(--color-accent); margin-top: var(--space-1);">{{ item.selling_plan_allocation.selling_plan.name }}</p>
              {%- endif -%}
              <div class="flex items-center gap-4 mt-4">
                <div class="flex items-center" style="border: 1px solid var(--color-border); border-radius: var(--radius-sm);">
                  <a href="/cart/change?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" style="padding: var(--space-2) var(--space-3); font-size: var(--text-sm);">-</a>
                  <span style="padding: var(--space-2) var(--space-3); font-size: var(--text-sm); min-width: 32px; text-align: center;">{{ item.quantity }}</span>
                  <a href="/cart/change?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" style="padding: var(--space-2) var(--space-3); font-size: var(--text-sm);">+</a>
                </div>
                <a href="/cart/change?id={{ item.key }}&quantity=0" style="font-size: var(--text-xs); color: var(--color-text-light); text-decoration: underline;">{{ 'cart.remove' | t }}</a>
              </div>
            </div>
            <div style="text-align: right;">
              <p style="font-family: var(--font-mono); font-weight: 600;">{{ item.final_line_price | money }}</p>
              {%- if item.original_line_price > item.final_line_price -%}
                <del style="font-size: var(--text-sm); color: var(--color-text-light);">{{ item.original_line_price | money }}</del>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}

        <!-- Cart Footer -->
        <div style="padding: var(--space-8) 0;">
          <div class="flex justify-between items-center mb-4">
            <span style="font-size: var(--text-lg); font-weight: 600;">{{ 'cart.subtotal' | t }}</span>
            <span style="font-family: var(--font-mono); font-size: var(--text-xl); font-weight: 700;">{{ cart.total_price | money }}</span>
          </div>
          <p style="font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-6);">{{ 'cart.taxes_shipping_notice' | t }}</p>
          <button type="submit" name="checkout" class="btn btn--primary btn--full btn--lg">{{ 'cart.checkout' | t }}</button>
          <a href="/collections/all" style="display: block; text-align: center; margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-text-light); text-decoration: underline;">{{ 'cart.continue_shopping' | t }}</a>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}

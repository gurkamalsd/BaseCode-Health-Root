{%- comment -%}BaseCode Root - trust-badges{%- endcomment -%}

{%- liquid
  assign pt = section.settings.padding_top
  assign pb = section.settings.padding_bottom
  assign bg = section.settings.bg_color | default: '#F5F2EC'
  assign tc = section.settings.text_color | default: '#1C2E23'
  assign ac = section.settings.accent_color | default: '#C4783A'
  assign icon_size = section.settings.icon_size | default: 28

  case section.settings.columns
    when '4'
      assign col_class = 'trust-badges__grid--4'
    when '6'
      assign col_class = 'trust-badges__grid--6'
    else
      assign col_class = 'trust-badges__grid--3'
  endcase

  assign card_style = section.settings.card_style | default: 'minimal'
  assign badge_layout = section.settings.badge_layout | default: 'stacked'
  assign full_width = section.settings.full_width
-%}

{%- style -%}
  #section-{{ section.id }} {
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
    background-color: {{ bg }};
    color: {{ tc }};
  }
  #section-{{ section.id }} .trust-badges__grid {
    display: grid;
    gap: 24px;
  }
  #section-{{ section.id }} .trust-badges__grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  #section-{{ section.id }} .trust-badges__grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  #section-{{ section.id }} .trust-badges__grid--6 {
    grid-template-columns: repeat(6, 1fr);
  }
  @media (max-width: 1023px) {
    #section-{{ section.id }} .trust-badges__grid--6 {
      grid-template-columns: repeat(3, 1fr);
    }
    #section-{{ section.id }} .trust-badges__grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    #section-{{ section.id }} .trust-badges__grid--3,
    #section-{{ section.id }} .trust-badges__grid--4,
    #section-{{ section.id }} .trust-badges__grid--6 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  {%- comment -%} Badge base styles {%- endcomment -%}
  #section-{{ section.id }} .trust-badge {
    display: flex;
    gap: 12px;
  }
  #section-{{ section.id }} .trust-badge--stacked {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  #section-{{ section.id }} .trust-badge--inline {
    flex-direction: row;
    align-items: flex-start;
    text-align: left;
  }

  {%- comment -%} Card styles {%- endcomment -%}
  {%- if card_style == 'bordered' -%}
  #section-{{ section.id }} .trust-badge {
    border: 1px solid {{ tc | color_modify: 'alpha', 0.15 }};
    border-radius: 10px;
    padding: 20px 16px;
  }
  {%- elsif card_style == 'card' -%}
  #section-{{ section.id }} .trust-badge {
    background: {{ tc | color_modify: 'alpha', 0.05 }};
    border-radius: 12px;
    padding: 24px 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  {%- else -%}
  #section-{{ section.id }} .trust-badge {
    padding: 8px 0;
  }
  {%- endif -%}

  #section-{{ section.id }} .trust-badge__icon {
    flex-shrink: 0;
    color: {{ ac }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #section-{{ section.id }} .trust-badge__icon svg,
  #section-{{ section.id }} .trust-badge__icon img {
    width: {{ icon_size }}px;
    height: {{ icon_size }}px;
    display: block;
  }
  #section-{{ section.id }} .trust-badge__title {
    font-size: var(--text-base);
    font-weight: 600;
    margin: 0 0 4px;
    color: {{ tc }};
    line-height: 1.3;
  }
  #section-{{ section.id }} .trust-badge__text {
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0;
    color: {{ tc }};
    opacity: 0.75;
  }

  {%- if section.settings.enable_animation -%}
  #section-{{ section.id }} [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  #section-{{ section.id }} [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  {%- endif -%}
{%- endstyle -%}

<section id="section-{{ section.id }}" class="trust-badges-section">
  <div class="{% if full_width %}container--full{% else %}container{% endif %}">
    {%- if section.settings.heading != blank -%}
      {%- assign h_level = section.settings.heading_level | default: 'h2' -%}
      {%- assign h_size = section.settings.heading_size | default: 'h3' -%}
      <{{ h_level }} class="trust-badges__heading heading--{{ h_size }} text-center"
         style="margin-bottom: 40px; color: {{ tc }};"
         {% if section.settings.enable_animation %}data-animate{% endif %}>
        {{ section.settings.heading | escape }}
      </{{ h_level }}>
    {%- endif -%}

    <div class="trust-badges__grid {{ col_class }}">
      {%- for block in section.blocks -%}
        {%- if forloop.index > 8 -%}{%- break -%}{%- endif -%}
        {%- assign delay_ms = forloop.index0 | times: 80 -%}
        <div class="trust-badge trust-badge--{{ badge_layout }}"
             style="{% if section.settings.enable_animation %}transition-delay: {{ delay_ms }}ms;{% endif %}"
             {{ block.shopify_attributes }}
             {% if section.settings.enable_animation %}data-animate{% endif %}>

          <div class="trust-badge__icon">
            {%- if block.settings.custom_icon != blank -%}
              <img src="{{ block.settings.custom_icon | image_url: width: 96 }}"
                   alt="{{ block.settings.custom_icon.alt | escape }}"
                   loading="lazy">
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'leaf' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-3.8 10-10 11z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {%- when 'check-circle' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {%- when 'award' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {%- when 'zap' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                {%- when 'flask' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v10l3.5 6.5A1 1 0 0 1 17.6 21H6.4a1 1 0 0 1-.9-1.5L9 13V3z"/><line x1="6" y1="8" x2="18" y2="8"/></svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- when 'lock' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </div>

          <div class="trust-badge__content">
            {%- if block.settings.title != blank -%}
              <p class="trust-badge__title">{{ block.settings.title | escape }}</p>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="trust-badge__text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if section.settings.enable_animation -%}
<script>
  (function() {
    var items = document.querySelectorAll('#section-{{ section.id }} [data-animate]');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(el) { observer.observe(el); });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level (SEO)",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h3",
      "options": [
        { "value": "h1", "label": "Extra large" },
        { "value": "h2", "label": "Large" },
        { "value": "h3", "label": "Medium" },
        { "value": "h4", "label": "Small" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns per row",
      "default": "3",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" },
        { "value": "6", "label": "6 columns" }
      ]
    },
    {
      "type": "select",
      "id": "badge_layout",
      "label": "Badge layout",
      "default": "stacked",
      "options": [
        { "value": "stacked", "label": "Stacked (icon above text)" },
        { "value": "inline", "label": "Inline (icon beside text)" }
      ]
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "default": "minimal",
      "options": [
        { "value": "minimal", "label": "Minimal (no border)" },
        { "value": "bordered", "label": "Bordered" },
        { "value": "card", "label": "Card (filled)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F2EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1C2E23"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Icon / accent color",
      "default": "#C4783A"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll animations",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "check-circle",
          "options": [
            { "value": "leaf", "label": "Leaf (Vegan)" },
            { "value": "shield", "label": "Shield (Protection)" },
            { "value": "check-circle", "label": "Check (Certified)" },
            { "value": "award", "label": "Award (Quality)" },
            { "value": "heart", "label": "Heart (Health)" },
            { "value": "zap", "label": "Zap (Effectiveness)" },
            { "value": "flask", "label": "Flask (Science)" },
            { "value": "star", "label": "Star (Rating)" },
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "lock", "label": "Lock (Security)" }
          ]
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon image (overrides selector above)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Third-Party Tested"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every batch independently verified for purity and potency."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "leaf",
            "title": "Vegan",
            "text": "HPMC veggie capsules. No gelatin, no animal products."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "award",
            "title": "cGMP Certified",
            "text": "Manufactured in a cGMP-certified facility."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "zap",
            "title": "MAKTREK Delivery",
            "text": "Acid-protection ensures bacteria arrive alive."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "check-circle",
            "title": "Third-Party Tested",
            "text": "Every batch independently verified for purity."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shield",
            "title": "No Gelatin",
            "text": "White HPMC capsules. Clean formula, no fillers."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "heart",
            "title": "NPN Registered",
            "text": "Registered with Health Canada for safety."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%}BaseCode Root - trust-badges{%- endcomment -%}
<section class="section" style="background-color: {{ section.settings.bg_color | default: '#F5F2EC' }};">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-center mb-12 reveal-hidden">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="trust-badges__grid">
      {%- for block in section.blocks -%}
        <div class="trust-badge reveal-hidden reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon">
            {%- case block.settings.icon -%}
              {%- when 'leaf' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-3.8 10-10 11z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
              {%- when 'shield' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'check-circle' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {%- when 'award' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
              {%- when 'heart' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- when 'zap' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {%- else -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {%- endcase -%}
          </div>
          <h3 class="trust-badge__title">{{ block.settings.title }}</h3>
          {%- if block.settings.text != blank -%}
            <p class="trust-badge__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F2EC"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "check-circle",
          "options": [
            {
              "value": "leaf",
              "label": "Leaf (Vegan)"
            },
            {
              "value": "shield",
              "label": "Shield (Protection)"
            },
            {
              "value": "check-circle",
              "label": "Check (Certified)"
            },
            {
              "value": "award",
              "label": "Award (Quality)"
            },
            {
              "value": "heart",
              "label": "Heart (Health)"
            },
            {
              "value": "zap",
              "label": "Zap (Effectiveness)"
            }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Third-Party Tested"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every batch independently verified for purity and potency."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "leaf",
            "title": "Vegan",
            "text": "HPMC veggie capsules. No gelatin, no animal products."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "award",
            "title": "cGMP Certified",
            "text": "Manufactured in a cGMP-certified facility."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "zap",
            "title": "MAKTREK Delivery",
            "text": "Acid-protection ensures bacteria arrive alive."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "check-circle",
            "title": "Third-Party Tested",
            "text": "Every batch independently verified for purity."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shield",
            "title": "No Gelatin",
            "text": "White HPMC capsules. Clean formula, no fillers."
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "heart",
            "title": "NPN Registered",
            "text": "Registered with Health Canada for safety."
          }
        }
      ]
    }
  ]
}
{% endschema %}

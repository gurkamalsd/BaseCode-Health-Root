{%- comment -%}BaseCode Root - blog-posts{%- endcomment -%}
<section class="section bg-white">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-center mb-10 reveal-hidden">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="grid grid-cols-1 gap-8" style="grid-template-columns: 1fr;">
      {%- if section.settings.blog != blank -%}
        {%- for article in blogs[section.settings.blog].articles limit: section.settings.limit -%}
          <article class="blog-card reveal-hidden reveal-delay-{{ forloop.index }}">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="blog-card__image">
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 767px) 100vw, 33vw"
                  alt="{{ article.image.alt | default: article.title }}"
                  loading="lazy"
                >
              </a>
            {%- endif -%}
            <p class="blog-card__date">{{ article.published_at | date: '%B %d, %Y' }}</p>
            <h3 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
            <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 160 }}</p>
            <a href="{{ article.url }}" class="link">{{ 'blog.read_more' | t }}</a>
          </article>
        {%- endfor -%}
      {%- else -%}
        <article class="blog-card">
          <div class="blog-card__image" style="background: var(--color-cream); display: flex; align-items: center; justify-content: center;">
            <span style="color: var(--color-text-light);">Blog Image</span>
          </div>
          <p class="blog-card__date">March 18, 2026</p>
          <h3 class="blog-card__title">The Biology Gap: Why Generic Supplements Fail</h3>
          <p class="blog-card__excerpt">Your biology is unique. Here's why that matters for your supplement choices.</p>
          <span class="link">Read More</span>
        </article>
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and section.settings.blog != blank -%}
      <div class="text-center mt-10">
        <a href="{{ blogs[section.settings.blog].url }}" class="btn btn--secondary">{{ 'blog.all_posts' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog Posts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Lab"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Posts to show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    }
  ],
  "presets": [{ "name": "Blog Posts" }]
}
{% endschema %}

{%- comment -%}BaseCode Root - featured-product{%- endcomment -%}
<section class="section" style="background-color: {{ section.settings.bg_color | default: '#C4783A' }}; color: {{ section.settings.text_color | default: '#FFFFFF' }};">
  <div class="container">
    <div class="grid gap-10 items-center" style="grid-template-columns: 1fr;">
      {%- assign featured = all_products[section.settings.product] -%}

      <div style="display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: center;">
        <!-- Product Image -->
        <div style="text-align: center;" class="reveal-left">
          {%- if featured.featured_image -%}
            <img
              src="{{ featured.featured_image | image_url: width: 600 }}"
              alt="{{ featured.title }}"
              width="400"
              height="400"
              loading="lazy"
              style="max-width: 400px; margin: 0 auto;"
            >
          {%- else -%}
            <div style="width: 300px; height: 400px; background: rgba(255,255,255,0.1); border-radius: var(--radius-lg); margin: 0 auto; display: flex; align-items: center; justify-content: center;">
              <span style="opacity: 0.5;">Product Image</span>
            </div>
          {%- endif -%}
        </div>

        <!-- Product Info -->
        <div class="reveal-right" style="text-align: center;">
          {%- if section.settings.subtitle != blank -%}
            <p style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8; margin-bottom: var(--space-2);">
              {{ section.settings.subtitle }}
            </p>
          {%- endif -%}

          <h2 style="font-size: var(--text-4xl); margin-bottom: var(--space-4);">
            {{ section.settings.heading | default: featured.title | default: 'Origin — The First Ethnobiotic' }}
          </h2>

          {%- if section.settings.text != blank -%}
            <p style="font-size: var(--text-lg); opacity: 0.9; margin-bottom: var(--space-6); max-width: 500px; margin-left: auto; margin-right: auto;">
              {{ section.settings.text }}
            </p>
          {%- endif -%}

          {%- if featured -%}
            <p style="font-family: var(--font-mono); font-size: var(--text-2xl); margin-bottom: var(--space-6);">
              {{ featured.price | money }}
              {%- if featured.selling_plan_groups.size > 0 -%}
                <span style="font-size: var(--text-sm);">{{ 'product.per_month' | t }}</span>
              {%- endif -%}
            </p>
          {%- endif -%}

          <a href="{{ featured.url | default: section.settings.button_link | default: '/products/origin' }}" class="btn btn--white btn--lg">
            {{ section.settings.button_text | default: 'Shop Now' }}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Biology-First Formula"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "40 billion CFU. 4 targeted strains. MAKTREK Bi-Pass delivery. FOS prebiotic. From $34/mo."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link (fallback)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#C4783A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Featured Product"
    }
  ]
}
{% endschema %}

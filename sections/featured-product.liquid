{%- comment -%}BaseCode Root - featured-product (Wonder-level customization){%- endcomment -%}
{%- liquid
  assign bg = section.settings.bg_color | default: '#C4783A'
  assign bg_opacity = section.settings.bg_opacity | default: 100
  assign text_col = section.settings.text_color | default: '#FFFFFF'
  assign pt = section.settings.padding_top | default: 60
  assign pb = section.settings.padding_bottom | default: 60
  assign layout = section.settings.layout | default: 'stacked'
  assign image_size = section.settings.image_size | default: 'medium'
  assign text_align = section.settings.text_align | default: 'center'
  assign heading_size = section.settings.heading_size | default: 'text-4xl'
  assign heading_level = section.settings.heading_level | default: 'h2'
  assign button_style = section.settings.button_style | default: 'white'
  assign show_price = section.settings.show_price
  assign show_subtitle = section.settings.show_subtitle
  assign full_width = section.settings.full_width
  assign enable_animation = section.settings.enable_animation
  assign featured = all_products[section.settings.product]
  assign image_max = '400px'
  if image_size == 'small'
    assign image_max = '280px'
  elsif image_size == 'large'
    assign image_max = '520px'
  endif
-%}

<section
  class="section"
  style="background:{{ bg }};{% if bg_opacity < 100 %}opacity:{{ bg_opacity | divided_by: 100.0 }};{% endif %}color:{{ text_col }};padding-top:{{ pt }}px;padding-bottom:{{ pb }}px;"
>
  <div class="{% if full_width %}container--wide{% else %}container{% endif %}">
    <div style="display:grid;{% if layout == 'side_by_side' %}grid-template-columns:1fr 1fr;gap:var(--space-12);align-items:center;{% elsif layout == 'side_by_side_reverse' %}grid-template-columns:1fr 1fr;gap:var(--space-12);align-items:center;{% else %}grid-template-columns:1fr;gap:var(--space-8);{% endif %}">

      {%- if layout == 'side_by_side_reverse' -%}
        <!-- Text First -->
        <div class="{% if enable_animation %}reveal-left{% endif %}" style="text-align:{{ text_align }};">
          {%- render 'featured-product-text', section: section, featured: featured, text_col: text_col, heading_size: heading_size, heading_level: heading_level, button_style: button_style, show_price: show_price, show_subtitle: show_subtitle -%}
        </div>
        <!-- Image -->
        <div style="text-align:center;" class="{% if enable_animation %}reveal-right{% endif %}">
          {%- render 'featured-product-image', section: section, featured: featured, image_max: image_max -%}
        </div>
      {%- elsif layout == 'side_by_side' -%}
        <!-- Image First -->
        <div style="text-align:center;" class="{% if enable_animation %}reveal-left{% endif %}">
          {%- render 'featured-product-image', section: section, featured: featured, image_max: image_max -%}
        </div>
        <!-- Text -->
        <div class="{% if enable_animation %}reveal-right{% endif %}" style="text-align:{{ text_align }};">
          {%- render 'featured-product-text', section: section, featured: featured, text_col: text_col, heading_size: heading_size, heading_level: heading_level, button_style: button_style, show_price: show_price, show_subtitle: show_subtitle -%}
        </div>
      {%- else -%}
        <!-- Stacked: Image then Text -->
        <div style="text-align:center;" class="{% if enable_animation %}reveal-left{% endif %}">
          {%- render 'featured-product-image', section: section, featured: featured, image_max: image_max -%}
        </div>
        <div class="{% if enable_animation %}reveal-right{% endif %}" style="text-align:{{ text_align }};">
          {%- render 'featured-product-text', section: section, featured: featured, text_col: text_col, heading_size: heading_size, heading_level: heading_level, button_style: button_style, show_price: show_price, show_subtitle: show_subtitle -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} [style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    { "type": "header", "content": "Product" },
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_subtitle", "label": "Show subtitle", "default": true },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Biology-First Formula" },
    { "type": "text", "id": "heading", "label": "Heading override" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size", "default": "text-4xl",
      "options": [
        { "value": "text-2xl", "label": "Small" },
        { "value": "text-3xl", "label": "Medium" },
        { "value": "text-4xl", "label": "Large" },
        { "value": "text-5xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select", "id": "heading_level", "label": "Heading tag (SEO)", "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ]
    },
    { "type": "textarea", "id": "text", "label": "Description", "default": "40 billion CFU. 4 targeted strains. MAKTREK Bi-Pass delivery. FOS prebiotic. From $34/mo." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button link (fallback)" },
    {
      "type": "select", "id": "button_style", "label": "Button style", "default": "white",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" }
      ]
    },
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "layout", "label": "Layout", "default": "stacked",
      "options": [
        { "value": "stacked", "label": "Stacked (centered)" },
        { "value": "side_by_side", "label": "Image left, text right" },
        { "value": "side_by_side_reverse", "label": "Text left, image right" }
      ]
    },
    {
      "type": "select", "id": "text_align", "label": "Text alignment", "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select", "id": "image_size", "label": "Image size", "default": "medium",
      "options": [
        { "value": "small", "label": "Small (280px)" },
        { "value": "medium", "label": "Medium (400px)" },
        { "value": "large", "label": "Large (520px)" }
      ]
    },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image override" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image override" },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": false },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#C4783A" },
    {
      "type": "range", "id": "bg_opacity", "label": "Background opacity", "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "default": 60, "unit": "px"
    },
    {
      "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "default": 60, "unit": "px"
    },
    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable scroll animation", "default": true }
  ],
  "presets": [{
    "name": "Featured Product"
  }]
}
{% endschema %}

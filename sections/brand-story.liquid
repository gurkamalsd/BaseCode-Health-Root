<section class="section" style="background-color: {{ section.settings.bg_color | default: '#F5F2EC' }};">
  <div class="container container--narrow text-center">
    {%- if section.settings.image != blank -%}
      <div style="width: 120px; height: 120px; margin: 0 auto var(--space-6); border-radius: var(--radius-full); overflow: hidden;" class="reveal-hidden">
        <img src="{{ section.settings.image | image_url: width: 240 }}" alt="" width="120" height="120" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
      </div>
    {%- endif -%}

    <h2 class="reveal-hidden" style="margin-bottom: var(--space-6);">{{ section.settings.heading | default: 'Empowering your health through biology.' }}</h2>

    {%- if section.settings.text != blank -%}
      <p style="font-size: var(--text-lg); color: var(--color-text-light); line-height: 1.7; margin-bottom: var(--space-8);" class="reveal-hidden">
        {{ section.settings.text }}
      </p>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <div class="reveal-hidden">
        <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--lg">{{ section.settings.button_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Small image (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your biology isn't one-size-fits-all."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "At BaseCode Health, we build supplements informed by biological diversity research. The supplement industry ignores the fact that everyone's biology is different. We don't. Origin is our first product — and it won't be the last."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/pages/about"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F2EC"
    }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}

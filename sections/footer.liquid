<footer style="background: #1C2E23;">
  <!-- Main footer content -->
  <div class="px-6 md:px-20 py-16">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 40px;">

      <!-- Top row: 3-4 columns on desktop -->
      <div style="display: grid; grid-template-columns: 1fr; gap: 40px;">
        {%- comment -%} Desktop: multi-column layout {%- endcomment -%}
        <div class="footer__columns">

          <!-- Brand column -->
          <div>
            <p class="font-mono-spec text-12 mb-2" style="color: #F5F2EC; letter-spacing: 0.18em;">BASECODE</p>
            <p class="font-heading text-13 font-light" style="color: rgba(245,242,236,0.40);">Supplements Built for Your Biology</p>
            <p class="font-mono-spec text-11 mt-2 mb-4" style="color: rgba(245,242,236,0.30);">Est. 2026</p>

            <div class="flex gap-4 mt-2">
              <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="font-mono-spec text-12 py-2 transition-colors" style="color: rgba(245,242,236,0.40);">Instagram</a>
              <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener noreferrer" class="font-mono-spec text-12 py-2 transition-colors" style="color: rgba(245,242,236,0.40);">X / Twitter</a>
            </div>
          </div>

          <!-- Navigation column -->
          <div class="flex flex-col">
            <p class="font-mono-spec text-11 uppercase mb-3" style="color: rgba(245,242,236,0.30); letter-spacing: 0.15em;">Navigate</p>
            <a href="/#protocol" class="font-heading text-13 font-light py-1 transition-colors" style="color: rgba(245,242,236,0.65);">Origin</a>
            <a href="/#science" class="font-heading text-13 font-light py-1 transition-colors" style="color: rgba(245,242,236,0.65);">Science</a>
            <a href="/#story" class="font-heading text-13 font-light py-1 transition-colors" style="color: rgba(245,242,236,0.65);">Story</a>
            <a href="/pages/free-report" class="font-heading text-13 font-light py-1 transition-colors" style="color: rgba(245,242,236,0.65);">Free Report</a>
            <a href="/pages/quiz" class="font-heading text-13 font-light py-1 transition-colors" style="color: rgba(245,242,236,0.65);">Biology Score Quiz</a>
            <a href="/products/origin" class="font-heading text-13 font-light py-1 transition-colors" style="color: rgba(245,242,236,0.65);">Buy Origin</a>
          </div>

          <!-- Support column -->
          <div>
            <p class="font-mono-spec text-11 uppercase mb-3" style="color: rgba(245,242,236,0.30); letter-spacing: 0.15em;">Support</p>
            <p class="font-heading text-13 font-light mb-2" style="color: rgba(245,242,236,0.50);">
              <a href="mailto:{{ section.settings.support_email | default: 'hello@basecodehealth.com' }}" class="hover-underline" style="color: rgba(245,242,236,0.65);">
                {{ section.settings.support_email | default: 'hello@basecodehealth.com' }}
              </a>
            </p>
            {%- if section.settings.support_hours != blank -%}
              <p class="font-heading text-13 font-light mb-2" style="color: rgba(245,242,236,0.40);">
                {{ section.settings.support_hours }}
              </p>
            {%- endif -%}
            {%- if section.settings.support_response_time != blank -%}
              <p class="font-mono-spec text-11" style="color: rgba(245,242,236,0.30);">
                {{ section.settings.support_response_time }}
              </p>
            {%- endif -%}
          </div>

          <!-- Legal column -->
          <div>
            <p class="font-mono-spec text-11 uppercase mb-3" style="color: rgba(245,242,236,0.30); letter-spacing: 0.15em;">Legal</p>
            <a href="/policies/privacy-policy" class="font-heading text-13 font-light py-1 block transition-colors hover-underline" style="color: rgba(245,242,236,0.65);">Privacy Policy</a>
            <a href="/policies/terms-of-service" class="font-heading text-13 font-light py-1 block transition-colors hover-underline" style="color: rgba(245,242,236,0.65);">Terms of Service</a>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar: copyright + address + payment icons -->
  <div style="border-top: 1px solid rgba(245,242,236,0.08); padding: 20px 24px;">
    <div class="footer__bottom-bar" style="max-width: 1200px; margin: 0 auto;">
      <div>
        <p class="font-mono-spec text-11" style="color: rgba(245,242,236,0.30);">
          &copy; {{ 'now' | date: '%Y' }} BaseCode Inc.
          {%- if section.settings.address_line != blank -%}
            &nbsp;&middot;&nbsp;{{ section.settings.address_line }}
          {%- endif -%}
        </p>
      </div>

      <!-- Payment icons -->
      <div class="footer__payment-icons" style="display: flex; align-items: center; gap: 8px;">
        <svg class="footer__payment-icon" width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="38" height="24" rx="4" fill="rgba(245,242,236,0.08)"/>
          <path d="M15.3 15.6l2.4-10.2h2.7l-2.4 10.2h-2.7zm11.1-10l-2.5 7-1.1-5.6c-.1-.6-.7-1-1.3-1h-4.1l-.1.3c.8.2 1.7.5 2.3.8l2 7.5h2.7l4.1-9h-2zm-18.6 0l-2.7 10.2h2.6l.4-1.8h3l.5 1.8h2.4L11.5 5.6h-3.7zm-.3 6.4l1.3-5.4 1.2 5.4h-2.5z" fill="rgba(245,242,236,0.50)"/>
        </svg>
        <svg class="footer__payment-icon" width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="38" height="24" rx="4" fill="rgba(245,242,236,0.08)"/>
          <circle cx="15" cy="12" r="7" fill="rgba(196,120,58,0.4)"/>
          <circle cx="23" cy="12" r="7" fill="rgba(196,120,58,0.3)"/>
        </svg>
        <svg class="footer__payment-icon" width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="38" height="24" rx="4" fill="rgba(245,242,236,0.08)"/>
          <text x="19" y="15" text-anchor="middle" fill="rgba(245,242,236,0.40)" font-size="8" font-family="JetBrains Mono, monospace">SHOP</text>
        </svg>
      </div>

      <p class="font-mono-spec text-10" style="color: rgba(245,242,236,0.25); line-height: 1.6; max-width: 400px;">
        *These statements have not been evaluated by the Food and Drug Administration or Health Canada. This product is not intended to diagnose, treat, cure, or prevent any disease.
      </p>
    </div>
  </div>
</footer>

<style>
  footer a:hover { color: #F5F2EC !important; }
  .hover-underline:hover { text-decoration: underline; }

  .footer__columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 768px) {
    .footer__columns {
      grid-template-columns: 1.4fr 1fr 1fr 0.8fr;
      gap: 40px;
    }
  }

  .footer__bottom-bar {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  @media (min-width: 768px) {
    .footer__bottom-bar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer__payment-icon {
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }
  .footer__payment-icon:hover {
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "hello@basecodehealth.com"
    },
    {
      "type": "text",
      "id": "support_hours",
      "label": "Support hours",
      "default": "Mon–Fri, 9am–5pm EST"
    },
    {
      "type": "text",
      "id": "support_response_time",
      "label": "Response time note",
      "default": "Typically replies within 24 hours"
    },
    {
      "type": "text",
      "id": "address_line",
      "label": "Address line (shown in copyright row)",
      "default": "Toronto, ON, Canada"
    }
  ]
}
{% endschema %}

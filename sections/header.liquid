{%- comment -%}BaseCode Root - header (Wonder-level customization){%- endcomment -%}

{%- liquid
  assign is_transparent = false
  if template == 'index' and section.settings.transparent_homepage
    assign is_transparent = true
  endif

  assign sticky = section.settings.sticky_header
  assign hide_on_scroll = section.settings.hide_on_scroll
  assign logo_position = section.settings.logo_position | default: 'left'
  assign show_search  = section.settings.show_search
  assign show_account = section.settings.show_account
  assign mobile_style = section.settings.mobile_menu_style
  assign bg_opacity   = section.settings.sticky_bg_opacity | times: 1.0 | divided_by: 100.0
  assign blur_val     = section.settings.background_blur
  assign logo_w_d     = section.settings.logo_width_desktop
  assign logo_w_m     = section.settings.logo_width_mobile
  assign transparent_color = section.settings.transparent_text_color
-%}

{%- style -%}
  .header {
    position: {{ sticky | default: true | replace: 'true', 'sticky' | replace: 'false', 'relative' }};
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }
  {%- unless sticky -%}
    .header { position: relative; }
  {%- endunless -%}
  {%- if section.settings.show_shadow -%}
    .header { box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
  {%- endif -%}
  {%- unless section.settings.show_separator -%}
    .header { border-bottom-color: transparent; }
  {%- endunless -%}

  /* Logo sizing */
  .header__logo-img { width: {{ logo_w_d }}px; height: auto; display: block; }
  @media (max-width: 767px) {
    .header__logo-img { width: {{ logo_w_m }}px; }
  }

  /* Transparent header state */
  .header--transparent {
    position: sticky;
    top: 0;
    background: transparent !important;
    border-bottom-color: transparent !important;
    box-shadow: none !important;
    color: {{ transparent_color }};
  }
  .header--transparent .header__nav-link,
  .header--transparent .header__icon,
  .header--transparent .header__logo-wordmark {
    color: {{ transparent_color }};
  }
  .header--transparent .header__nav-link::after {
    background: {{ transparent_color }};
  }
  .header--transparent .header__icon:hover {
    background-color: {{ transparent_color | color_modify: 'alpha', 0.12 }};
  }
  /* Use alternate logo when transparent if set */
  {%- if section.settings.transparent_logo != blank -%}
    .header--transparent .header__logo-default { display: none; }
    .header--transparent .header__logo-transparent { display: block; }
    .header--scrolled .header__logo-default { display: block; }
    .header--scrolled .header__logo-transparent { display: none !important; }
  {%- endif -%}
  .header__logo-transparent { display: none; }

  /* Scrolled / sticky state */
  .header--scrolled {
    background-color: rgba(255, 255, 255, {{ bg_opacity }}) !important;
    border-bottom-color: var(--color-border) !important;
    {%- if blur_val -%}
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
    {%- endif -%}
    {%- if section.settings.show_shadow -%}
      box-shadow: 0 2px 12px rgba(0,0,0,0.08) !important;
    {%- endif -%}
    color: var(--color-text);
  }
  .header--scrolled .header__nav-link,
  .header--scrolled .header__icon,
  .header--scrolled .header__logo-wordmark {
    color: var(--color-text);
  }
  .header--scrolled .header__nav-link::after {
    background: var(--color-accent);
  }
  .header--scrolled .header__icon:hover {
    background-color: var(--color-cream);
  }

  /* Predictive search */
  .header__search-form {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) var(--space-6);
    box-shadow: var(--shadow-md);
    display: none;
    z-index: var(--z-dropdown);
  }
  .header__search-form.is-open {
    display: block;
  }
  .header__search-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--text-base);
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s ease;
  }
  .header__search-input:focus {
    border-color: var(--color-accent);
  }

  /* Full-screen mobile menu variant */
  .mobile-menu--fullscreen .mobile-menu__panel {
    width: 100% !important;
    max-width: 100% !important;
    padding: var(--space-8) var(--space-6) !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }
  .mobile-menu--fullscreen .mobile-menu__link {
    font-size: var(--text-3xl) !important;
    font-weight: 700 !important;
    letter-spacing: -0.02em;
  }
{%- endstyle -%}

<header
  class="header {% if is_transparent %}header--transparent{% endif %} {% if sticky %}header--sticky{% endif %} {% if logo_position == 'center' %}header--center{% endif %}"
  id="site-header"
  role="banner"
  data-transparent="{{ is_transparent }}"
  data-sticky="{{ sticky }}"
  data-hide-on-scroll="{{ hide_on_scroll }}"
>
  <div class="header__inner{% if logo_position == 'center' %} header__inner--center{% endif %}">

    {%- if logo_position == 'center' -%}
      {%- comment -%} CENTER LAYOUT: [hamburger + nav-links] [logo] [icons] {%- endcomment -%}

      {%- comment -%} Left: hamburger + desktop nav links {%- endcomment -%}
      <div class="header__left">
        <button
          class="header__menu-toggle header__icon header__menu-toggle--always"
          id="menu-toggle"
          aria-label="{{ 'accessibility.menu_open' | t | default: 'Open menu' }}"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>

        <nav class="header__nav" role="navigation" aria-label="Main navigation">
          {%- for link in section.settings.menu.links -%}
            {%- if link.links.size > 0 -%}
              <div class="header__nav-dropdown" style="position: relative;">
                <button class="header__nav-link" style="display: flex; align-items: center; gap: 4px; background: none; border: none; cursor: pointer; padding: 0;" aria-expanded="false" aria-haspopup="true">
                  {{ link.title }}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0; transition: transform 0.2s ease;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div class="header__dropdown-menu" style="position: absolute; top: calc(100% + 8px); left: 50%; transform: translateX(-50%); min-width: 200px; background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-2) 0; box-shadow: 0 8px 30px rgba(0,0,0,0.10); display: none; z-index: var(--z-dropdown);">
                  {%- for child_link in link.links -%}
                    <a href="{{ child_link.url }}" class="header__nav-link" style="display: block; padding: var(--space-2) var(--space-5); font-size: var(--text-sm); white-space: nowrap;" {% if child_link.current %}aria-current="page"{% endif %}>{{ child_link.title }}</a>
                  {%- endfor -%}
                </div>
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="header__nav-link" {% if link.current %}aria-current="page"{% endif %}>{{ link.title }}</a>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      </div>

      {%- comment -%} Center: logo {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="header__logo-img header__logo-default" width="{{ logo_w_d }}" height="auto" loading="eager" fetchpriority="high">
          {%- if section.settings.transparent_logo != blank -%}
            <img src="{{ section.settings.transparent_logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="header__logo-img header__logo-transparent" width="{{ logo_w_d }}" height="auto" loading="eager">
          {%- endif -%}
        {%- else -%}
          <span class="header__logo-wordmark" style="font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Right: icons {%- endcomment -%}
      <div class="header__icons">
        {%- if show_search -%}
          <button class="header__icon" id="search-toggle" aria-label="{{ 'header.search' | t | default: 'Search' }}" aria-expanded="false" aria-controls="header-search-form">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        {%- endif -%}
        {%- if show_account -%}
          <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'header.account' | t | default: 'Account' }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}
        <button class="header__icon" id="cart-toggle" data-cart-toggle aria-label="{{ 'header.cart' | t | default: 'Cart' }} ({{ cart.item_count }})" style="position: relative;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span id="cart-count" class="header__cart-count" aria-live="polite" style="display: {% if cart.item_count > 0 %}flex{% else %}none{% endif %};">{{ cart.item_count }}</span>
        </button>
      </div>

    {%- else -%}
      {%- comment -%} LEFT LAYOUT: original [logo] [nav] [icons] {%- endcomment -%}

      <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="header__logo-img header__logo-default" width="{{ logo_w_d }}" height="auto" loading="eager" fetchpriority="high">
          {%- if section.settings.transparent_logo != blank -%}
            <img src="{{ section.settings.transparent_logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="header__logo-img header__logo-transparent" width="{{ logo_w_d }}" height="auto" loading="eager">
          {%- endif -%}
        {%- else -%}
          <span class="header__logo-wordmark" style="font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <nav class="header__nav" role="navigation" aria-label="Main navigation">
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="header__nav-dropdown" style="position: relative;">
              <button class="header__nav-link" style="display: flex; align-items: center; gap: 4px; background: none; border: none; cursor: pointer; padding: 0;" aria-expanded="false" aria-haspopup="true">
                {{ link.title }}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0; transition: transform 0.2s ease;"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
              <div class="header__dropdown-menu" style="position: absolute; top: calc(100% + 8px); left: 50%; transform: translateX(-50%); min-width: 200px; background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-2) 0; box-shadow: 0 8px 30px rgba(0,0,0,0.10); display: none; z-index: var(--z-dropdown);">
                {%- for child_link in link.links -%}
                  <a href="{{ child_link.url }}" class="header__nav-link" style="display: block; padding: var(--space-2) var(--space-5); font-size: var(--text-sm); white-space: nowrap;" {% if child_link.current %}aria-current="page"{% endif %}>{{ child_link.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header__nav-link" {% if link.current %}aria-current="page"{% endif %}>{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      <div class="header__icons">
        {%- if show_search -%}
          <button class="header__icon hide-mobile" id="search-toggle" aria-label="{{ 'header.search' | t | default: 'Search' }}" aria-expanded="false" aria-controls="header-search-form">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        {%- endif -%}
        {%- if show_account -%}
          <a href="{{ routes.account_url }}" class="header__icon hide-mobile" aria-label="{{ 'header.account' | t | default: 'Account' }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}
        <button class="header__icon" id="cart-toggle" data-cart-toggle aria-label="{{ 'header.cart' | t | default: 'Cart' }} ({{ cart.item_count }})" style="position: relative;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span id="cart-count" class="header__cart-count" aria-live="polite" style="display: {% if cart.item_count > 0 %}flex{% else %}none{% endif %};">{{ cart.item_count }}</span>
        </button>
        <button class="header__menu-toggle header__icon" id="menu-toggle" aria-label="{{ 'accessibility.menu_open' | t | default: 'Open menu' }}" aria-expanded="false" aria-controls="mobile-menu">
          <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Predictive search form {%- endcomment -%}
  {%- if show_search -%}
    <div class="header__search-form" id="header-search-form" role="search">
      <form action="{{ routes.search_url }}" method="get">
        <input
          type="search"
          name="q"
          class="header__search-input"
          placeholder="{{ section.settings.search_placeholder | default: 'Search products…' }}"
          aria-label="{{ section.settings.search_placeholder | default: 'Search products…' }}"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        >
      </form>
    </div>
  {%- endif -%}

</header>

{%- comment -%} Mobile menu {%- endcomment -%}
<div
  class="mobile-menu {% if mobile_style == 'fullscreen' %}mobile-menu--fullscreen{% endif %}"
  id="mobile-menu"
  role="dialog"
  aria-label="{{ 'accessibility.menu_title' | t | default: 'Mobile menu' }}"
  aria-hidden="true"
  aria-modal="true"
>
  <div class="mobile-menu__backdrop" id="mobile-menu-backdrop" aria-hidden="true"></div>
  <div class="mobile-menu__panel">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-8);">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}" style="text-decoration: none; color: inherit;" tabindex="-1">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="{{ logo_w_m }}" height="auto" style="width: {{ logo_w_m }}px; height: auto;">
        {%- else -%}
          <span style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <button class="header__icon" id="mobile-menu-close" data-menu-close aria-label="{{ 'accessibility.menu_close' | t | default: 'Close menu' }}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <nav aria-label="{{ 'accessibility.menu_title' | t | default: 'Mobile navigation' }}" style="width: 100%;">
      {%- for link in section.settings.menu.links -%}
        {%- if link.links.size > 0 -%}
          <button
            class="mobile-menu__link mobile-menu__parent-toggle"
            aria-expanded="false"
            style="display: flex; align-items: center; justify-content: space-between; width: 100%; background: none; border: none; cursor: pointer; text-align: left; padding: var(--space-3) 0; border-bottom: 1px solid var(--color-border);"
          >
            {{ link.title }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transition: transform 0.2s ease; flex-shrink: 0;"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="mobile-menu__children" style="display: none; padding-left: var(--space-4);">
            {%- for child_link in link.links -%}
              <a
                href="{{ child_link.url }}"
                class="mobile-menu__link"
                style="font-size: var(--text-base); padding: var(--space-2) 0; border-bottom: 1px solid var(--color-border); color: var(--color-text-light);"
                {% if child_link.current %}aria-current="page"{% endif %}
              >
                {{ child_link.title }}
              </a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <a
            href="{{ link.url }}"
            class="mobile-menu__link"
            style="display: block; padding: var(--space-3) 0; border-bottom: 1px solid var(--color-border);"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div style="margin-top: auto; padding-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-3);">
      {%- if show_account -%}
        <a href="{{ routes.account_url }}" class="mobile-menu__link" style="font-size: var(--text-base);">{{ 'header.account' | t | default: 'Account' }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- comment -%}
  All header JS (scroll, mobile menu, dropdowns, search) is in theme.js.
  No inline script needed — prevents duplicate handler conflicts.
{%- endcomment -%}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "label": "Logo width — desktop",
      "min": 60,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Logo width — mobile",
      "min": 40,
      "max": 160,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "options": [
        { "value": "left", "label": "Left (default)" },
        { "value": "center", "label": "Center (like Lana Banana)" }
      ],
      "default": "center",
      "info": "Center mode: hamburger + nav links left, logo centered, icons right."
    },
    {
      "type": "select",
      "id": "mobile_menu_style",
      "label": "Mobile menu style",
      "options": [
        { "value": "slide", "label": "Slide-in panel" },
        { "value": "fullscreen", "label": "Full-screen overlay" }
      ],
      "default": "slide"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder text",
      "default": "Search products…"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Sticky header"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_on_scroll",
      "label": "Hide header on scroll down",
      "default": true,
      "info": "Header hides when scrolling down, reveals on scroll up. Requires sticky header."
    },
    {
      "type": "range",
      "id": "sticky_bg_opacity",
      "label": "Sticky background opacity",
      "min": 80,
      "max": 100,
      "step": 1,

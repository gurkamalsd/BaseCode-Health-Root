{%- comment -%}BaseCode Root - newsletter{%- endcomment -%}
<section class="section" style="background-color: {{ section.settings.bg_color | default: '#1C2E23' }}; color: {{ section.settings.text_color | default: '#F5F2EC' }};">
  <div class="container container--narrow text-center">
    <h2 class="mb-4 reveal-hidden">{{ section.settings.heading | default: 'Stay in the loop' }}</h2>
    {%- if section.settings.text != blank -%}
      <p style="font-size: var(--text-lg); opacity: 0.8; margin-bottom: var(--space-8);" class="reveal-hidden">{{ section.settings.text }}</p>
    {%- endif -%}

    <form class="newsletter__form reveal-hidden" data-lead-form data-source="newsletter">
      <div style="position: absolute; left: -9999px;" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off">
      </div>
      <input type="text" name="firstName" class="newsletter__input" placeholder="{{ 'forms.name_placeholder' | t }}" style="flex: 0.6;">
      <input type="email" name="email" class="newsletter__input" placeholder="{{ 'forms.email_placeholder' | t }}" required>
      <button type="submit" class="btn btn--accent">{{ section.settings.button_text | default: 'Subscribe' }}</button>
    </form>

    <p style="font-size: var(--text-xs); opacity: 0.5; margin-top: var(--space-4);">{{ 'forms.no_spam' | t }}</p>

    <div data-form-success style="display: none; padding: var(--space-6) 0;">
      <p style="font-size: var(--text-lg); font-weight: 600;">{{ 'forms.success' | t }}</p>
      {%- if settings.discount_code != blank -%}
        <p style="margin-top: var(--space-2);">Use code <strong style="font-family: var(--font-mono);">{{ settings.discount_code }}</strong> for {{ settings.discount_description }}.</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the loop"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "Get research updates, product launches, and biology tips. No spam."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1C2E23"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F5F2EC"
    }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}

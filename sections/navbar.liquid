<nav
  class="navbar fixed left-0 w-full transition"
  style="top: 30px; z-index: 1000; background: rgba(28,46,35,0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.08); height: 64px;"
>
  <div class="flex items-center justify-between h-full px-6 md:px-20" style="max-width: 1600px; margin: 0 auto;">
    <!-- Logo -->
    <a href="/" class="font-heading font-semibold text-13 uppercase" style="color: #F5F2EC; letter-spacing: 0.18em;">
      BaseCode Health
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="/#science" class="font-heading text-14 font-normal transition-colors" style="color: rgba(245,242,236,0.65);">Science</a>
      <a href="/#aging" class="font-heading text-14 font-normal transition-colors" style="color: rgba(245,242,236,0.65);">Science</a>
      <a href="/#protocol" class="font-heading text-14 font-normal transition-colors" style="color: rgba(245,242,236,0.65);">Origin</a>
      <a href="/#story" class="font-heading text-14 font-normal transition-colors" style="color: rgba(245,242,236,0.65);">Story</a>
      <a href="/pages/free-report" class="font-heading text-14 font-normal transition-colors flex items-center gap-2" style="color: rgba(245,242,236,0.65);">
        Free Report
        <span class="font-mono-spec text-10 font-medium rounded-full" style="background: #C4783A; color: #1C2E23; padding: 3px 8px;">FREE</span>
      </a>
      <a href="/pages/quiz" class="font-heading text-14 font-normal transition-colors flex items-center gap-2" style="color: rgba(245,242,236,0.65);">
        Quiz
        <span class="font-mono-spec text-10 font-medium rounded-full" style="background: #C4783A; color: #1C2E23; padding: 3px 8px;">NEW</span>
      </a>
    </div>

    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="/products/origin"
        class="font-heading text-14 font-medium rounded-full transition-colors"
        style="background: #C4783A; color: #1C2E23; padding: 10px 24px;"
      >
        Shop Origin
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      class="navbar__mobile-toggle md:hidden"
      style="color: #F5F2EC; padding: 10px;"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-nav-menu"
    class="navbar__mobile-menu md:hidden px-6 pb-6"
    style="background: #1C2E23; display: none; max-height: calc(100vh - 94px); overflow-y: auto;"
    role="menu"
  >
    <a href="/#science" class="block py-3 font-heading text-16" style="color: rgba(245,242,236,0.75);">Science</a>
    <a href="/#aging" class="block py-3 font-heading text-16" style="color: rgba(245,242,236,0.75);">Science</a>
    <a href="/#protocol" class="block py-3 font-heading text-16" style="color: rgba(245,242,236,0.75);">Origin</a>
    <a href="/#story" class="block py-3 font-heading text-16" style="color: rgba(245,242,236,0.75);">Story</a>
    <a href="/pages/free-report" class="block py-3 font-heading text-16" style="color: rgba(245,242,236,0.75);">
      Free Report <span class="font-mono-spec text-11 font-medium rounded-full ml-2" style="background: #C4783A; color: #1C2E23; padding: 2px 6px;">FREE</span>
    </a>
    <a href="/pages/quiz" class="block py-3 font-heading text-16" style="color: rgba(245,242,236,0.75);">
      Quiz <span class="font-mono-spec text-11 font-medium rounded-full ml-2" style="background: #C4783A; color: #1C2E23; padding: 2px 6px;">NEW</span>
    </a>

    <div class="flex flex-col gap-3 mt-4">
      <a href="/pages/free-report" class="inline-block text-center font-heading text-14 font-medium rounded-full" style="border: 1px solid #C4783A; color: #C4783A; padding: 14px 24px;">
        Get Free Report
      </a>
      <a href="/products/origin" class="inline-block text-center font-heading text-14 font-medium rounded-full" style="background: #C4783A; color: #1C2E23; padding: 14px 24px;">
        Shop Origin
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar--scrolled {
    background: rgba(28,46,35,0.95) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .navbar__mobile-menu--open {
    display: block !important;
  }
  .navbar a:hover {
    color: #F5F2EC !important;
  }
</style>

{% schema %}
{
  "name": "Navigation",
  "class": "navbar-section",
  "settings": []
}
{% endschema %}

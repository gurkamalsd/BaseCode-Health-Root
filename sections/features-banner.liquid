{%- comment -%}BaseCode Root - features-banner{%- endcomment -%}

{%- liquid
  assign section_id = 'features-banner-' | append: section.id
  assign pt = section.settings.padding_top
  assign pb = section.settings.padding_bottom
  assign heading_size = section.settings.heading_size
  assign heading_level = section.settings.heading_level
  assign icon_color = section.settings.icon_color
  assign icon_size = section.settings.icon_size
  assign text_size = section.settings.text_size
  assign desktop_cols = section.settings.desktop_columns
  assign mobile_layout = section.settings.mobile_layout
  assign show_dividers = section.settings.show_dividers
  assign enable_animation = section.settings.enable_animation
  assign layout = section.settings.layout

  case text_size
    when 'small'
      assign text_size_val = '0.8rem'
    when 'large'
      assign text_size_val = '1rem'
    else
      assign text_size_val = '0.875rem'
  endcase
-%}

<section
  id="{{ section_id }}"
  class="features-banner{% if enable_animation %} features-banner--animate{% endif %}"
  style="
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  "
>
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <{{ heading_level }}
        class="features-banner__heading"
        style="font-size: {{ heading_size }}px;"
      >
        {{- section.settings.heading -}}
      </{{ heading_level }}>
    {%- endif -%}

    {%- comment -%}Mobile slider wrapper{%- endcomment -%}
    {%- if mobile_layout == 'slider' -%}
      <div class="features-banner__slider-wrap" data-slider>
        <div class="features-banner__track" data-track>
    {%- else -%}
      <div class="features-banner__grid features-banner__grid--{{ desktop_cols }}{% if show_dividers %} features-banner__grid--divided{% endif %}">
    {%- endif -%}

        {%- for block in section.blocks -%}
          <div
            class="features-banner__item features-banner__item--{{ layout }}{% if enable_animation %} features-banner__item--fade{% endif %}{% if show_dividers and mobile_layout != 'slider' %} features-banner__item--border{% endif %}"
            style="
              {%- if layout == 'stacked' -%}text-align: center;{%- endif -%}
            "
            {{ block.shopify_attributes }}
          >
            {%- comment -%}Icon{%- endcomment -%}
            {%- if block.settings.icon != 'none' or block.settings.icon_image != blank -%}
              <div
                class="features-banner__icon"
                style="
                  width: {{ icon_size }}px;
                  height: {{ icon_size }}px;
                  color: {{ icon_color }};
                  flex-shrink: 0;
                "
              >
                {%- if block.settings.icon_image != blank -%}
                  <img
                    src="{{ block.settings.icon_image | image_url: width: 96 }}"
                    alt=""
                    width="{{ icon_size }}"
                    height="{{ icon_size }}"
                    loading="lazy"
                    style="width: {{ icon_size }}px; height: {{ icon_size }}px; object-fit: contain;"
                  >
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'truck' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                      </svg>
                    {%- when 'shield' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      </svg>
                    {%- when 'refresh' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="23 4 23 10 17 10"></polyline>
                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                      </svg>
                    {%- when 'star' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                      </svg>
                    {%- when 'leaf' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-3.8 10-10 11z"></path>
                        <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
                      </svg>
                    {%- when 'lock' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                      </svg>
                    {%- when 'check' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    {%- when 'flask' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 3h6m-3 0v7l-5 9h12l-5-9V3"></path>
                      </svg>
                    {%- when 'heart' -%}
                      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                      </svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%}Text content{%- endcomment -%}
            <div class="features-banner__text-wrap">
              {%- if block.settings.text != blank -%}
                <span
                  class="features-banner__text"
                  style="font-size: {{ text_size_val }};"
                >
                  {{- block.settings.text -}}
                </span>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <span
                  class="features-banner__subtext"
                  style="font-size: calc({{ text_size_val }} * 0.875);"
                >
                  {{- block.settings.subtext -}}
                </span>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}

    {%- if mobile_layout == 'slider' -%}
        </div>{%- comment -%}/track{%- endcomment -%}
      </div>{%- comment -%}/slider-wrap{%- endcomment -%}
    {%- else -%}
      </div>{%- comment -%}/grid{%- endcomment -%}
    {%- endif -%}

  </div>
</section>

<style>
  #{{ section_id }} {
    --fb-icon-size: {{ icon_size }}px;
    --fb-icon-color: {{ icon_color }};
    --fb-text-size: {{ text_size_val }};
    --fb-cols-desktop: {{ desktop_cols }};
  }

  /* ── Section heading ─────────────────────────────────── */
  .features-banner__heading {
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    color: inherit;
  }

  /* ── Grid (desktop) ──────────────────────────────────── */
  .features-banner__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem 1.5rem;
    justify-items: start;
  }

  @media (min-width: 768px) {
    .features-banner__grid {
      grid-template-columns: repeat(var(--fb-cols-desktop), 1fr);
      gap: 1rem 2rem;
      justify-items: center;
    }
  }

  /* ── Divided grid ────────────────────────────────────── */
  .features-banner__grid--divided {
    gap: 0;
  }

  .features-banner__item--border {
    padding: 1rem 1.5rem;
    border-right: 1px solid rgba(0,0,0,0.1);
  }

  .features-banner__item--border:last-child {
    border-right: none;
  }

  @media (max-width: 767px) {
    .features-banner__item--border {
      border-right: none;
      border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    .features-banner__item--border:last-child {
      border-bottom: none;
    }
  }

  /* ── Item layout ─────────────────────────────────────── */
  .features-banner__item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .features-banner__item--stacked {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* ── Icon wrapper ────────────────────────────────────── */
  .features-banner__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── Text ────────────────────────────────────────────── */
  .features-banner__text-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .features-banner__text {
    font-family: var(--font-heading);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.3;
    color: inherit;
  }

  .features-banner__subtext {
    font-family: var(--font-body);
    font-weight: 400;
    color: inherit;
    opacity: 0.7;
    line-height: 1.4;
    text-transform: none;
    letter-spacing: 0;
  }

  /* ── Mobile slider ───────────────────────────────────── */
  .features-banner__slider-wrap {
    overflow: hidden;
    position: relative;
  }

  .features-banner__track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }

  .features-banner__track::-webkit-scrollbar {
    display: none;
  }

  .features-banner__track .features-banner__item {
    flex-shrink: 0;
    scroll-snap-align: start;
    min-width: 60vw;
  }

  @media (min-width: 768px) {
    .features-banner__slider-wrap {
      overflow: visible;
    }
    .features-banner__track {
      display: grid;
      grid-template-columns: repeat(var(--fb-cols-desktop), 1fr);
      overflow: visible;
      scroll-snap-type: none;
    }
    .features-banner__track .features-banner__item {
      min-width: unset;
      justify-content: center;
    }
  }

  /* ── Animation ───────────────────────────────────────── */
  .features-banner--animate .features-banner__item--fade {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .features-banner--animate .features-banner__item--fade.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

{%- if section.settings.enable_animation -%}
<script>
(function () {
  var items = document.querySelectorAll('#{{ section_id }} .features-banner__item--fade');
  if (!items.length) return;
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry, i) {
      if (entry.isIntersecting) {
        setTimeout(function () {
          entry.target.classList.add('is-visible');
        }, i * 80);
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  items.forEach(function (el) { io.observe(el); });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Features Banner",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Icon layout",
      "default": "inline",
      "options": [
        { "value": "inline", "label": "Icon + text inline" },
        { "value": "stacked", "label": "Icon above text" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Columns on desktop",
      "default": "4",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" },
        { "value": "6", "label": "6 columns" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "default": "grid",
      "info": "Slider scrolls horizontally on mobile. Grid wraps into 2 columns.",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Horizontal slider" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Show dividers between items",
      "default": false,
      "info": "Applies vertical borders between items on desktop."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F2EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1C2E23"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#C4783A"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level (SEO)",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Feature text size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll animation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "none", "label": "No icon" },
            { "value": "truck", "label": "Shipping truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "refresh", "label": "Returns / refresh" },
            { "value": "star", "label": "Star / quality" },
            { "value": "leaf", "label": "Leaf / natural" },
            { "value": "lock", "label": "Lock / secure" },
            { "value": "check", "label": "Checkmark" },
            { "value": "flask", "label": "Flask / science" },
            { "value": "heart", "label": "Heart / health" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom icon image",
          "info": "Overrides the icon selector above."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "info": "Optional smaller descriptor below main text."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Features Banner",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "text": "Free Shipping on Subscriptions" } },
        { "type": "feature", "settings": { "icon": "shield", "text": "30-Day Guarantee" } },
        { "type": "feature", "settings": { "icon": "leaf", "text": "Vegan & Clean Formula" } },
        { "type": "feature", "settings": { "icon": "lock", "text": "Secure Checkout" } }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%}BaseCode Root - features-banner{%- endcomment -%}
<section class="section--sm" style="background:{{ section.settings.bg_color | default: '#F5F2EC' }};">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-center mb-8" style="font-size:var(--text-2xl);">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:var(--space-8) var(--space-12);">
      {%- for block in section.blocks -%}
        <div style="display:flex;align-items:center;gap:var(--space-3);{% if section.settings.layout == 'stacked' %}flex-direction:column;text-align:center;{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div style="flex-shrink:0;width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
              {%- if block.settings.icon_image != blank -%}
                <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="" width="40" height="40" loading="lazy">
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                  {%- when 'shield' -%}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  {%- when 'refresh' -%}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                  {%- when 'star' -%}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  {%- when 'leaf' -%}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-3.8 10-10 11z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
                  {%- when 'lock' -%}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
          {%- endif -%}
          <span style="font-family:var(--font-heading);font-size:var(--text-sm);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5F2EC" },
    {
      "type": "select", "id": "layout", "label": "Icon layout", "default": "inline",
      "options": [
        { "value": "inline", "label": "Icon + text inline" },
        { "value": "stacked", "label": "Icon above text" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "truck",
          "options": [
            { "value": "truck", "label": "Shipping truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "refresh", "label": "Returns/refresh" },
            { "value": "star", "label": "Star/quality" },
            { "value": "leaf", "label": "Leaf/natural" },
            { "value": "lock", "label": "Lock/secure" }
          ]
        },
        { "type": "image_picker", "id": "icon_image", "label": "Custom icon image", "info": "Overrides the icon selector above" },
        { "type": "text", "id": "text", "label": "Text", "default": "Free Shipping" }
      ]
    }
  ],
  "presets": [{
    "name": "Features Banner",
    "blocks": [
      { "type": "feature", "settings": { "icon": "truck", "text": "Free Shipping on Subscriptions" } },
      { "type": "feature", "settings": { "icon": "shield", "text": "30-Day Guarantee" } },
      { "type": "feature", "settings": { "icon": "leaf", "text": "Vegan & Clean Formula" } },
      { "type": "feature", "settings": { "icon": "lock", "text": "Secure Checkout" } }
    ]
  }]
}
{% endschema %}

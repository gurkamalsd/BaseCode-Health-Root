{%- comment -%}BaseCode Root - rich-text{%- endcomment -%}
<section class="section" style="background-color: {{ section.settings.bg_color | default: '#FFFFFF' }};">
  <div class="container container--narrow">
    {%- if section.settings.heading != blank -%}
      <h2 class="{% if section.settings.center %}text-center{% endif %} mb-8">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="rte {% if section.settings.center %}text-center{% endif %}" style="font-size: var(--text-base); line-height: 1.8; color: var(--color-text-light);">
        {{ section.settings.text }}
      </div>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <div class="{% if section.settings.center %}text-center{% endif %} mt-8">
        <a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "center",
      "label": "Center text",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [{ "name": "Rich Text" }]
}
{% endschema %}

{%- comment -%}BaseCode Root - image-banner{%- endcomment -%}
<section class="image-banner" style="min-height: {{ section.settings.height | default: '400' }}px;">
  <div class="image-banner__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 960 }} 960w, {{ section.settings.image | image_url: width: 1440 }} 1440w, {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        loading="lazy"
        style="width: 100%; height: 100%; object-fit: cover;"
      >
    {%- else -%}
      <div style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--color-primary), var(--color-accent));"></div>
    {%- endif -%}
  </div>
  <div class="image-banner__overlay" style="background: {{ section.settings.overlay_color | default: 'linear-gradient(135deg, rgba(28, 46, 35, 0.6), rgba(196, 120, 58, 0.4))' }};"></div>
  <div class="image-banner__content reveal-hidden">
    {%- if section.settings.heading != blank -%}
      <h2 class="image-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--white btn--lg" style="margin-top: var(--space-6);">
        {{ section.settings.button_text }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Image Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your gut controls more than digestion."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": ""
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height (px)",
      "min": 200,
      "max": 600,
      "step": 50,
      "default": 400
    }
  ],
  "presets": [{ "name": "Image Banner" }]
}
{% endschema %}

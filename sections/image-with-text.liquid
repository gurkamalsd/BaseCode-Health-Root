{%- comment -%}BaseCode Root - image-with-text{%- endcomment -%}
<section class="section" style="background:{{ section.settings.bg_color | default: '#FFFFFF' }};">
  <div class="{% if section.settings.full_width %}container--wide{% else %}container{% endif %}">
    <div class="image-text {% if section.settings.layout == 'text_first' %}image-text--reverse{% endif %}">
      <!-- Image -->
      <div class="image-text__media reveal-{% if section.settings.layout == 'text_first' %}right{% else %}left{% endif %}"
        style="{% if section.settings.image_ratio != blank %}aspect-ratio:{{ section.settings.image_ratio }};{% endif %}">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 767px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            loading="lazy"
          >
        {%- else -%}
          <div style="width:100%;height:100%;min-height:400px;background:var(--color-cream);display:flex;align-items:center;justify-content:center;">
            <span style="color:var(--color-text-light);">Upload image</span>
          </div>
        {%- endif -%}
      </div>

      <!-- Text -->
      <div class="reveal-{% if section.settings.layout == 'text_first' %}left{% else %}right{% endif %}"
        style="display:flex;flex-direction:column;justify-content:{{ section.settings.vertical_align | default: 'center' }};padding:var(--space-6) 0;{% if section.settings.text_align %}text-align:{{ section.settings.text_align }};{% endif %}">

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'subheading' -%}
              <p style="font-family:var(--font-heading);font-size:var(--text-sm);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:{{ block.settings.color | default: 'var(--color-accent)' }};margin-bottom:var(--space-3);" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- when 'heading' -%}
              <h2 style="font-size:var(--text-3xl);margin-bottom:var(--space-4);" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </h2>
            {%- when 'text' -%}
              <div style="font-size:var(--text-base);color:var(--color-text-light);line-height:1.7;margin-bottom:var(--space-6);max-width:520px;" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- when 'button' -%}
              <div {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link | default: '#' }}" class="btn btn--{{ block.settings.style | default: 'primary' }}">
                  {{ block.settings.text | default: 'Learn More' }}
                </a>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    {
      "type": "image_picker", "id": "image", "label": "Image"
    },
    {
      "type": "select", "id": "layout", "label": "Layout", "default": "image_first",
      "options": [
        { "value": "image_first", "label": "Image first" },
        { "value": "text_first", "label": "Text first" }
      ]
    },
    {
      "type": "select", "id": "text_align", "label": "Text alignment", "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select", "id": "vertical_align", "label": "Vertical align", "default": "center",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ]
    },
    {
      "type": "select", "id": "image_ratio", "label": "Image ratio", "default": "4/5",
      "options": [
        { "value": "1/1", "label": "Square" },
        { "value": "4/5", "label": "Portrait" },
        { "value": "3/4", "label": "Tall portrait" },
        { "value": "16/9", "label": "Landscape" }
      ]
    },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": false }
  ],
  "blocks": [
    {
      "type": "subheading", "name": "Subheading",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Our Story" },
        { "type": "color", "id": "color", "label": "Color", "default": "#C4783A" }
      ]
    },
    {
      "type": "heading", "name": "Heading",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Built from biology outward." }
      ]
    },
    {
      "type": "text", "name": "Text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Our founder dreamed of creating supplements that actually account for biological diversity. The result is Origin.</p>" }
      ]
    },
    {
      "type": "button", "name": "Button",
      "settings": [
        { "type": "text", "id": "text", "label": "Label", "default": "Learn More" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select", "id": "style", "label": "Style", "default": "primary",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ]
        }
      ]
    }
  ],
  "presets": [{
    "name": "Image with Text",
    "blocks": [
      { "type": "subheading", "settings": { "text": "Meet the Founder" } },
      { "type": "heading", "settings": { "text": "Built from biology outward." } },
      { "type": "text", "settings": { "text": "<p>Gurkamal started BaseCode Health because the supplements he tried were never built for his biology. So he built one.</p>" } },
      { "type": "button", "settings": { "text": "Read Our Story" } }
    ]
  }]
}
{% endschema %}

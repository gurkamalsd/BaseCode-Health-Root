{%- comment -%}BaseCode Root - main-product{%- endcomment -%}
<section class="section bg-white">
  <div class="container">
    <div class="product-main">
      <!-- Product Gallery -->
      <div class="product-gallery">
        <div class="product-gallery__main" id="product-gallery-main">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 1200 }}"
              srcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 767px) 100vw, 50vw"
              alt="{{ product.featured_image.alt | default: product.title }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              loading="eager"
              id="product-main-image"
            >
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div style="display: flex; gap: var(--space-3); margin-top: var(--space-4); overflow-x: auto;">
            {%- for image in product.images -%}
              <button
                data-thumbnail="{{ forloop.index0 }}"
                data-image-src="{{ image | image_url: width: 1200 }}"
                style="flex: 0 0 80px; width: 80px; height: 80px; border-radius: var(--radius-md); overflow: hidden; border: 2px solid {% if forloop.first %}var(--color-primary){% else %}transparent{% endif %}; cursor: pointer; padding: 0; background: var(--color-cream);"
                aria-label="View image {{ forloop.index }}"
              >
                <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | default: product.title }}" width="80" height="80" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Product Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p style="font-size: var(--text-sm); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: var(--space-2); font-weight: 600;">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-info__title">{{ product.title }}</h1>

        <!-- Price -->
        <div class="product-info__price" id="product-price">
          {%- if product.compare_at_price > product.price -%}
            <del>{{ product.compare_at_price | money }}</del>
          {%- endif -%}
          <span id="product-price-value">{{ product.price | money }}</span>
          {%- if product.selling_plan_groups.size > 0 -%}
            <span style="font-size: var(--text-sm); color: var(--color-text-light);" id="product-price-suffix">{{ 'product.per_month' | t }}</span>
          {%- endif -%}
        </div>

        <!-- Star Rating placeholder -->
        <div style="display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-6);">
          <span style="color: #f59e0b; letter-spacing: 2px;">★★★★★</span>
          <span style="font-size: var(--text-sm); color: var(--color-text-light);">5.0</span>
        </div>

        <!-- Selling Plan Toggle (Subscribe / One-time) -->
        {%- if product.selling_plan_groups.size > 0 -%}
          <div class="selling-plan-toggle" id="selling-plan-toggle">
            <button type="button" class="selling-plan-toggle__option is-active" data-plan="subscribe">
              {{ 'product.subscribe_save' | t }}<br>
              <span style="font-family: var(--font-mono); font-weight: 700;" id="subscribe-price">
                {%- for group in product.selling_plan_groups -%}
                  {%- for plan in group.selling_plans -%}
                    {%- if forloop.first -%}
                      {{ product.selected_or_first_available_variant.price | minus: 600 | money }}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
              </span>
            </button>
            <button type="button" class="selling-plan-toggle__option" data-plan="one-time">
              {{ 'product.one_time' | t }}<br>
              <span style="font-family: var(--font-mono); font-weight: 700;">{{ product.price | money }}</span>
            </button>
          </div>
        {%- endif -%}

        <!-- Add to Cart Form -->
        <form id="product-form" action="/cart/add" method="post">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="product-variant-id">
          {%- if product.selling_plan_groups.size > 0 -%}
            <input type="hidden" name="selling_plan" value="{{ product.selling_plan_groups.first.selling_plans.first.id }}" id="product-selling-plan">
          {%- endif -%}
          <input type="hidden" name="quantity" value="1">

          <button
            type="submit"
            class="btn btn--primary btn--full btn--lg"
            style="margin-bottom: var(--space-4);"
            {% unless product.available %}disabled{% endunless %}
            id="add-to-cart-btn"
          >
            {%- if product.available -%}
              {{ 'product.add_to_cart' | t }}
            {%- else -%}
              {{ 'product.sold_out' | t }}
            {%- endif -%}
          </button>
        </form>

        <!-- Trust signals -->
        <div style="display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-8);">
          <div style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--color-text-light);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {{ 'product.free_shipping' | t }}
          </div>
          <div style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--color-text-light);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {{ 'product.money_back' | t }}
          </div>
          <div style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--color-text-light);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            {{ 'product.secure_checkout' | t }}
          </div>
        </div>

        <!-- Product Tabs -->
        <div class="product-tabs" id="product-tabs">
          <div class="product-tabs__nav">
            <button class="product-tabs__tab is-active" data-tab="description">{{ 'product.description' | t }}</button>
            <button class="product-tabs__tab" data-tab="ingredients">{{ 'product.ingredients' | t }}</button>
            <button class="product-tabs__tab" data-tab="shipping">{{ 'product.shipping' | t }}</button>
          </div>

          <div class="product-tabs__panel is-active" data-tab-panel="description">
            <div class="rte" style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text-light);">
              {{ product.description }}
            </div>
          </div>

          <div class="product-tabs__panel" data-tab-panel="ingredients">
            <div style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text-light);">
              {%- if product.metafields.custom.ingredients != blank -%}
                {{ product.metafields.custom.ingredients | metafield_tag }}
              {%- else -%}
                <p>L. acidophilus, B. lactis, L. plantarum, L. paracasei, MAKTREK Bi-Pass (marine polysaccharide), FOS (fructooligosaccharide), Hypromellose (HPMC capsule), Rice maltodextrin, L-Leucine.</p>
              {%- endif -%}
            </div>
          </div>

          <div class="product-tabs__panel" data-tab-panel="shipping">
            <div style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text-light);">
              <p><strong>Free shipping</strong> on all subscription orders.</p>
              <p>One-time orders ship for a flat rate of $5.99.</p>
              <p>Orders ship within 1-2 business days. Delivery typically takes 3-7 business days depending on your location.</p>
              <p><strong>30-day money-back guarantee.</strong> If Origin doesn't work for you, we'll refund your purchase. No questions asked.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Page",
  "tag": "section",
  "settings": []
}
{% endschema %}

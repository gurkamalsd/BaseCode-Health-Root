<section class="section bg-white">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-center mb-10 reveal-hidden">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="carousel">
      <div class="carousel__track" id="product-carousel-track">
        {%- if section.settings.collection != blank -%}
          {%- for product in collections[section.settings.collection].products limit: section.settings.limit -%}
            <div class="carousel__slide">
              {% render 'product-card', product: product, show_atc: true %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="carousel__slide">
              <div class="product-card">
                <div class="product-card__image-wrapper" style="background: var(--color-cream);">
                  <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                    <span style="color: var(--color-text-light); font-size: var(--text-sm);">Product {{ i }}</span>
                  </div>
                </div>
                <h3 class="product-card__title">Sample Product {{ i }}</h3>
                <div class="product-card__price">$29.99</div>
                <button class="btn btn--secondary btn--full btn--sm" disabled>Add to Cart</button>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="carousel__arrow carousel__arrow--prev" aria-label="{{ 'accessibility.previous_slide' | t }}" data-carousel-prev>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="carousel__arrow carousel__arrow--next" aria-label="{{ 'accessibility.next_slide' | t }}" data-carousel-next>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Supplements built for your biology"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Product Carousel"
    }
  ]
}
{% endschema %}

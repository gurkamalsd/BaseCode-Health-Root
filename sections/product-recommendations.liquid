{%- comment -%}BaseCode Root - product-recommendations (Wonder-level customization){%- endcomment -%}

{%- liquid
  assign bg           = section.settings.bg_color       | default: '#F5F2EC'
  assign text_col     = section.settings.text_color     | default: '#1C2E23'
  assign pt           = section.settings.padding_top    | default: 60
  assign pb           = section.settings.padding_bottom | default: 60
  assign heading_tag  = section.settings.heading_tag    | default: 'h2'
  assign heading_sz   = section.settings.heading_size   | default: 'medium'
  assign text_align   = section.settings.text_align     | default: 'center'
  assign max_products = section.settings.max_products   | default: 4
  assign per_desktop  = section.settings.per_desktop    | default: 4
  assign per_mobile   = section.settings.per_mobile     | default: 2
  assign full_width   = section.settings.full_width
  assign img_ratio    = section.settings.image_ratio    | default: 'adapt'
  assign show_hover   = section.settings.show_secondary_image
  assign show_vendor  = section.settings.show_vendor
  assign show_rating  = section.settings.show_rating
  assign show_quick   = section.settings.show_quick_add
  assign animate      = section.settings.enable_animation
  assign hide_mobile  = section.settings.disable_on_mobile

  comment
    Determine whether we are on a product page and have live recommendations.
    If not on a product page (or in the theme editor with no product context),
    fall back to the collection picker.
  endcomment
  assign use_recs     = false
  if product and recommendations.products_count > 0
    assign use_recs = true
  endif
  assign fallback_col = collections[section.settings.fallback_collection]
-%}

<style>
  #section-{{ section.id }} {
    background-color: {{ bg }};
    color: {{ text_col }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }

  /* ── Hide on mobile (Wonder feature) ─────────── */
  {%- if hide_mobile -%}
  @media (max-width: 767px) {
    #section-{{ section.id }} { display: none !important; }
  }
  {%- endif -%}

  /* ── Header ───────────────────────────────────── */
  #section-{{ section.id }} .pr__header {
    text-align: {{ text_align }};
    margin-bottom: 2.5rem;
  }

  #section-{{ section.id }} .pr__subheading {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent, #C4783A);
    margin-bottom: 0.625rem;
  }

  #section-{{ section.id }} .pr__heading {
    color: {{ text_col }};
    margin: 0;
    {% if heading_sz == 'small' %}
      font-size: clamp(1.1rem, 2vw, 1.5rem);
    {% elsif heading_sz == 'medium' %}
      font-size: clamp(1.5rem, 3vw, 2.25rem);
    {% elsif heading_sz == 'large' %}
      font-size: clamp(2rem, 4vw, 3rem);
    {% elsif heading_sz == 'xlarge' %}
      font-size: clamp(2.5rem, 5vw, 4rem);
    {% else %}
      font-size: clamp(1.5rem, 3vw, 2.25rem);
    {% endif %}
  }

  /* ── Grid ─────────────────────────────────────── */
  #section-{{ section.id }} .pr__grid {
    display: grid;
    grid-template-columns: repeat({{ per_desktop }}, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1023px) {
    #section-{{ section.id }} .pr__grid {
      grid-template-columns: repeat({{ per_desktop | at_most: 3 }}, 1fr);
    }
  }

  @media (max-width: 767px) {
    #section-{{ section.id }} .pr__grid {
      grid-template-columns: repeat({{ per_mobile }}, 1fr);
      gap: 1rem;
    }
  }

  /* ── Product card ─────────────────────────────── */
  #section-{{ section.id }} .pr__card {
    display: flex;
    flex-direction: column;
  }

  /* ── Image wrapper + ratio ────────────────────── */
  #section-{{ section.id }} .pr__card-image-wrapper {
    position: relative;
    overflow: hidden;
    background-color: var(--color-cream, #F5F2EC);
    border-radius: var(--radius-sm, 4px);
    margin-bottom: 0.875rem;
    {%- if img_ratio == 'portrait' -%}
      aspect-ratio: 3 / 4;
    {%- elsif img_ratio == 'square' -%}
      aspect-ratio: 1 / 1;
    {%- else -%}
      /* adapt: no forced ratio — image drives height */
    {%- endif -%}
  }

  #section-{{ section.id }} .pr__card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Hover secondary image ────────────────────── */
  {%- if show_hover -%}
  #section-{{ section.id }} .pr__card-image--secondary {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  #section-{{ section.id }} .pr__card-image-wrapper:hover .pr__card-image--secondary {
    opacity: 1;
  }
  #section-{{ section.id }} .pr__card-image-wrapper:hover .pr__card-image--primary {
    opacity: 0;
  }
  #section-{{ section.id }} .pr__card-image--primary {
    transition: opacity 0.35s ease;
  }
  {%- endif -%}

  /* ── Card text area ───────────────────────────── */
  #section-{{ section.id }} .pr__card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    text-align: {{ text_align }};
  }

  #section-{{ section.id }} .pr__card-vendor {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.55;
    margin-bottom: 0.25rem;
  }

  #section-{{ section.id }} .pr__card-title {
    font-family: var(--font-heading);
    font-size: var(--text-base, 1rem);
    font-weight: 600;
    line-height: 1.3;
    color: {{ text_col }};
    margin-bottom: 0.375rem;
    text-decoration: none;
  }

  #section-{{ section.id }} .pr__card-title:hover {
    text-decoration: underline;
  }

  /* ── Rating ───────────────────────────────────── */
  #section-{{ section.id }} .pr__card-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.78rem;
    color: var(--color-accent, #C4783A);
    margin-bottom: 0.375rem;
    {% if text_align == 'center' %}justify-content: center;{% endif %}
  }

  /* ── Price ────────────────────────────────────── */
  #section-{{ section.id }} .pr__card-price {
    font-size: var(--text-base, 1rem);
    font-weight: 600;
    color: {{ text_col }};
    margin-bottom: 0.75rem;
    margin-top: auto;
  }

  #section-{{ section.id }} .pr__card-price del {
    font-weight: 400;
    opacity: 0.5;
    margin-right: 0.375rem;
  }

  /* ── Quick add ────────────────────────────────── */
  #section-{{ section.id }} .pr__card-atc {
    margin-top: auto;
  }

  /* ── Animation ────────────────────────────────── */
  {%- if animate -%}
  #section-{{ section.id }} .animate-fade {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #section-{{ section.id }} .animate-fade.is-visible {
    opacity: 1;
    transform: none;
  }
  {%- endif -%}
</style>

<section
  id="section-{{ section.id }}"
  class="product-recommendations-section{% if full_width %} product-recommendations-section--full{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="product-recommendations"
>
  <div class="{% if full_width %}container--wide{% else %}container{% endif %}">

    {%- comment -%} ── Section header ──────────────────────────────── {%- endcomment -%}
    {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
      <div class="pr__header">
        {%- if section.settings.subheading != blank -%}
          <p class="pr__subheading{% if animate %} animate-fade{% endif %}">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }}
            class="pr__heading{% if animate %} animate-fade{% endif %}"
            {% if animate %}style="transition-delay:80ms;"{% endif %}
          >
            {{ section.settings.heading | escape }}
          </{{ heading_tag }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%}
      ── Product grid ──────────────────────────────────────────────────
      Priority order:
        1. Live API recommendations (product page context)
        2. Fallback collection picker (any other page or editor preview)
        3. Placeholder cards (editor only, no collection set)
    {%- endcomment -%}

    {%- if use_recs -%}
      {%- comment -%}
        Shopify Recommendations API — populated via JS fetch on product pages.
        The liquid below renders server-side when accessed via:
          GET /recommendations/products?section_id=SECTION_ID&product_id=PRODUCT_ID&limit=N
        On the page itself the div starts empty and is filled by the fetch script below.
      {%- endcomment -%}
      <div
        id="pr-grid-{{ section.id }}"
        class="pr__grid"
        data-recommendations-container
      >
        {%- for product in recommendations.products limit: max_products -%}
          {%- render 'pr-product-card',
            product: product,
            show_vendor: show_vendor,
            show_rating: show_rating,
            show_quick: show_quick,
            show_hover: show_hover,
            img_ratio: img_ratio,
            per_mobile: per_mobile,
            per_desktop: per_desktop,
            animate: animate,
            loop_index: forloop.index0,
            text_col: text_col,
            bg: bg
          -%}
        {%- endfor -%}
      </div>

    {%- elsif fallback_col != blank and fallback_col.products_count > 0 -%}
      {%- comment -%} Fallback: render products from the picker collection {%- endcomment -%}
      <div id="pr-grid-{{ section.id }}" class="pr__grid">
        {%- for product in fallback_col.products limit: max_products -%}

          <div class="pr__card{% if animate %} animate-fade{% endif %}"
            {% if animate %}style="transition-delay:{{ forloop.index0 | times: 60 }}ms;"{% endif %}>

            {%- comment -%} Image ─────────────────────────────────────── {%- endcomment -%}
            <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              <div class="pr__card-image-wrapper">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w"
                    sizes="(max-width:767px) {{ 100 | divided_by: per_mobile }}vw, {{ 100 | divided_by: per_desktop }}vw"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="300" height="300"
                    class="pr__card-image--primary"
                  >
                  {%- if show_hover and product.images.size > 1 -%}
                    <img
                      src="{{ product.images[1] | image_url: width: 600 }}"
                      srcset="{{ product.images[1] | image_url: width: 300 }} 300w, {{ product.images[1] | image_url: width: 600 }} 600w"
                      sizes="(max-width:767px) {{ 100 | divided_by: per_mobile }}vw, {{ 100 | divided_by: per_desktop }}vw"
                      alt="{{ product.images[1].alt | default: product.title | escape }}"
                      loading="lazy"
                      width="300" height="300"
                      class="pr__card-image--secondary"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div style="width:100%;{% if img_ratio == 'portrait' %}aspect-ratio:3/4;{% elsif img_ratio == 'square' %}aspect-ratio:1/1;{% else %}height:200px;{% endif %}background:var(--color-cream);display:flex;align-items:center;justify-content:center;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                  </div>
                {%- endif -%}
              </div>
            </a>

            {%- comment -%} Body ─────────────────────────────────────── {%- endcomment -%}
            <div class="pr__card-body">
              {%- if show_vendor -%}
                <p class="pr__card-vendor">{{ product.vendor | escape }}</p>
              {%- endif -%}

              <a href="{{ product.url }}" class="pr__card-title">{{ product.title }}</a>

              {%- if show_rating and product.metafields.reviews.rating.value != blank -%}
                <div class="pr__card-rating">
                  {% render 'star-rating', rating: product.metafields.reviews.rating.value %}
                  <span>({{ product.metafields.reviews.rating_count }})</span>
                </div>
              {%- endif -%}

              <div class="pr__card-price">
                {%- if product.compare_at_price > product.price -%}
                  <del>{{ product.compare_at_price | money }}</del>
                {%- endif -%}
                <span>{{ product.price | money }}</span>
              </div>

              {%- if show_quick and product.available -%}
                <div class="pr__card-atc">
                  <form action="/cart/add" method="post">
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="btn btn--primary btn--full btn--sm">
                      {{ 'product.add_to_cart' | t }}
                    </button>
                  </form>
                </div>
              {%- elsif show_quick -%}
                <div class="pr__card-atc">
                  <button class="btn btn--secondary btn--full btn--sm" disabled>{{ 'product.sold_out' | t }}</button>
                </div>
              {%- endif -%}
            </div>

          </div>

        {%- else -%}
          <p style="opacity:0.5;grid-column:1/-1;text-align:center;">No products found in the selected collection.</p>
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%} Editor placeholder — no collection selected yet {%- endcomment -%}
      <div class="pr__grid">
        {%- for i in (1..max_products) -%}
          <div class="pr__card">
            <div class="pr__card-image-wrapper" style="{% if img_ratio == 'portrait' %}aspect-ratio:3/4;{% elsif img_ratio == 'square' %}aspect-ratio:1/1;{% else %}height:240px;{% endif %}display:flex;align-items:center;justify-content:center;">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light,#ccc)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
            </div>
            <div class="pr__card-body">
              {%- if show_vendor -%}<p class="pr__card-vendor">BaseCode Health</p>{%- endif -%}
              <a class="pr__card-title" href="#">Sample Product {{ i }}</a>
              {%- if show_rating -%}
                <div class="pr__card-rating">★★★★★ <span>(12)</span></div>
              {%- endif -%}
              <div class="pr__card-price">$34.00</div>
              {%- if show_quick -%}
                <div class="pr__card-atc">
                  <button class="btn btn--primary btn--full btn--sm" disabled>Add to cart</button>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment -%}
  ── Recommendations API fetch ────────────────────────────────────────────
  On product pages only: fetch the recommendations HTML from Shopify's API
  and inject it into the empty container. The API returns this section's
  liquid rendered with `recommendations` context, so the grid populates
  without a page reload.
{%- endcomment -%}
{%- if product -%}
<script>
(function () {
  var sectionId  = '{{ section.id }}';
  var productId  = {{ product.id }};
  var limit      = {{ max_products }};
  var container  = document.getElementById('pr-grid-' + sectionId);

  if (!container) return;

  var url = window.Shopify
    ? window.location.origin + '/recommendations/products?section_id=' + sectionId + '&product_id=' + productId + '&limit=' + limit
    : null;

  if (!url) return;

  fetch(url)
    .then(function (r) { return r.text(); })
    .then(function (html) {
      var parser  = new DOMParser();
      var doc     = parser.parseFromString(html, 'text/html');
      var newGrid = doc.getElementById('pr-grid-' + sectionId);
      if (newGrid && newGrid.children.length > 0) {
        container.innerHTML = newGrid.innerHTML;
        {%- if animate -%}
        // Trigger animations on freshly injected cards
        var cards = container.querySelectorAll('.animate-fade');
        if (cards.length) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
            });
          }, { threshold: 0.1 });
          cards.forEach(function (el) { io.observe(el); });
        }
        {%- endif -%}
      }
    })
    .catch(function () {
      // Silent fail — fallback content already rendered server-side
    });
})();
</script>
{%- endif -%}

{%- if animate and product == blank -%}
{%- comment -%} Animate fallback/placeholder cards on non-product pages {%- endcomment -%}
<script>
(function () {
  var targets = document.querySelectorAll('#section-{{ section.id }} .animate-fade');
  if (!targets.length) return;
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  targets.forEach(function (el) { io.observe(el); });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "info": "Shown above the heading in accent color"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small",  "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large",  "label": "Large" },
        { "value": "xlarge", "label": "X-Large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading level (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Recommendations"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "info": "Applies to both API recommendations and fallback collection"
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback collection",
      "info": "Shown on non-product pages (homepage, collections, etc.) and in the theme editor. Also used if no API recommendations are returned."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "per_desktop",
      "label": "Columns — desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "per_mobile",
      "label": "Columns — mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false,
      "info": "Extends to wide container"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Product Cards"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt",   "label": "Adapt to image" },
        { "value": "portrait","label": "Portrait (3:4)" },
        { "value": "square",  "label": "Square (1:1)" }
      ],
      "default": "adapt"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": false,
      "info": "Swaps to the product's second image on mouse-over (desktop only)"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": false,
      "info": "Requires a reviews app that writes to product.metafields.reviews"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add button",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F2EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1C2E23"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Animation & Visibility"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll animations",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "disable_on_mobile",
      "label": "Hide on mobile",
      "default": false,
      "info": "Wonder feature — hides this section entirely on screens under 768px"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations",
      "settings": {
        "heading": "You May Also Like",
        "heading_size": "medium",
        "heading_tag": "h2",
        "max_products": 4,
        "per_desktop": 4,
        "per_mobile": 2,
        "full_width": false,
        "text_align": "center",
        "image_ratio": "adapt",
        "show_secondary_image": false,
        "show_vendor": false,
        "show_rating": false,
        "show_quick_add": true,
        "bg_color": "#F5F2EC",
        "text_color": "#1C2E23",
        "padding_top": 60,
        "padding_bottom": 60,
        "enable_animation": true,
        "disable_on_mobile": false
      }
    }
  ]
}
{% endschema %}

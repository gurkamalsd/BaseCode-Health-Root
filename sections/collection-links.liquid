{%- comment -%}BaseCode Root - collection-links{%- endcomment -%}
{%- liquid
  assign section_id  = 'collection-links-' | append: section.id
  assign pt          = section.settings.padding_top   | default: 60
  assign pb          = section.settings.padding_bottom | default: 60
  assign enable_anim = section.settings.enable_animation
  assign text_scale_raw = section.settings.text_scale | default: 20
  assign text_scale = text_scale_raw | divided_by: 10.0
  assign line_h_raw  = section.settings.line_height | default: 14
  assign line_h    = line_h_raw | divided_by: 10.0
  assign heading_lv  = section.settings.heading_level | default: 'h2'
-%}

<section
  id="{{ section_id }}"
  class="collection-links{% if enable_anim %} anim-enabled{% endif %}"
  style="
    background-color: {{ section.settings.bg_color | default: '#F5F2EC' }};
    color: {{ section.settings.text_color | default: '#1C2E23' }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
    position: relative;
  "
>
  <div class="container">

    {%- comment -%}---- Optional heading ----{%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      {%- assign hs = section.settings.heading_size | default: 'h2' -%}
      {%- case hs -%}
        {%- when 'h1' -%}{%- assign h_fs = 'var(--text-5xl, 3rem)' -%}
        {%- when 'h2' -%}{%- assign h_fs = 'var(--text-4xl, 2.25rem)' -%}
        {%- when 'h3' -%}{%- assign h_fs = 'var(--text-3xl, 1.875rem)' -%}
        {%- when 'h4' -%}{%- assign h_fs = 'var(--text-2xl, 1.5rem)' -%}
        {%- when 'h5' -%}{%- assign h_fs = 'var(--text-xl, 1.25rem)' -%}
        {%- when 'h6' -%}{%- assign h_fs = 'var(--text-lg, 1.125rem)' -%}
        {%- else -%}{%- assign h_fs = 'var(--text-4xl, 2.25rem)' -%}
      {%- endcase -%}
      <{{ heading_lv }}
        class="collection-links__section-heading{% if enable_anim %} anim-fade-up{% endif %}"
        style="font-size: {{ h_fs }}; line-height: 1.15; margin-bottom: var(--space-10, 2.5rem);"
      >
        {{ section.settings.heading }}
      </{{ heading_lv }}>
    {%- endif -%}

    {%- comment -%}---- Collection list ----{%- endcomment -%}
    <ul
      class="collection-links__list"
      role="list"
      style="
        list-style: none;
        margin: 0;
        padding: 0;
      "
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign col        = block.settings.collection
          assign col_title  = block.settings.custom_text | default: col.title
          assign col_url    = col.url | default: '#'
          assign col_img    = block.settings.custom_image | default: col.image
          assign item_color = block.settings.text_color | default: section.settings.text_color | default: '#1C2E23'
          assign img_pos    = block.settings.hover_image_position | default: 'right'
        -%}
        <li
          class="collection-links__item{% if enable_anim %} anim-fade-up{% endif %}"
          data-block-index="{{ forloop.index0 }}"
          style="
            --item-color: {{ item_color }};
            border-top: 1px solid currentColor;
            position: relative;
          "
          {{ block.shopify_attributes }}
        >
          <a
            href="{{ col_url }}"
            class="collection-links__item-link"
            data-hover-img="{{ col_img | image_url: width: 600 }}"
            data-img-pos="{{ img_pos }}"
            aria-label="{{ col_title }}"
            style="
              display: flex;
              align-items: center;
              justify-content: space-between;
              padding: var(--space-4, 1rem) 0;
              text-decoration: none;
              color: {{ item_color }};
              font-family: var(--font-heading);
              font-size: calc(1rem * {{ text_scale }});
              line-height: {{ line_h }};
              font-weight: 700;
              transition: opacity 0.2s ease;
              gap: var(--space-4, 1rem);
            "
          >
            <span class="collection-links__item-label">
              {{- col_title | default: 'Collection' -}}
            </span>
            <span class="collection-links__arrow" aria-hidden="true" style="flex-shrink: 0; opacity: 0.5; transition: transform 0.25s ease, opacity 0.25s ease;">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </li>
      {%- endfor -%}

      {%- comment -%} Bottom border for last item {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <li style="border-top: 1px solid currentColor;" aria-hidden="true"></li>
      {%- endif -%}
    </ul>

  </div>{%- comment -%}end .container{%- endcomment -%}

  {%- comment -%}---- Hover image container (absolutely positioned, JS-controlled) ----{%- endcomment -%}
  <div
    class="collection-links__hover-img"
    id="{{ section_id }}-hover-img"
    aria-hidden="true"
    style="
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      opacity: 0;
      transition: opacity 0.25s ease;
      border-radius: 4px;
      overflow: hidden;
      width: 260px;
      aspect-ratio: 3/4;
      box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    "
  >
    <img
      src=""
      alt=""
      id="{{ section_id }}-hover-img-el"
      style="width: 100%; height: 100%; object-fit: cover; display: block;"
      loading="lazy"
    >
  </div>

</section>

{%- comment -%}---- Section-scoped CSS ----{%- endcomment -%}
<style>
  #{{ section_id }} .collection-links__list {
    max-width: 100%;
  }

  #{{ section_id }} .collection-links__item-link:hover .collection-links__arrow {
    transform: translateX(6px);
    opacity: 1;
  }

  #{{ section_id }} .collection-links__item-link:hover {
    opacity: 0.7;
  }

  {%- if enable_anim -%}
  #{{ section_id }} .anim-fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #{{ section_id }}.in-view .anim-fade-up {
    opacity: 1;
    transform: none;
  }
  {%- for i in (1..10) -%}
  #{{ section_id }}.in-view .anim-fade-up:nth-child({{ i }}) {
    transition-delay: {{ i | minus: 1 | times: 0.07 }}s;
  }
  {%- endfor -%}
  {%- endif -%}

  @media (max-width: 767px) {
    #{{ section_id }} .collection-links__item-link {
      font-size: calc(1rem * {{ text_scale | times: 0.72 }}) !important;
    }
    /* On mobile, no hover image reveal */
    #{{ section_id }}-hover-img {
      display: none !important;
    }
  }
</style>

{%- comment -%}---- Hover image JS ----{%- endcomment -%}
<script>
(function () {
  'use strict';

  var section   = document.getElementById('{{ section_id }}');
  if (!section) return;

  var hoverBox  = document.getElementById('{{ section_id }}-hover-img');
  var hoverImg  = document.getElementById('{{ section_id }}-hover-img-el');
  if (!hoverBox || !hoverImg) return;

  var links = section.querySelectorAll('.collection-links__item-link');
  var mouseX = 0, mouseY = 0;
  var ticking = false;
  var currentSrc = '';

  function isMobile() {
    return window.innerWidth <= 767;
  }

  function positionBox(x, y, pos) {
    var boxW   = hoverBox.offsetWidth  || 260;
    var boxH   = hoverBox.offsetHeight || 346;
    var margin = 20;
    var vpW    = window.innerWidth;
    var vpH    = window.innerHeight;
    var left, top;

    if (pos === 'left') {
      left = x - boxW - margin;
      if (left < margin) left = x + margin;
    } else {
      left = x + margin;
      if (left + boxW > vpW - margin) left = x - boxW - margin;
    }

    top = y - boxH / 2;
    if (top < margin) top = margin;
    if (top + boxH > vpH - margin) top = vpH - boxH - margin;

    hoverBox.style.left = left + 'px';
    hoverBox.style.top  = top  + 'px';
  }

  links.forEach(function (link) {
    var imgSrc = link.getAttribute('data-hover-img');
    var imgPos = link.getAttribute('data-img-pos') || 'right';

    link.addEventListener('mouseenter', function () {
      if (isMobile() || !imgSrc || imgSrc === '') return;
      // Swap image src only if changed
      if (currentSrc !== imgSrc) {
        hoverImg.src = imgSrc;
        currentSrc = imgSrc;
      }
      positionBox(mouseX, mouseY, imgPos);
      hoverBox.style.opacity = '1';
    });

    link.addEventListener('mousemove', function (e) {
      if (isMobile()) return;
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (!ticking) {
        requestAnimationFrame(function () {
          positionBox(mouseX, mouseY, imgPos);
          ticking = false;
        });
        ticking = true;
      }
    });

    link.addEventListener('mouseleave', function () {
      hoverBox.style.opacity = '0';
    });
  });

  // Track mouse globally for initial position
  document.addEventListener('mousemove', function (e) {
    mouseX = e.clientX;
    mouseY = e.clientY;
  }, { passive: true });

  // Entrance animation
  {%- if enable_anim -%}
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.08 });
    obs.observe(section);
  } else {
    section.classList.add('in-view');
  }
  {%- endif -%}

})();
</script>

{% schema %}
{
  "name": "Collection Links",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to hide"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level (SEO)",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "Extra large (H1 size)" },
        { "value": "h2", "label": "Large (H2 size)" },
        { "value": "h3", "label": "Medium (H3 size)" },
        { "value": "h4", "label": "Small (H4 size)" },
        { "value": "h5", "label": "Extra small (H5 size)" },
        { "value": "h6", "label": "Tiny (H6 size)" }
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_scale",
      "label": "Text scale multiplier",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 20,
      "info": "Divide by 10 for actual multiplier — e.g. 20 = 2.0rem (32px)"
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 14,
      "info": "Divide by 10 for actual value — e.g. 14 = 1.4"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F5F2EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text color",
      "default": "#1C2E23"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll-in + hover image reveal",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "collection_link",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_text",
          "label": "Custom label",
          "info": "Overrides collection title"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom hover image",
          "info": "Overrides collection featured image"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color override",
          "info": "Leave blank to use section default"
        },
        {
          "type": "select",
          "id": "hover_image_position",
          "label": "Hover image side",
          "default": "right",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Links",
      "settings": {
        "heading": "Shop by Category",
        "heading_level": "h2",
        "heading_size": "h2",
        "text_scale": 20,
        "line_height": 14,
        "bg_color": "#F5F2EC",
        "text_color": "#1C2E23",
        "padding_top": 60,
        "padding_bottom": 60,
        "enable_animation": true
      },
      "blocks": [
        { "type": "collection_link", "settings": { "custom_text": "Gut Health", "hover_image_position": "right" } },
        { "type": "collection_link", "settings": { "custom_text": "Energy", "hover_image_position": "right" } },
        { "type": "collection_link", "settings": { "custom_text": "Sleep", "hover_image_position": "right" } }
      ]
    }
  ]
}
{% endschema %}

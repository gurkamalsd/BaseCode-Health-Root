<!-- Page Tracking + Sticky CTA Logic -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof trackEvent === 'function') {
      trackEvent('ViewContent', {
        content_name: '{{ symptom }}-landing-page',
        content_category: 'landing_page',
        content_type: '{{ symptom }}'
      });
    }

    // Sticky mobile CTA - show after scrolling past hero
    var stickyCta = document.getElementById('landing-sticky-cta');
    if (stickyCta) {
      var shown = false;
      window.addEventListener('scroll', function() {
        if (window.scrollY > window.innerHeight && !shown) {
          stickyCta.style.transform = 'translateY(0)';
          shown = true;
        } else if (window.scrollY <= window.innerHeight && shown) {
          stickyCta.style.transform = 'translateY(100%)';
          shown = false;
        }
      });
    }

    // Lead form submission
    var forms = document.querySelectorAll('[data-lead-form]');
    forms.forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var honeypot = form.querySelector('[name="website"]');
        if (honeypot && honeypot.value) return;
        var email = form.querySelector('[name="email"]').value;
        var firstName = form.querySelector('[name="firstName"]').value;
        var source = form.getAttribute('data-source') || 'landing';
        var errorEl = form.querySelector('.lead-form-error');
        var btn = form.querySelector('button[type="submit"]');

        if (!email || !email.includes('@')) {
          if (errorEl) errorEl.style.display = 'block';
          return;
        }
        if (errorEl) errorEl.style.display = 'none';
        if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }

        fetch('https://buxlhvxlffyaaojqaese.supabase.co/functions/v1/waitlist-signup', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ1eGxodnhsZmZ5YWFvanFhZXNlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI4MTIyMjgsImV4cCI6MjA4ODM4ODIyOH0.kFaL51umWL65Yc-hqd67Q7xzNdxuRvVzSeEuh9YzxSI'
          },
          body: JSON.stringify({ email: email, firstName: firstName, source: source })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var wrapper = form.closest('[data-lead-wrapper]');
          if (wrapper) {
            var formView = wrapper.querySelector('[data-lead-form-view]');
            var successView = wrapper.querySelector('[data-lead-success-view]');
            if (formView) formView.style.display = 'none';
            if (successView) successView.style.display = 'block';
            var successMsg = successView.querySelector('[data-success-msg]');
            if (data.duplicate && successMsg) successMsg.textContent = "You're already on the list!";
          }
          if (typeof trackEvent === 'function') {
            trackEvent('Lead', { content_name: source });
          }
        })
        .catch(function() {
          if (errorEl) { errorEl.style.display = 'block'; errorEl.textContent = 'Something went wrong. Please try again.'; }
          if (btn) { btn.textContent = btn.getAttribute('data-default-text') || 'Try Again'; btn.disabled = false; }
        });
      });
    });
  });
</script>


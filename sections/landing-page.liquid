{%- comment -%}BaseCode Root - landing-page{%- endcomment -%}
<!-- ═══════════════════════════════════════════════════
     Landing Page Section — Ultimate Conversion Template
     Hormozi-style dream outcome selling + Seed/Thorne aesthetic
     Structure: Urgency Bar → Social Proof Hero → Trust Strip →
     Agitate → Bridge → Ingredient Science → Dream Outcomes →
     Comparison → Reviews → Value Stack + CTA → Lead Capture →
     FAQ → Final CTA → Sticky Mobile CTA
     ═══════════════════════════════════════════════════ -->

{%- assign symptom = section.settings.symptom_slug | default: "gut-health" -%}

{%- comment -%} ── Color settings with RGB extraction ── {%- endcomment -%}
{%- assign primary_dark = section.settings.primary_dark | default: "#1C2E23" -%}
{%- assign accent       = section.settings.accent       | default: "#C4783A" -%}
{%- assign light_bg     = section.settings.light_bg     | default: "#F5F2EC" -%}
{%- assign card_bg      = section.settings.card_bg      | default: "#EDE8DF" -%}
{%- assign text_dark    = section.settings.text_dark    | default: "#1C2E23" -%}
{%- assign text_body    = section.settings.text_body    | default: "#4A5550" -%}
{%- assign text_muted   = section.settings.text_muted   | default: "#8A9490" -%}

{%- comment -%} Extract RGB channels for rgba() usage {%- endcomment -%}
{%- assign primary_dark_r = primary_dark | color_extract: 'red'   -%}
{%- assign primary_dark_g = primary_dark | color_extract: 'green' -%}
{%- assign primary_dark_b = primary_dark | color_extract: 'blue'  -%}

{%- assign accent_r = accent | color_extract: 'red'   -%}
{%- assign accent_g = accent | color_extract: 'green' -%}
{%- assign accent_b = accent | color_extract: 'blue'  -%}

{%- assign light_bg_r = light_bg | color_extract: 'red'   -%}
{%- assign light_bg_g = light_bg | color_extract: 'green' -%}
{%- assign light_bg_b = light_bg | color_extract: 'blue'  -%}

{%- comment -%} ── Product link resolution ── {%- endcomment -%}
{%- if section.settings.product != blank -%}
  {%- assign product_url = section.settings.product.url -%}
{%- elsif section.settings.product_link != blank -%}
  {%- assign product_url = section.settings.product_link -%}
{%- else -%}
  {%- assign product_url = "/products/origin" -%}
{%- endif -%}

{%- assign subscribe_price  = section.settings.subscribe_price  | default: "$34/mo" -%}
{%- assign onetime_price    = section.settings.onetime_price    | default: "$40" -%}
{%- assign discount_code    = section.settings.discount_code    | default: "FOUNDER20" -%}
{%- assign discount_percent = section.settings.discount_percent | default: "20%" -%}

{%- comment -%} ── Section visibility ── {%- endcomment -%}
{%- assign show_urgency_bar  = section.settings.show_urgency_bar  -%}
{%- assign show_trust_strip  = section.settings.show_trust_strip  -%}
{%- assign show_ingredients  = section.settings.show_ingredients  -%}
{%- assign show_comparison   = section.settings.show_comparison   -%}
{%- assign show_faq          = section.settings.show_faq          -%}
{%- assign show_lead_capture = section.settings.show_lead_capture -%}

{%- comment -%} ── Padding ── {%- endcomment -%}
{%- assign pt = section.settings.padding_top    | default: 0 -%}
{%- assign pb = section.settings.padding_bottom | default: 0 -%}

<div style="padding-top: {{ pt }}px; padding-bottom: {{ pb }}px;">

<!-- ═══ URGENCY BAR ═══ -->
{%- if show_urgency_bar -%}
<div style="background: {{ accent }}; padding: 10px 16px; text-align: center;">
  <p class="font-mono-spec text-11 font-medium" style="color: {{ primary_dark }}; letter-spacing: 0.08em;">
    🔥 {{ section.settings.urgency_text | default: "LAUNCH PRICING — " }}
    <strong>{{ subscribe_price }}</strong> (15% off) · Founding member rate ·
    <a href="{{ product_url }}" style="color: {{ primary_dark }}; text-decoration: underline;">Lock it in →</a>
  </p>
</div>
{%- endif -%}

<!-- ═══ HERO — Full-Bleed Background Image ═══ -->
{%- assign hero_img = 'landing-' | append: symptom | append: '-hero.webp' -%}
<section
  class="relative overflow-hidden"
  style="display: flex; align-items: center; min-height: 80vh; min-height: 80svh; padding-top: 60px;"
>
  <!-- Background Image -->
  <div class="absolute inset-0" style="background-image: url('{{ hero_img | asset_url }}'); background-size: cover; background-position: center right; background-repeat: no-repeat;"></div>
  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(13,31,22,0.92) 0%, rgba(13,31,22,0.85) 40%, rgba(13,31,22,0.5) 70%, rgba(13,31,22,0.3) 100%);"></div>
  <!-- Bottom fade -->
  <div class="absolute inset-0" style="background: linear-gradient(to top, #0d1f16, transparent 40%);"></div>

  <div class="relative px-6 md:px-20 py-10 md:py-16" style="z-index: 2; width: 100%; max-width: 1200px; margin: 0 auto;">
    <div style="max-width: 640px;">
        <!-- Live customer count -->
        <div class="flex items-center gap-2 mb-4 opacity-0 animate-fade-up delay-100">
          <span class="inline-block" style="width: 8px; height: 8px; border-radius: 50%; background: #22c55e; animation: pulse-dot 2s ease-in-out infinite;"></span>
          <span class="font-mono-spec text-11" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.5); letter-spacing: 0.05em;">2,847 people viewed this page today</span>
        </div>

        <!-- Star rating -->
        <div class="flex items-center gap-2 mb-5 opacity-0 animate-fade-up delay-100">
          <div class="flex gap-0.5">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="{{ accent }}" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          <span class="font-heading text-14 font-medium" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.7);">4.8 · 312 verified reviews</span>
        </div>

        <p class="font-mono-spec text-11 uppercase mb-4 opacity-0 animate-fade-up delay-100" style="color: rgba({{ accent_r }},{{ accent_g }},{{ accent_b }},0.80); letter-spacing: 0.25em;">
          {{ section.settings.eyebrow | default: "The Science Behind Your Symptoms" }}
        </p>

        <h1 class="font-heading text-24 md:text-36 lg:text-40 font-semibold mb-5 opacity-0 animate-fade-up delay-250" style="color: {{ light_bg }}; line-height: 1.1;">
          {{ section.settings.headline }}
        </h1>

        <p class="font-heading text-16 md:text-18 font-light mb-6 opacity-0 animate-fade-up delay-400" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.65); line-height: 1.7; max-width: 540px;">
          {{ section.settings.subheadline }}
        </p>

        <!-- Hero CTA -->
        <div class="flex flex-wrap items-center gap-4 mb-4 opacity-0 animate-fade-up delay-500">
          <a href="{{ product_url }}" class="btn btn--primary cta-pulse" onclick="if(typeof trackEvent==='function')trackEvent('ViewContent', {content_name: '{{ symptom }}-landing-cta'})">
            {{ section.settings.cta_text | default: "Try Origin — $34/mo" }}
          </a>
          <a href="/pages/quiz" class="font-heading text-14 font-light transition" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.8);">Take the Free Quiz →</a>
        </div>

        <!-- Sub-CTA trust line -->
        <div class="flex flex-wrap items-center gap-4 opacity-0 animate-fade-up delay-550">
          <span class="flex items-center gap-1 font-mono-spec text-10" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.45);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="{{ accent }}" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            30-Day Money Back
          </span>
          <span class="flex items-center gap-1 font-mono-spec text-10" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.45);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="{{ accent }}" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Free Shipping
          </span>
          <span class="flex items-center gap-1 font-mono-spec text-10" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.45);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="{{ accent }}" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Cancel Anytime
          </span>
        </div>
      </div>

      <!-- Featured Review (floating card) -->
      {%- for block in section.blocks -%}
        {%- if block.type == "review" and forloop.first -%}
          <div class="mt-6 opacity-0 animate-fade-up delay-550 rounded-xl p-4" style="max-width: 480px; background: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.08); border: 1px solid rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.10); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
            <div class="flex items-start gap-3">
              <div class="flex items-center justify-center flex-shrink-0" style="width: 36px; height: 36px; border-radius: 50%; background: {{ accent }}; color: {{ primary_dark }}; font-size: 14px; font-weight: 600;">
                {{ block.settings.name | slice: 0 }}
              </div>
              <div style="flex: 1; min-width: 0;">
                <div class="flex items-center gap-2 mb-1">
                  <div class="flex gap-0.5">
                    {%- for i in (1..5) -%}
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="{{ accent }}" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {%- endfor -%}
                  </div>
                  <span class="font-mono-spec text-10" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.4);">Verified ✓</span>
                </div>
                <p class="font-heading text-13 font-light mb-1" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.85); line-height: 1.5;">
                  &ldquo;{{ block.settings.quote | truncate: 120 }}&rdquo;
                </p>
                <p class="font-heading text-11 font-medium" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.55);">— {{ block.settings.name }}</p>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

<!-- ═══ TRUST STRIP ═══ -->
{%- if show_trust_strip -%}
<div class="py-4 px-6" style="background: {{ light_bg }}; border-bottom: 1px solid rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.08);">
  <div class="flex flex-wrap justify-center gap-6 md:gap-10" style="max-width: 900px; margin: 0 auto;">
    <span class="flex items-center gap-2 font-mono-spec text-11" style="color: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.55); letter-spacing: 0.05em;">
      <span style="font-size: 14px;">🇺🇸</span> Made in USA · cGMP
    </span>
    <span class="flex items-center gap-2 font-mono-spec text-11" style="color: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.55); letter-spacing: 0.05em;">
      <span style="font-size: 14px;">🔬</span> HELIUS Study-Backed
    </span>
    <span class="flex items-center gap-2 font-mono-spec text-11" style="color: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.55); letter-spacing: 0.05em;">
      <span style="font-size: 14px;">🛡</span> 30-Day Money-Back
    </span>
    <span class="flex items-center gap-2 font-mono-spec text-11" style="color: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.55); letter-spacing: 0.05em;">
      <span style="font-size: 14px;">🌱</span> Vegan · Non-GMO
    </span>
    <span class="flex items-center gap-2 font-mono-spec text-11" style="color: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.55); letter-spacing: 0.05em;">
      <span style="font-size: 14px;">⚡</span> 40 Billion CFU
    </span>
  </div>
</div>
{%- endif -%}

<!-- ═══ QUICK STAT CALLOUT ═══ -->
<section class="py-10 px-6" style="background: {{ light_bg }};">
  <div style="max-width: 900px; margin: 0 auto;">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 text-center reveal-hidden stagger-children">
      <div class="p-5 rounded-xl" style="background: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.03); border: 1px solid rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.06);">
        <p class="font-heading text-32 font-semibold" style="color: {{ accent }};">2,084</p>
        <p class="font-mono-spec text-10 uppercase" style="color: {{ text_body }}; letter-spacing: 0.1em;">Subjects in HELIUS study</p>
      </div>
      <div class="p-5 rounded-xl" style="background: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.03); border: 1px solid rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.06);">
        <p class="font-heading text-32 font-semibold" style="color: {{ accent }};">40B</p>
        <p class="font-mono-spec text-10 uppercase" style="color: {{ text_body }}; letter-spacing: 0.1em;">CFU per serving</p>
      </div>
      <div class="p-5 rounded-xl" style="background: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.03); border: 1px solid rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.06);">
        <p class="font-heading text-28 font-semibold" style="color: {{ accent }};">MAKTREK</p>
        <p class="font-mono-spec text-10 uppercase" style="color: {{ text_body }}; letter-spacing: 0.1em;">Acid-protected delivery</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ AGITATE — The Cost of Inaction ═══ -->
<section class="py-16 md:py-24 px-6 md:px-20" style="background: {{ light_bg }};">
  <div style="max-width: 800px; margin: 0 auto;">
    <div class="text-center mb-10 reveal-hidden">
      <p class="font-mono-spec text-11 uppercase mb-4" style="color: {{ accent }}; letter-spacing: 0.2em;">
        {{ section.settings.agitate_eyebrow | default: "What's Really Going On" }}
      </p>
      <h2 class="font-heading text-24 md:text-36 font-medium mb-5" style="color: {{ primary_dark }}; line-height: 1.15;">
        {{ section.settings.agitate_headline }}
      </h2>
    </div>

    <div class="space-y-5 reveal-hidden">
      {%- assign agitate_points = section.settings.agitate_body | split: "||" -%}
      {%- for point in agitate_points -%}
        <div class="flex gap-4 items-start p-5 rounded-xl" style="background: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.03); border: 1px solid rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.06);">
          <span class="flex-shrink-0 mt-0.5" style="color: {{ accent }};">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </span>
          <p class="font-heading text-15 font-light" style="color: {{ text_body }}; line-height: 1.75;">{{ point }}</p>
        </div>
      {%- endfor -%}
    </div>

    <!-- Cost Box -->
    <div class="mt-10 rounded-2xl p-6 md:p-8 reveal-hidden" style="background: {{ primary_dark }};">
      <p class="font-mono-spec text-10 uppercase mb-3" style="color: {{ accent }}; letter-spacing: 0.15em;">The Real Cost</p>
      <p class="font-heading text-18 md:text-22 font-medium mb-3" style="color: {{ light_bg }}; line-height: 1.3;">
        {{ section.settings.cost_headline }}
      </p>
      <p class="font-heading text-14 font-light" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.60); line-height: 1.7;">
        {{ section.settings.cost_body }}
      </p>
    </div>

    <!-- Mid-page CTA -->
    <div class="text-center mt-10 reveal-hidden">
      <a href="{{ product_url }}" class="btn btn--primary inline-block" onclick="if(typeof trackEvent==='function')trackEvent('ViewContent', {content_name: '{{ symptom }}-agitate-cta'})">
        {{ section.settings.cta_text | default: "Try Origin — $34/mo" }}
      </a>
      <p class="font-mono-spec text-11 mt-3" style="color: rgba({{ primary_dark_r }},{{ primary_dark_g }},{{ primary_dark_b }},0.4);">Risk-free · 30-day money-back guarantee</p>
    </div>
  </div>
</section>

<!-- ═══ BRIDGE — The Science Connection ═══ -->
<section class="relative py-16 md:py-24 px-6 md:px-20" style="background: {{ primary_dark }}; border-radius: 32px 32px 0 0; margin-top: -16px;">
  <div style="max-width: 1000px; margin: 0 auto;">
    <div class="text-center mb-12 reveal-hidden">
      <p class="font-mono-spec text-11 uppercase mb-4" style="color: {{ accent }}; letter-spacing: 0.2em;">
        The Connection Most Doctors Miss
      </p>
      <h2 class="font-heading text-24 md:text-36 font-medium mb-5" style="color: {{ light_bg }}; line-height: 1.1;">
        {{ section.settings.bridge_headline }}
      </h2>
      <p class="font-heading text-16 font-light mx-auto" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.55); max-width: 620px; line-height: 1.7;">
        {{ section.settings.bridge_body }}
      </p>
    </div>

    <!-- Pathway Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10 stagger-children">
      {%- for block in section.blocks -%}
        {%- if block.type == "pathway" -%}
          <div class="rounded-2xl p-6 reveal-hidden" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
            <div class="flex items-center justify-center mb-4" style="width: 40px; height: 40px; border-radius: 50%; background: rgba({{ accent_r }},{{ accent_g }},{{ accent_b }},0.15);">
              <span class="font-heading text-16 font-semibold" style="color: {{ accent }};">{{ forloop.index }}</span>
            </div>
            <p class="font-mono-spec text-10 uppercase mb-2" style="color: rgba({{ accent_r }},{{ accent_g }},{{ accent_b }},0.7); letter-spacing: 0.12em;">{{ block.settings.step }}</p>
            <h3 class="font-heading text-17 font-medium mb-2" style="color: {{ light_bg }};">{{ block.settings.title }}</h3>
            <p class="font-heading text-13 font-light" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.55); line-height: 1.7;">{{ block.settings.body }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Mechanism Infographic -->
    {%- assign mech_img = 'landing-' | append: symptom | append: '-mechanism.png' -%}
    <div class="mt-10 rounded-2xl overflow-hidden reveal-hidden" style="border: 1px solid rgba(255,255,255,0.08);">
      <img src="{{ mech_img | asset_url }}" alt="How Origin addresses {{ symptom | replace: '-', ' ' }}" loading="lazy" style="width: 100%; height: auto; display: block;">
    </div>

    <!-- Citation -->
    {%- if section.settings.citation -%}
      <div class="text-center reveal-hidden p-4 rounded-xl mt-6" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
        <p class="font-mono-spec text-10" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.35);">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba({{ accent_r }},{{ accent_g }},{{ accent_b }},0.5)" stroke-width="2" style="display: inline; vertical-align: middle; margin-right: 4px;"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          {{ section.settings.citation }}
        </p>
      </div>
    {%- endif -%}

    <!-- Mid-section CTA -->
    <div class="text-center mt-10 reveal-hidden">
      <a href="{{ product_url }}" class="btn btn--primary inline-block">
        {{ section.settings.cta_text | default: "Try Origin — $34/mo" }}
      </a>
    </div>
  </div>
</section>

<!-- ═══ INGREDIENT SCIENCE — How Each Strain Helps ═══ -->
{%- if show_ingredients -%}
<section class="py-16 md:py-24 px-6 md:px-20" style="background: {{ primary_dark }};">
  <div style="max-width: 1000px; margin: 0 auto;">
    <div class="text-center mb-12 reveal-hidden">
      <p class="font-mono-spec text-11 uppercase mb-4" style="color: {{ accent }}; letter-spacing: 0.2em;">The Formula</p>
      <h2 class="font-heading text-24 md:text-36 font-medium mb-4" style="color: {{ light_bg }}; line-height: 1.1;">
        {{ section.settings.solution_headline }}
      </h2>
      <p class="font-heading text-16 font-light mx-auto" style="color: rgba({{ light_bg_r }},{{ light_bg_g }},{{ light_bg_b }},0.55); max-width: 600px; line-height: 1.7;">
        {{ section.settings.solution_body }}
      </p>
    </div>

    <!-- Ingredient blocks (schema-driven) or fallback to hardcoded strains -->
    {%- assign has_ingredient_blocks = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == "ingredient" -%}
        {%- assign has_ingredient_blocks = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10 stagger-children">
      {%- if has_ingredient_blocks -%}
        {%- assign ing_icons = "🔒|🛡|🔥|🧠|⚗️|🌿" | split: "|" -%}
        {%- assign ing_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == "ingredient" -%}
            <div class="rounded-2xl p-6 reveal-hidden" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <div class="flex items-start gap-4">
                <div class="flex items-center justify-center flex-shrink-0" style="width: 44px; height: 44px; border-radius: 12px; background: rgba({{ accent_r }},{{ accent_g }},{{ accent_b }},0.12);">
                  <span style="font-size: 20px;">{{ ing_icons[ing_index] }}</span>
                </div>
                <div>

<section
  class="relative overflow-hidden noise-overlay"
  style="min-height: 100svh; display: flex; align-items: flex-end; background: linear-gradient(135deg, #0d1f16 0%, #1C2E23 45%, #243b2c 75%, #1a3328 100%);"
  aria-label="Hero"
>
  {%- if section.settings.hero_image != blank -%}
    <img src="{{ section.settings.hero_image | image_url: width: 1600 }}" alt="" width="1584" height="672" fetchpriority="high" class="absolute inset-0 w-full h-full" style="object-fit: cover; opacity: 0.4;">
  {%- else -%}
    <img src="{{ 'basecode-hero-bg-new.webp' | asset_url }}" alt="" width="1584" height="672" fetchpriority="high" class="absolute inset-0 w-full h-full" style="object-fit: cover; opacity: 0.4;">
  {%- endif -%}
  <div class="absolute inset-0" style="background: linear-gradient(to top, #0d1f16, rgba(13,31,22,0.6), transparent);"></div>

  <div class="relative px-6 md:px-20 flex flex-col md:flex-row md:items-center md:gap-12 lg:gap-20" style="z-index: 2; width: 100%; max-width: 1280px; margin: 0 auto; padding-top: 112px; padding-bottom: 32px;">
    <!-- Left content -->
    <div class="flex-1" style="max-width: 700px;">
      <p class="font-mono-spec text-11 uppercase mb-6 opacity-0 animate-fade-up delay-100" style="color: rgba(196,120,58,0.80); letter-spacing: 0.25em;">
        Clinical-Grade Adaptobiotics™ · Down-Regulate the Biological Tax
      </p>

      <h1 class="font-heading text-44 md:text-68 font-semibold mb-6 opacity-0 animate-fade-up delay-250" style="color: #F5F2EC; line-height: 1.05;">
        Your biology was not<br>built for this.
      </h1>

      <p class="font-heading text-22 md:text-28 font-light mb-6 opacity-0 animate-fade-up delay-300" style="color: #D4A97A; line-height: 1.3; max-width: 540px;">
        Down-regulate. Restore baseline. Adapt.
      </p>

      <p class="font-heading text-18 md:text-20 font-light mb-8 opacity-0 animate-fade-up delay-400" style="color: rgba(245,242,236,0.70); line-height: 1.7; max-width: 540px;">
        The Western diet, chronic stress, and modern environmental load inflict a biological tax on every system in your body. BaseCode builds clinical-grade protocols to bridge the gap between your biological baseline and the demands of the environment you actually live in.
      </p>

      <div class="flex flex-wrap items-center gap-4 mb-4 opacity-0 animate-fade-up delay-500">
        <a href="/products/origin" class="btn btn--primary cta-pulse">Start Your Protocol — $34/mo</a>
        <a href="/pages/quiz" class="font-heading text-15 font-light transition" style="color: #F5F2EC;">Take the Assessment →</a>
      </div>

      <!-- Trust signals row -->
      <div class="flex flex-wrap items-center gap-4 opacity-0 animate-fade-up delay-550" style="margin-bottom: 20px;">
        <span class="flex items-center gap-1.5 font-mono-spec text-10" style="color: rgba(245,242,236,0.55);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          30-Day Money Back
        </span>
        <span class="flex items-center gap-1.5 font-mono-spec text-10" style="color: rgba(245,242,236,0.55);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Free Shipping
        </span>
        <span class="flex items-center gap-1.5 font-mono-spec text-10" style="color: rgba(245,242,236,0.55);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C4783A" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Cancel Anytime
        </span>
      </div>
    </div>

    <!-- Right — Score teaser -->
    <div class="mt-10 md:mt-0 shrink-0 mx-auto md:mx-0" style="width: 100%; max-width: 360px;">
      <a
        href="/pages/quiz"
        data-score-teaser
        class="block rounded-2xl p-8 transition opacity-0 animate-fade-up delay-700"
        style="background: rgba(245,242,236,0.06); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(245,242,236,0.10);"
        aria-label="Take the Environmental Impact Score Quiz"
      >
        <p class="font-mono-spec text-10 uppercase text-center mb-6" style="color: rgba(196,120,58,0.80); letter-spacing: 0.25em;">
          Environmental Impact Score
        </p>

        <div class="flex justify-center mb-5">
          <div class="relative inline-flex items-center justify-center">
            <svg width="160" height="160" viewBox="0 0 160 160">
              <circle cx="80" cy="80" r="68" fill="none" stroke="rgba(245,242,236,0.08)" stroke-width="8"/>
              <circle
                data-teaser-ring
                cx="80" cy="80" r="68" fill="none" stroke="#C4783A" stroke-width="8"
                stroke-linecap="round"
                transform="rotate(-90 80 80)"
                style="transition: stroke-dashoffset 0.05s linear;"
              />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span data-teaser-count class="font-heading text-40 font-medium" style="color: #F5F2EC; line-height: 1;">0</span>
              <span class="font-mono-spec text-11" style="color: rgba(245,242,236,0.40); letter-spacing: 0.1em; margin-top: 2px;">/ 100</span>
            </div>
          </div>
        </div>

        <div class="flex justify-center mb-5">
          <span class="inline-block font-mono-spec text-10 uppercase rounded-full" style="background: rgba(196,120,58,0.15); color: #C4783A; border: 1px solid rgba(196,120,58,0.25); padding: 4px 12px; letter-spacing: 0.2em;">
            High Risk
          </span>
        </div>

        <p class="font-heading text-15 font-light text-center mb-6" style="color: rgba(245,242,236,0.65); line-height: 1.6;">
          Bloating, low energy, brain fog?<br>
          Discover your <span style="color: #C4783A;">biology score</span>.
        </p>

        <div class="flex justify-center">
          <span class="inline-flex items-center gap-2 font-heading text-14 font-semibold rounded-full" style="background: linear-gradient(135deg, #C4783A, #D4925A); color: #1C2E23; padding: 12px 28px;">
            Take the Free 2-Minute Quiz
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>

        <p class="font-mono-spec text-9 text-center mt-4 uppercase" style="color: rgba(245,242,236,0.25); letter-spacing: 0.15em;">
          Free · 7 Questions · Personalized Results
        </p>
      </a>
    </div>
  </div>

  <!-- Bounce chevron -->
  <div class="absolute animate-bounce-chevron" style="bottom: 32px; left: 50%; transform: translateX(-50%); z-index: 2;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,236,0.30)" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    }
  ]
}
{% endschema %}

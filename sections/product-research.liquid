{%- comment -%}
  Research credibility strip — appears after product hero.
  Shows journal names where supporting research was published.
{%- endcomment -%}

<div class="research-strip">
  <span class="font-mono-spec text-11 uppercase" style="color: rgba(245,242,236,0.50); letter-spacing: 0.08em;">Cited in:</span>
  <span class="research-strip__item">Nature Medicine</span>
  <span class="research-strip__item">Cell</span>
  <span class="research-strip__item">Gut</span>
  <span class="research-strip__item">PLOS Biology</span>
</div>

{% schema %}
{
  "name": "Research Strip",
  "class": "research-strip-section",
  "settings": []
}
{% endschema %}

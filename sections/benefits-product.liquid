{%- comment -%}BaseCode Root - benefits-product — Central product image with surrounding benefit blocks{%- endcomment -%}

{%- liquid
  assign section_id = 'benefits-product-' | append: section.id
  assign pt = section.settings.padding_top | default: 80
  assign pb = section.settings.padding_bottom | default: 80
  assign enable_anim = section.settings.enable_animation
  assign img_width_pct = section.settings.desktop_image_width | default: 40
  assign img_max_w = section.settings.desktop_image_max_width | default: 400
  assign total_blocks = section.blocks.size
  assign half = total_blocks | divided_by: 2
  assign left_side_count = half
  assign right_side_count = total_blocks | minus: half

  assign product = section.settings.product
  assign product_img = section.settings.desktop_image
  if product_img == blank and product != blank
    assign product_img = product.featured_image
  endif
  assign product_img_mobile = section.settings.mobile_image | default: product_img
-%}

<section
  id="{{ section_id }}"
  class="benefits-product{% if enable_anim %} anim-enabled{% endif %}"
  style="
    background-color: {{ section.settings.bg_color | default: '#FFFFFF' }};
    color: {{ section.settings.text_color | default: '#1C2E23' }};
    --bp-accent: {{ section.settings.accent_color | default: '#C4783A' }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  "
>
  <div class="{% if section.settings.full_width %}container--wide{% else %}container{% endif %}">

    {%- comment -%}---- Section header ----{%- endcomment -%}
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div
        class="benefits-product__header{% if enable_anim %} bp-fade-up{% endif %}"
        style="
          text-align: center;
          margin-bottom: var(--space-10, 2.5rem);
          max-width: 640px;
          margin-left: auto;
          margin-right: auto;
        "
      >
        {%- if section.settings.subheading != blank -%}
          <p
            class="benefits-product__subheading"
            style="
              font-family: var(--font-heading);
              font-size: var(--text-sm, 0.875rem);
              font-weight: 600;
              text-transform: uppercase;
              letter-spacing: 0.1em;
              color: var(--bp-accent);
              margin-bottom: var(--space-3, 0.75rem);
            "
          >
            {{- section.settings.subheading -}}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2
            class="benefits-product__heading"
            style="
              font-family: var(--font-heading);
              font-size: var(--text-4xl, 2.25rem);
              font-weight: 700;
              line-height: 1.15;
              margin: 0;
            "
          >
            {{- section.settings.heading -}}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%}---- Desktop: 3-column layout (left benefits | product image | right benefits) ----{%- endcomment -%}
    <div class="benefits-product__layout">

      {%- comment -%}---- Left column — first 3 blocks ----{%- endcomment -%}
      <div class="benefits-product__col benefits-product__col--left">
        {%- for block in section.blocks -%}
          {%- if forloop.index0 < half -%}

            {%- comment -%} Heading scale {%- endcomment -%}
            {%- if block.settings.heading_scale == 'small' -%}
              {%- assign b_h_fs = 'var(--text-sm, 0.875rem)' -%}
            {%- else -%}
              {%- assign b_h_fs = 'var(--text-base, 1rem)' -%}
            {%- endif -%}

            <div
              class="benefits-product__benefit{% if enable_anim %} bp-fade-up{% endif %} benefits-product__benefit--left"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Icon {%- endcomment -%}
              <div
                class="benefits-product__icon"
                aria-hidden="true"
              >
                {%- if block.settings.custom_icon != blank -%}
                  <img
                    src="{{ block.settings.custom_icon | image_url: width: 64 }}"
                    alt=""
                    width="32"
                    height="32"
                    loading="lazy"
                    style="width: 32px; height: 32px; object-fit: contain; display: block;"
                  >
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'check' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    {%- when 'shield' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    {%- when 'leaf' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-3.8 10-10 11z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
                    {%- when 'star' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    {%- when 'truck' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                    {%- when 'lock' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    {%- when 'flask' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6m-3 0v7l-5 9h12l-5-9V3"></path></svg>
                    {%- when 'heart' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    {%- when 'refresh' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                    {%- else -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
              <div class="benefits-product__benefit-text">
                {%- if block.settings.heading != blank -%}
                  <p
                    class="benefits-product__benefit-heading"
                    style="font-size: {{ b_h_fs }}; font-weight: 700; font-family: var(--font-heading); line-height: 1.2; margin-bottom: 0.2rem;"
                  >
                    {{- block.settings.heading -}}
                  </p>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p
                    class="benefits-product__benefit-body"
                    style="font-size: var(--text-sm, 0.875rem); line-height: 1.55; opacity: 0.8; margin: 0;"
                  >
                    {{- block.settings.text -}}
                  </p>
                {%- endif -%}
              </div>
            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%}---- Center column — product image ----{%- endcomment -%}
      <div
        class="benefits-product__product{% if enable_anim %} bp-fade-up{% endif %}"
        style="flex: 0 0 {{ img_width_pct }}%; max-width: {{ img_max_w }}px;"
      >
        {%- if product_img != blank -%}
          {%- comment -%} Mobile image {%- endcomment -%}
          {%- if product_img_mobile != blank and product_img_mobile != product_img -%}
            <img
              class="benefits-product__product-img benefits-product__product-img--mobile"
              src="{{ product_img_mobile | image_url: width: 800 }}"
              srcset="{{ product_img_mobile | image_url: width: 400 }} 400w, {{ product_img_mobile | image_url: width: 800 }} 800w"
              sizes="80vw"
              alt="{{ product_img_mobile.alt | default: section.settings.heading | escape }}"
              loading="lazy"
              width="{{ product_img_mobile.width }}"
              height="{{ product_img_mobile.height }}"
            >
          {%- endif -%}
          {%- comment -%} Desktop image {%- endcomment -%}
          <img
            class="benefits-product__product-img benefits-product__product-img--desktop{% if product_img_mobile != blank and product_img_mobile != product_img %} benefits-product__product-img--hide-mobile{% endif %}"
            src="{{ product_img | image_url: width: 800 }}"
            srcset="
              {{ product_img | image_url: width: 400 }} 400w,
              {{ product_img | image_url: width: 600 }} 600w,
              {{ product_img | image_url: width: 800 }} 800w
            "
            sizes="(max-width: 767px) 80vw, {{ img_width_pct }}vw"
            alt="{{ product_img.alt | default: section.settings.heading | escape }}"
            loading="lazy"
            width="{{ product_img.width }}"
            height="{{ product_img.height }}"
          >
        {%- else -%}
          <div
            style="
              width: 100%;
              aspect-ratio: 3/4;
              background: var(--color-cream, #F5F2EC);
              display: flex;
              align-items: center;
              justify-content: center;
              border-radius: 8px;
            "
          >
            <span style="color: var(--color-text-light, #888); font-size: 0.875rem;">Upload product image</span>
          </div>
        {%- endif -%}

        {%- comment -%}---- CTA button under product image (desktop) ----{%- endcomment -%}
        {%- if section.settings.button_text != blank -%}
          <div
            class="benefits-product__cta{% if enable_anim %} bp-fade-up{% endif %}"
            style="margin-top: var(--space-6, 1.5rem); text-align: center;"
          >
            {%- if section.settings.quick_buy and product != blank -%}
              {%- comment -%}Quick buy form — posts directly to cart{%- endcomment -%}
              {%- assign first_variant = product.selected_or_first_available_variant -%}
              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ first_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button
                  type="submit"
                  class="btn btn--{{ section.settings.button_style | default: 'primary' }}"
                  style="width: 100%;"
                >
                  {{- section.settings.button_text -}}
                </button>
              </form>
            {%- else -%}
              <a
                href="{{ section.settings.button_link | default: product.url | default: '#' }}"
                class="btn btn--{{ section.settings.button_style | default: 'primary' }}"
                style="width: 100%; display: block; text-align: center;"
              >
                {{- section.settings.button_text -}}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%}---- Right column — blocks 4-6 ----{%- endcomment -%}
      <div class="benefits-product__col benefits-product__col--right">
        {%- for block in section.blocks -%}
          {%- if forloop.index0 >= half -%}

            {%- if block.settings.heading_scale == 'small' -%}
              {%- assign b_h_fs = 'var(--text-sm, 0.875rem)' -%}
            {%- else -%}
              {%- assign b_h_fs = 'var(--text-base, 1rem)' -%}
            {%- endif -%}

            <div
              class="benefits-product__benefit{% if enable_anim %} bp-fade-up{% endif %} benefits-product__benefit--right"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Icon {%- endcomment -%}
              <div
                class="benefits-product__icon"
                aria-hidden="true"
              >
                {%- if block.settings.custom_icon != blank -%}
                  <img
                    src="{{ block.settings.custom_icon | image_url: width: 64 }}"
                    alt=""
                    width="32"
                    height="32"
                    loading="lazy"
                    style="width: 32px; height: 32px; object-fit: contain; display: block;"
                  >
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'check' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    {%- when 'shield' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    {%- when 'leaf' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-3.8 10-10 11z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
                    {%- when 'star' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    {%- when 'truck' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                    {%- when 'lock' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    {%- when 'flask' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6m-3 0v7l-5 9h12l-5-9V3"></path></svg>
                    {%- when 'heart' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    {%- when 'refresh' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                    {%- else -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
              <div class="benefits-product__benefit-text">
                {%- if block.settings.heading != blank -%}
                  <p
                    class="benefits-product__benefit-heading"
                    style="font-size: {{ b_h_fs }}; font-weight: 700; font-family: var(--font-heading); line-height: 1.2; margin-bottom: 0.2rem;"
                  >
                    {{- block.settings.heading -}}
                  </p>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p
                    class="benefits-product__benefit-body"
                    style="font-size: var(--text-sm, 0.875rem); line-height: 1.55; opacity: 0.8; margin: 0;"
                  >
                    {{- block.settings.text -}}
                  </p>
                {%- endif -%}
              </div>
            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>{%- comment -%}/layout{%- endcomment -%}

    {%- comment -%}---- Mobile CTA (shown below benefits on mobile) ----{%- endcomment -%}
    {%- if section.settings.button_text != blank -%}
      <div class="benefits-product__mobile-cta">
        {%- if section.settings.quick_buy and product != blank -%}
          {%- assign first_variant = product.selected_or_first_available_variant -%}
          <form action="/cart/add" method="post">
            <input type="hidden" name="id" value="{{ first_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="btn btn--{{ section.settings.button_style | default: 'primary' }}"
              style="width: 100%;"
            >
              {{- section.settings.button_text -}}
            </button>
          </form>
        {%- else -%}
          <a
            href="{{ section.settings.button_link | default: product.url | default: '#' }}"
            class="btn btn--{{ section.settings.button_style | default: 'primary' }}"
            style="width: 100%; display: block; text-align: center;"
          >
            {{- section.settings.button_text -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ── Layout ──────────────────────────────────────── */
  #{{ section_id }} .benefits-product__layout {
    display: flex;
    align-items: center;
    gap: var(--space-8, 2rem);
  }

  #{{ section_id }} .benefits-product__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-6, 1.5rem);
  }

  #{{ section_id }} .benefits-product__product {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Product image ───────────────────────────────── */
  #{{ section_id }} .benefits-product__product-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  #{{ section_id }} .benefits-product__product-img--hide-mobile { display: block; }
  #{{ section_id }} .benefits-product__product-img--mobile       { display: none; }

  /* ── Individual benefit ──────────────────────────── */
  #{{ section_id }} .benefits-product__benefit {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3, 0.75rem);
  }

  #{{ section_id }} .benefits-product__benefit--left {
    flex-direction: row;
    text-align: left;
  }

  #{{ section_id }} .benefits-product__benefit--right {
    flex-direction: row-reverse;
    text-align: right;
  }

  #{{ section_id }} .benefits-product__benefit--right .benefits-product__benefit-text {
    text-align: right;
  }

  #{{ section_id }} .benefits-product__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bp-accent);
    color: #fff;
    border-radius: 50%;
  }

  #{{ section_id }} .benefits-product__icon svg {
    display: block;
  }

  #{{ section_id }} .benefits-product__benefit-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  /* ── Mobile ──────────────────────────────────────── */
  #{{ section_id }} .benefits-product__mobile-cta {
    display: none;
  }

  @media (max-width: 767px) {
    #{{ section_id }} .benefits-product__layout {
      flex-direction: column;
      gap: var(--space-6, 1.5rem);
    }
    #{{ section_id }} .benefits-product__product {
      width: 80%;
      max-width: 320px;
      margin: 0 auto;
      flex: none;
    }
    /* Hide desktop CTA on mobile — use mobile-cta block */
    #{{ section_id }} .benefits-product__cta {
      display: none;
    }
    #{{ section_id }} .benefits-product__mobile-cta {
      display: block;
      margin-top: var(--space-6, 1.5rem);
    }
    #{{ section_id }} .benefits-product__col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5, 1.25rem) var(--space-4, 1rem);
    }
    /* Both left and right benefits go LTR on mobile */
    #{{ section_id }} .benefits-product__benefit--right {
      flex-direction: row;
      text-align: left;
    }
    #{{ section_id }} .benefits-product__benefit--right .benefits-product__benefit-text {
      text-align: left;
    }
    /* Product image mobile swap */
    #{{ section_id }} .benefits-product__product-img--hide-mobile { display: none; }
    #{{ section_id }} .benefits-product__product-img--mobile       { display: block; }
  }

  /* ── Animation ───────────────────────────────────── */
  {%- if enable_anim -%}
  #{{ section_id }}.anim-enabled .bp-fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #{{ section_id }}.anim-enabled.in-view .bp-fade-up {
    opacity: 1;
    transform: none;
  }
  #{{ section_id }}.anim-enabled.in-view .benefits-product__header { transition-delay: 0s; }
  #{{ section_id }}.anim-enabled.in-view .benefits-product__product { transition-delay: 0.1s; }
  {%- for block in section.blocks -%}
  #{{ section_id }}.anim-enabled.in-view .benefits-product__benefit:nth-of-type({{ forloop.index }}) {
    transition-delay: {{ forloop.index | times: 0.08 | plus: 0.1 }}s;
  }
  {%- endfor -%}
  {%- endif -%}
</style>

{%- if enable_anim -%}
<script>
(function () {
  var el = document.getElementById('{{ section_id }}');
  if (!el) return;
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    obs.observe(el);
  } else {
    el.classList.add('in-view');
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Benefits — Product",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Used for quick buy and as fallback product image source."
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",

      {%- for question in faq_questions -%}
        <div class="faq-item" style="border-bottom: 1px solid #DDD6CC;">
          <button class="faq-trigger font-heading text-16 md:text-18 font-medium text-left py-6 w-full flex justify-between items-center" style="color: #1C2E23;" aria-expanded="false">
            <span>{{ question }}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="faq-chevron flex-shrink-0 ml-4 transition" style="transition: transform 0.2s;">
              <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-content font-heading text-15 font-light" style="color: #4A5550; line-height: 1.8;">
            {{ faq_answers[forloop.index0] }}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="text-center mt-12 reveal-hidden">
      <p class="font-heading text-16 font-light mb-5" style="color: #4A5550;">
        Want the science behind the formula?
      </p>
      <a href="/pages/free-report" class="btn btn--primary inline-block">
        Download the Free Research Report

</section>

<!-- FAQPage Schema (JSON-LD) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for question in faq_questions -%}
    {
      "@type": "Question",
      "name": {{ question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_answers[forloop.index0] | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>

{% schema %}
{
  "name": "FAQ",
  "class": "faq-section",
  "settings": []
}
{% endschema %}

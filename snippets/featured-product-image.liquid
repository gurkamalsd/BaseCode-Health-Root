{%- comment -%}Featured product image snippet{%- endcomment -%}
{%- if section.settings.desktop_image != blank -%}
  <picture>
    {%- if section.settings.mobile_image != blank -%}
      <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 600 }}">
    {%- endif -%}
    <img
      src="{{ section.settings.desktop_image | image_url: width: 800 }}"
      alt="{{ featured.title | default: section.settings.heading }}"
      loading="lazy"
      style="max-width:{{ image_max }};margin:0 auto;"
    >
  </picture>
{%- elsif featured.featured_image -%}
  <img
    src="{{ featured.featured_image | image_url: width: 800 }}"
    alt="{{ featured.title }}"
    width="400"
    height="400"
    loading="lazy"
    style="max-width:{{ image_max }};margin:0 auto;"
  >
{%- else -%}
  <div style="width:300px;height:400px;background:rgba(255,255,255,0.1);border-radius:var(--radius-lg);margin:0 auto;display:flex;align-items:center;justify-content:center;">
    <span style="opacity:0.5;">Product Image</span>
  </div>
{%- endif -%}

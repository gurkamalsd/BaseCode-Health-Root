{%- comment -%}
  Product Recommendations Card snippet
  Usage: {% render 'pr-product-card', product: product, show_vendor: true, show_rating: true, ... %}
{%- endcomment -%}

<div class="pr__card{% if animate %} animate-fade{% endif %}"
  {% if animate %}style="transition-delay:{{ loop_index | times: 60 }}ms;"{% endif %}>

  {%- comment -%} Image {%- endcomment -%}
  <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    <div class="pr__card-image-wrapper" style="background: {{ bg | default: 'var(--color-cream)' }}; border-radius: var(--radius-lg); overflow: hidden; position: relative; aspect-ratio: {{ img_ratio | default: '1/1' }};">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w"
          sizes="(max-width: 767px) 45vw, 280px"
          alt="{{ product.featured_image.alt | default: product.title }}"
          width="300"
          height="300"
          loading="lazy"
          style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;"
        >
        {%- if show_hover and product.images.size > 1 -%}
          <img
            src="{{ product.images[1] | image_url: width: 600 }}"
            alt="{{ product.title }} - alternate"
            loading="lazy"
            style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.3s ease;"
            class="pr__card-hover-image"
          >
        {%- endif -%}
      {%- else -%}
        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--color-cream);">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
        </div>
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span style="position: absolute; top: var(--space-3); right: var(--space-3); background: var(--color-accent); color: var(--color-white); font-size: var(--text-xs); font-weight: 700; padding: var(--space-1) var(--space-2); border-radius: var(--radius-sm); text-transform: uppercase;">
          -{{ savings }}%
        </span>
      {%- endif -%}
    </div>
  </a>

  {%- comment -%} Info {%- endcomment -%}
  <div style="padding: var(--space-3) 0;">
    {%- if show_vendor and product.vendor != blank -%}
      <p style="font-size: var(--text-xs); color: {{ text_col | default: 'var(--color-text-light)' }}; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-1);">
        {{ product.vendor }}
      </p>
    {%- endif -%}

    <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">
      <h3 style="font-family: var(--font-heading); font-size: var(--text-base); font-weight: 500; color: {{ text_col | default: 'var(--color-text)' }}; margin-bottom: var(--space-1);">
        {{ product.title }}
      </h3>
    </a>

    <p style="font-size: var(--text-sm); color: {{ text_col | default: 'var(--color-text)' }};">
      {%- if product.compare_at_price > product.price -%}
        <span style="text-decoration: line-through; color: var(--color-text-light); margin-right: var(--space-2);">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      {{ product.price | money }}
    </p>

    {%- if show_rating -%}
      {% render 'star-rating', product: product %}
    {%- endif -%}
  </div>

  {%- if show_quick and product.available -%}
    <button
      class="btn btn--secondary"
      style="width: 100%; margin-top: var(--space-2); font-size: var(--text-sm); padding: var(--space-2) var(--space-4);"
      data-quick-add="{{ product.selected_or_first_available_variant.id }}"
    >
      Add to Cart
    </button>
  {%- endif -%}
</div>

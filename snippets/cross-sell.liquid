{%- comment -%}
  Cross-sell snippet for cart drawer
  Usage: {% render 'cross-sell' %}
  Shows product recommendations in the cart drawer to increase AOV
{%- endcomment -%}

{%- if settings.cross_sell_collection != blank -%}
  {%- assign cross_collection = collections[settings.cross_sell_collection] -%}
  {%- if cross_collection.products.size > 0 -%}
    <div class="cross-sell" style="padding:var(--space-4) var(--space-6); border-top:1px solid var(--color-border);">
      <h3 style="font-family:var(--font-heading); font-size:var(--text-sm); font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:var(--space-4);">
        {{ settings.cross_sell_heading | default: 'You might also like' }}
      </h3>
      <div style="display:flex; gap:var(--space-3); overflow-x:auto; scrollbar-width:none; padding-bottom:var(--space-2);">
        {%- for product in cross_collection.products limit: settings.cross_sell_limit | default: 4 -%}
          {%- assign in_cart = false -%}
          {%- for item in cart.items -%}
            {%- if item.product.id == product.id -%}
              {%- assign in_cart = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- unless in_cart -%}
            <div style="flex:0 0 120px; text-align:center;">
              <a href="{{ product.url }}" style="display:block;">
                <div style="width:100px; height:100px; border-radius:var(--radius-md); overflow:hidden; margin:0 auto var(--space-2); background:var(--color-cream);">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title }}" width="100" height="100" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
                  {%- endif -%}
                </div>
                <p style="font-size:var(--text-xs); font-weight:500; margin-bottom:var(--space-1); line-height:1.3;">{{ product.title | truncate: 30 }}</p>
                <p style="font-family:var(--font-mono); font-size:var(--text-xs);">{{ product.price | money }}</p>
              </a>
              <form action="/cart/add" method="post" style="margin-top:var(--space-2);">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="btn btn--secondary btn--sm" style="font-size:10px; padding:var(--space-1) var(--space-3);">
                  + Add
                </button>
              </form>
            </div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

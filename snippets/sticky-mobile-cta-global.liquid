{%- comment -%}
  Global sticky mobile CTA bar — appears on scroll on ALL pages.
  Shows on mobile only (<768px). Product pages use their own sticky CTA.
  JS: appears after scrolling 600px, hides when scrolling back up near top.
{%- endcomment -%}

{%- unless template contains 'product' -%}
<div id="global-sticky-cta" class="md:hidden" style="
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 900;
  padding: 12px 16px;
  background: #1C2E23;
  border-top: 1px solid rgba(196,120,58,0.20);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
">
  <div class="flex items-center justify-between gap-3">
    <div style="flex: 1; min-width: 0;">
      <p class="font-heading text-14 font-medium" style="color: #F5F2EC; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Origin — The First Adaptobiotic</p>
      <p class="font-heading text-12" style="color: rgba(245,242,236,0.55);">
        From $34/mo · Free shipping
      </p>
    </div>
    <a
      href="/products/origin"
      class="font-heading text-13 font-semibold rounded-full shrink-0 cta-pulse"
      style="background: linear-gradient(135deg, #C4783A, #D4925A); color: #1C2E23; padding: 11px 22px; box-shadow: 0 2px 12px rgba(196,120,58,0.30);"
    >
      Shop Now
    </a>
  </div>
</div>

<script>
  (function() {
    var cta = document.getElementById('global-sticky-cta');
    if (!cta) return;
    var shown = false;
    function check() {
      var y = window.scrollY || window.pageYOffset;
      if (y > 600 && !shown) {
        cta.style.transform = 'translateY(0)';
        shown = true;
      } else if (y <= 300 && shown) {
        cta.style.transform = 'translateY(100%)';
        shown = false;
      }
    }
    window.addEventListener('scroll', check, { passive: true });
  })();
</script>
{%- endunless -%}
